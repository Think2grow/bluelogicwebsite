---
import { getBaseOrganizationSchema } from "../utils/schema";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  schema?: any | any[]; // Allow pages to pass additional schema
}

const {
  title = "Blue Logic Water - Professional RO Systems",
  description = "Premium reverse osmosis water filtration systems for Salt Lake City homes. Half the cost, half the footprint, 10x quieter.",
  schema = null,
} = Astro.props;

// Get the current URL
const siteUrl = Astro.site?.toString() || "https://bluelogicwater.com";
const currentUrl = new URL(Astro.url.pathname, siteUrl).toString();

// Base organization schema for all pages
const baseSchema = getBaseOrganizationSchema(siteUrl);

// Combine base schema with page-specific schema
const allSchemas = schema
  ? Array.isArray(schema)
    ? [baseSchema, ...schema]
    : [baseSchema, schema]
  : [baseSchema];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- JSON-LD Structured Data -->
    {
      allSchemas.map((schemaItem) => (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(schemaItem)}
        />
      ))
    }
  </head>
  <body>
    <Header />

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --color-obsidian: oklch(0.2 0.02 270);
    --color-glacier: oklch(0.7 0.1 220);
    --color-quartz: oklch(0.95 0.01 90);
    --color-white: oklch(1 0 0);
  }

  html {
    font-family: "Inter", system-ui, sans-serif;
    background-color: var(--color-white);
    color: var(--color-obsidian);
  }

  body {
    margin: 0;
    padding: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
  }

  /* Prevent body scroll when sidebar is open */
  body.sidebar-open {
    overflow: hidden;
  }
</style>
