---
import {
  getBaseOrganizationSchema,
  DEFAULT_OG_METADATA,
  type OpenGraphMetadata,
} from "../utils/schema";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

// import fonts. Matches names in package.json and global.css
import "@fontsource/jetbrains-mono";
import "@fontsource/inter";
import "@fontsource/instrument-serif";

interface Props {
  title?: string;
  description?: string;
  schema?: any | any[]; // Allow pages to pass additional schema
  og?: Partial<OpenGraphMetadata>; // Allow pages to customize Open Graph metadata
}

const {
  title = "Blue Logic Water - Professional RO Systems",
  description = "Premium reverse osmosis water filtration systems for Salt Lake City homes. Half the cost, half the footprint, 10x quieter.",
  schema = null,
  og = {},
} = Astro.props;

// Get the current URL
const siteUrl = Astro.site?.toString() || "https://bluelogicwater.com";
const currentUrl = new URL(Astro.url.pathname, siteUrl).toString();

// Base organization schema for all pages
const baseSchema = getBaseOrganizationSchema(siteUrl);

// Merge default OG metadata with page-specific overrides
const ogMetadata: OpenGraphMetadata = {
  ...DEFAULT_OG_METADATA,
  ...og,
  url: og.url || currentUrl,
};

// Convert image to absolute URL if it's relative
const ogImageUrl = ogMetadata.image?.startsWith("http")
  ? ogMetadata.image
  : new URL(ogMetadata.image || DEFAULT_OG_METADATA.image!, siteUrl).toString();

// Combine base schema with page-specific schema
const allSchemas = schema
  ? Array.isArray(schema)
    ? [baseSchema, ...schema]
    : [baseSchema, schema]
  : [baseSchema];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Open Graph Meta Tags -->
    <meta property="og:title" content={ogMetadata.title} />
    <meta property="og:description" content={ogMetadata.description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={ogMetadata.imageWidth} />
    <meta property="og:image:height" content={ogMetadata.imageHeight} />
    <meta property="og:image:alt" content={ogMetadata.imageAlt} />
    <meta property="og:image:type" content={ogMetadata.imageType} />
    <meta property="og:url" content={ogMetadata.url} />
    <meta property="og:type" content={ogMetadata.type} />
    <meta property="og:site_name" content="Blue Logic Water" />

    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogMetadata.title} />
    <meta name="twitter:description" content={ogMetadata.description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD Structured Data -->
    {
      allSchemas.map((schemaItem) => (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(schemaItem)}
        />
      ))
    }
    
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-GCNVMD4Z7R"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-GCNVMD4Z7R');
    </script>

    <!-- ContentDSP Tracking -->
    <script is:inline>!function(s,a,e,v,n,t,z){if(s.saq)return;n=s.saq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!s._saq)s._saq=n;n.push=n;n.loaded=!0;n.version='1.0';n.queue=[];t=a.createElement(e);t.async=!0;t.src=v;z=a.getElementsByTagName(e)[0];z.parentNode.insertBefore(t,z)}(window,document,'script','https://contentdsp.com/events.js');saq('ts', 'pTI-0oKJkHPME2lozyEL0Q');</script>

    <script
      src="https://widgets.leadconnectorhq.com/loader.js"
      data-resources-url="https://widgets.leadconnectorhq.com/chat-widget/loader.js"
      data-widget-id="69e6e0281024ff50c0585ab1"
    ></script>
    
    <!-- astro view transitions -->
    <ClientRouter />
  </head>
  <body
    class="min-h-screen flex flex-col bg-background text-foreground font-sans m-0 p-0"
  >
    <Header />

    <main class="flex-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
