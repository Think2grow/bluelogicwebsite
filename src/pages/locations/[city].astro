---
import Layout from "../../layouts/Layout.astro";
import { getCityPaths, type CityData } from "../../data/cities";
import {
  getLocalBusinessSchema,
  getBreadcrumbSchema,
} from "../../utils/schema";

export const prerender = true;

// Generate static paths for all cities
export function getStaticPaths() {
  return getCityPaths();
}

// Get city data from props
const { cityData } = Astro.props as { cityData: CityData };

// Generate page-specific JSON-LD schemas
const siteUrl = Astro.site?.toString() || "https://bluelogicwater.com";
const currentUrl = new URL(Astro.url.pathname, siteUrl).toString();

const schemas = [
  getLocalBusinessSchema(siteUrl, cityData.name, "UT"),
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Locations", url: "/locations" },
    { name: cityData.name, url: `/locations/${cityData.slug}` },
  ]),
];
---

<Layout
  title={`Water Filtration ${cityData.name} - Blue Logic Water`}
  description={`Professional reverse osmosis systems for ${cityData.name} homes. Combat Utah's hard water with commercial-grade filtration at half the cost.`}
  schema={schemas}
>
  <section class="hero">
    <div class="container">
      <h1>Water Purification for {cityData.name}</h1>
      <p class="subtitle">
        Professional RO systems designed for {cityData.region}'s unique water
        challenges
      </p>
    </div>
  </section>

  <section class="water-quality">
    <div class="container">
      <h2>Understanding {cityData.name}'s Water</h2>

      <div class="water-stats">
        <div class="stat-card">
          <div class="stat-number">{cityData.tdsRange}</div>
          <div class="stat-label">Total Dissolved Solids (TDS)</div>
          <p>{cityData.description}</p>
        </div>

        <div class="stat-card">
          <div class="stat-number">{cityData.hardnessLevel}</div>
          <div class="stat-label">Water Hardness Rating</div>
          <p>
            {cityData.name} consistently experiences {
              cityData.hardnessLevel.toLowerCase()
            } water conditions.
          </p>
        </div>

        {
          cityData.population && (
            <div class="stat-card">
              <div class="stat-number">{cityData.population}</div>
              <div class="stat-label">Residents Served</div>
              <p>
                Serving the {cityData.name} community with professional water
                solutions.
              </p>
            </div>
          )
        }
      </div>

      <div class="water-info">
        <h3>Water Source: {cityData.waterSource}</h3>
        <p>
          {cityData.name}'s water supply presents unique challenges for
          homeowners:
        </p>
        <ul>
          {cityData.commonIssues.map((issue) => <li>{issue}</li>)}
        </ul>
      </div>

      {
        cityData.contaminantsExceedingGuidelines && (
          <div class="ewg-report">
            <div class="ewg-header">
              <h3>Environmental Working Group (EWG) Water Quality Report</h3>
              <p class="ewg-subtitle">
                Based on official utility testing data provided to EWG
              </p>
            </div>

            <div class="ewg-stats-row">
              <div class="ewg-stat-box alert">
                <div class="ewg-stat-value">
                  {cityData.contaminantsExceedingGuidelines}
                </div>
                <div class="ewg-stat-text">
                  Contaminants Exceed EWG Health Guidelines
                </div>
              </div>

              <div class="ewg-stat-box info">
                <div class="ewg-stat-value">{cityData.totalContaminants}</div>
                <div class="ewg-stat-text">Total Contaminants Detected</div>
              </div>

              <div class="ewg-stat-box">
                <div class="ewg-stat-value">✓</div>
                <div class="ewg-stat-text">{cityData.complianceStatus}</div>
              </div>
            </div>

            {cityData.topContaminants && (
              <div class="top-contaminants">
                <h4>Most Concerning Contaminants in {cityData.name}:</h4>
                <div class="contaminant-list">
                  {cityData.topContaminants.map((contaminant) => (
                    <div class="contaminant-item">
                      <span class="contaminant-alert">⚠</span>
                      <span class="contaminant-name">{contaminant}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}

            <div class="ewg-note">
              <p>
                <strong>What This Means:</strong> While {cityData.name}'s water
                meets federal drinking water standards, it contains contaminants
                at levels that exceed EWG's stricter health guidelines. Federal
                limits haven't been updated in nearly 20 years. Reverse osmosis
                filters remove virtually all these contaminants, providing an
                extra layer of protection for your family.
              </p>
            </div>

            {cityData.ewgTapwaterDatabaseUrl && (
              <div class="ewg-source">
                <a href={cityData.ewgTapwaterDatabaseUrl} target="_blank">
                  View Full EWG Report →
                </a>
              </div>
            )}
          </div>
        )
      }
    </div>
  </section>

  <section class="why-ro">
    <div class="container">
      <h2>Why Reverse Osmosis for {cityData.name} Homes?</h2>

      <div class="reason-grid">
        <div class="reason-card">
          <h3>Eliminates Hard Water</h3>
          <p>
            RO removes 99%+ of dissolved minerals, eliminating scale buildup on
            fixtures, appliances, and plumbing. No more spotty dishes or clogged
            showerheads.
          </p>
        </div>

        <div class="reason-card">
          <h3>Removes Contaminants</h3>
          <p>
            Beyond minerals, RO removes chlorine, PFAS, heavy metals, and other
            potential contaminants that simple filters can't touch.
          </p>
        </div>

        <div class="reason-card">
          <h3>Better for Your Health</h3>
          <p>
            Pure water means fewer skin irritations, better hydration, and peace
            of mind knowing what's NOT in your water.
          </p>
        </div>

        <div class="reason-card">
          <h3>Protects Your Investment</h3>
          <p>
            Extend the life of your appliances, water heaters, and plumbing by
            preventing mineral buildup and corrosion.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="blue-logic-difference">
    <div class="container">
      <h2>The Blue Logic Difference in {cityData.name}</h2>

      <div class="difference-grid">
        <div class="difference-card">
          <div class="icon">💰</div>
          <h3>Half the Cost</h3>
          <p>$15,000 vs $30,000+ competitors</p>
        </div>

        <div class="difference-card">
          <div class="icon">📐</div>
          <h3>Half the Footprint</h3>
          <p>Compact design perfect for modern homes</p>
        </div>

        <div class="difference-card">
          <div class="icon">🔇</div>
          <h3>10x Quieter</h3>
          <p>Whisper-quiet operation</p>
        </div>

        <div class="difference-card">
          <div class="icon">🏔️</div>
          <h3>Local Expertise</h3>
          <p>Built for Utah water, by Utah professionals</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Ready for Pure Water in {cityData.name}?</h2>
      <p>Schedule your free water purity audit today</p>
      <a href="/#contact" class="cta-button">Get Started</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: linear-gradient(
      135deg,
      oklch(0.7 0.1 220) 0%,
      oklch(0.85 0.05 220) 100%
    );
    color: white;
    padding: 6rem 2rem 4rem;
    text-align: center;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  h1 {
    font-family: "Instrument Serif", serif;
    font-size: 3.5rem;
    margin: 0 0 1rem;
    font-weight: 400;
  }

  .subtitle {
    font-size: 1.5rem;
    opacity: 0.95;
    margin: 0;
  }

  section {
    padding: 4rem 2rem;
  }

  h2 {
    font-family: "Instrument Serif", serif;
    font-size: 2.5rem;
    margin: 0 0 2rem;
    text-align: center;
    font-weight: 400;
  }

  h3 {
    font-family: "Instrument Serif", serif;
    font-size: 1.75rem;
    margin: 0 0 1rem;
    font-weight: 400;
  }

  .water-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .stat-card {
    background: oklch(0.98 0.005 220);
    padding: 2rem;
    border-radius: 1rem;
    text-align: center;
  }

  .stat-number {
    font-size: 3rem;
    font-weight: 700;
    color: oklch(0.7 0.1 220);
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: oklch(0.3 0.02 270);
  }

  .water-info {
    background: white;
    padding: 2rem;
    border-radius: 1rem;
    border: 1px solid oklch(0.95 0.01 90);
  }

  .water-info ul {
    margin: 1rem 0;
    padding-left: 1.5rem;
    line-height: 1.8;
  }

  .water-info li {
    margin-bottom: 0.75rem;
  }

  /* EWG Report Styles */
  .ewg-report {
    background: linear-gradient(
      135deg,
      oklch(0.98 0.005 220),
      oklch(0.995 0.001 90)
    );
    border: 2px solid oklch(0.7 0.1 220);
    border-radius: 1.25rem;
    padding: 3rem;
    margin-top: 3rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .ewg-header {
    margin-bottom: 2rem;
    border-bottom: 2px solid oklch(0.85 0.05 220);
    padding-bottom: 1.5rem;
  }

  .ewg-header h3 {
    margin: 0 0 0.5rem;
    color: oklch(0.2 0.02 270);
    font-size: 1.5rem;
  }

  .ewg-subtitle {
    font-size: 0.95rem;
    color: oklch(0.5 0.05 270);
    margin: 0;
    font-style: italic;
  }

  .ewg-stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .ewg-stat-box {
    background: white;
    padding: 1.5rem;
    border-radius: 0.875rem;
    text-align: center;
    border: 2px solid oklch(0.9 0.01 90);
    transition: all 0.3s ease;
  }

  .ewg-stat-box:hover {
    border-color: oklch(0.7 0.1 220);
    box-shadow: 0 2px 12px rgba(97, 137, 184, 0.15);
  }

  .ewg-stat-box.alert {
    border-color: oklch(0.65 0.15 25);
    background: linear-gradient(
      135deg,
      oklch(0.98 0.005 25),
      oklch(0.995 0.001 25)
    );
  }

  .ewg-stat-box.info {
    border-color: oklch(0.7 0.1 220);
    background: linear-gradient(
      135deg,
      oklch(0.98 0.005 220),
      oklch(0.995 0.001 220)
    );
  }

  .ewg-stat-value {
    font-size: 2.5rem;
    font-weight: 700;
    color: oklch(0.2 0.02 270);
    margin-bottom: 0.5rem;
  }

  .ewg-stat-box.alert .ewg-stat-value {
    color: oklch(0.6 0.15 25);
  }

  .ewg-stat-box.info .ewg-stat-value {
    color: oklch(0.6 0.12 220);
  }

  .ewg-stat-text {
    font-size: 0.95rem;
    font-weight: 600;
    color: oklch(0.4 0.05 270);
    line-height: 1.4;
  }

  .top-contaminants {
    background: white;
    padding: 2rem;
    border-radius: 0.875rem;
    margin-bottom: 2rem;
    border-left: 4px solid oklch(0.65 0.15 25);
  }

  .top-contaminants h4 {
    margin: 0 0 1.25rem;
    color: oklch(0.2 0.02 270);
    font-family: "Instrument Serif", serif;
    font-size: 1.25rem;
    font-weight: 400;
  }

  .contaminant-list {
    display: grid;
    gap: 1rem;
  }

  .contaminant-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: oklch(0.98 0.005 25);
    border-radius: 0.5rem;
    border: 1px solid oklch(0.9 0.01 25);
  }

  .contaminant-alert {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .contaminant-name {
    font-size: 1rem;
    color: oklch(0.2 0.02 270);
    font-weight: 500;
  }

  .ewg-note {
    background: oklch(0.96 0.01 60);
    padding: 1.75rem;
    border-radius: 0.875rem;
    border-left: 4px solid oklch(0.7 0.12 60);
    margin-bottom: 1.5rem;
    line-height: 1.7;
    color: oklch(0.25 0.02 90);
  }

  .ewg-note p {
    margin: 0;
    font-size: 0.95rem;
  }

  .ewg-source {
    text-align: center;
  }

  .ewg-source a {
    display: inline-block;
    color: oklch(0.6 0.12 220);
    text-decoration: none;
    font-weight: 600;
    padding: 0.75rem 1.5rem;
    border: 2px solid oklch(0.7 0.1 220);
    border-radius: 0.5rem;
    transition: all 0.3s ease;
  }

  .ewg-source a:hover {
    background: oklch(0.7 0.1 220);
    color: white;
  }

  .reason-grid,
  .difference-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .reason-card,
  .difference-card {
    background: white;
    padding: 2rem;
    border-radius: 1rem;
    border: 1px solid oklch(0.95 0.01 90);
  }

  .icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .blue-logic-difference {
    background: oklch(0.98 0.005 220);
  }

  .cta-section {
    background: oklch(0.2 0.02 270);
    color: white;
    text-align: center;
    padding: 5rem 2rem;
  }

  .cta-section h2 {
    color: white;
    margin-bottom: 1rem;
  }

  .cta-section p {
    font-size: 1.25rem;
    margin-bottom: 2rem;
  }

  .cta-button {
    display: inline-block;
    background: oklch(0.7 0.1 220);
    color: white;
    padding: 1.25rem 3rem;
    text-decoration: none;
    border-radius: 0.75rem;
    font-weight: 600;
    font-size: 1.125rem;
    transition: all 0.2s;
  }

  .cta-button:hover {
    background: oklch(0.75 0.12 220);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2.5rem;
    }

    .subtitle {
      font-size: 1.125rem;
    }

    h2 {
      font-size: 2rem;
    }

    .stat-number {
      font-size: 2.25rem;
    }

    .reason-grid,
    .difference-grid {
      grid-template-columns: 1fr;
    }

    .ewg-report {
      padding: 2rem;
      margin-top: 2rem;
    }

    .ewg-header h3 {
      font-size: 1.25rem;
    }

    .ewg-stats-row {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .ewg-stat-value {
      font-size: 2rem;
    }

    .top-contaminants {
      padding: 1.5rem;
    }

    .top-contaminants h4 {
      font-size: 1.125rem;
      margin-bottom: 1rem;
    }

    .contaminant-item {
      padding: 0.75rem;
    }

    .ewg-note {
      padding: 1.25rem;
      font-size: 0.9rem;
    }
  }
</style>
