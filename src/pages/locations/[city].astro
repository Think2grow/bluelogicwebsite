---
import Layout from "../../layouts/Layout.astro";
import { getCityPaths, type CityData } from "../../data/cities";
import {
  getLocalBusinessSchema,
  getBreadcrumbSchema,
} from "../../utils/schema";

export const prerender = true;

// Generate static paths for all cities
export function getStaticPaths() {
  return getCityPaths();
}

// Get city data from props
const { cityData } = Astro.props as { cityData: CityData };

// Generate page-specific JSON-LD schemas
const siteUrl = Astro.site?.toString() || "https://bluelogicwater.com";
const currentUrl = new URL(Astro.url.pathname, siteUrl).toString();

const schemas = [
  getLocalBusinessSchema(siteUrl, cityData.name, "UT"),
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Locations", url: "/locations" },
    { name: cityData.name, url: `/locations/${cityData.slug}` },
  ]),
];
---

<Layout
  title={`Water Filtration ${cityData.name} - Blue Logic Water`}
  description={`Professional reverse osmosis systems for ${cityData.name} homes. Combat Utah's hard water with commercial-grade filtration at half the cost.`}
  schema={schemas}
>
  <section class="hero-gradient-dark py-20 md:py-24 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-6xl font-serif mb-4 text-white">
        Water Purification for {cityData.name}
      </h1>
      <p class="text-xl md:text-2xl text-white/90">
        Professional RO systems designed for {cityData.region}'s unique water
        challenges
      </p>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-3xl md:text-4xl font-serif text-center mb-12 text-foreground"
      >
        Understanding {cityData.name}'s Water
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        <div class="stat-card">
          <div class="text-4xl md:text-5xl font-bold text-primary mb-2">
            {cityData.tdsRange}
          </div>
          <div class="text-lg font-semibold mb-4 text-foreground">
            Total Dissolved Solids (TDS)
          </div>
          <p class="text-muted-foreground">{cityData.description}</p>
        </div>

        <div class="stat-card">
          <div class="text-4xl md:text-5xl font-bold text-primary mb-2">
            {cityData.hardnessLevel}
          </div>
          <div class="text-lg font-semibold mb-4 text-foreground">
            Water Hardness Rating
          </div>
          <p class="text-muted-foreground">
            {cityData.name} consistently experiences {
              cityData.hardnessLevel.toLowerCase()
            } water conditions.
          </p>
        </div>

        {
          cityData.population && (
            <div class="stat-card">
              <div class="text-4xl md:text-5xl font-bold text-primary mb-2">
                {cityData.population}
              </div>
              <div class="text-lg font-semibold mb-4 text-foreground">
                Residents Served
              </div>
              <p class="text-muted-foreground">
                Serving the {cityData.name} community with professional water
                solutions.
              </p>
            </div>
          )
        }
      </div>

      <div class="water-info">
        <h3 class="text-2xl font-serif mb-4 text-foreground">
          Water Source: {cityData.waterSource}
        </h3>
        <p class="text-muted-foreground mb-4">
          {cityData.name}'s water supply presents unique challenges for
          homeowners:
        </p>
        <ul class="list-disc pl-6 text-muted-foreground space-y-3">
          {cityData.commonIssues.map((issue) => <li>{issue}</li>)}
        </ul>
      </div>

      {
        cityData.contaminantsExceedingGuidelines && (
          <div class="ewg-report">
            <div class="ewg-header">
              <h3 class="text-xl md:text-2xl font-serif text-foreground mb-2">
                Environmental Working Group (EWG) Water Quality Report
              </h3>
              <p class="text-muted-foreground italic">
                Based on official utility testing data provided to EWG
              </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
              <div class="ewg-stat-box alert">
                <div class="text-4xl font-bold text-destructive mb-2">
                  {cityData.contaminantsExceedingGuidelines}
                </div>
                <div class="text-sm font-semibold text-muted-foreground">
                  Contaminants Exceed EWG Health Guidelines
                </div>
              </div>

              <div class="ewg-stat-box info">
                <div class="text-4xl font-bold text-primary mb-2">
                  {cityData.totalContaminants}
                </div>
                <div class="text-sm font-semibold text-muted-foreground">
                  Total Contaminants Detected
                </div>
              </div>

              <div class="ewg-stat-box">
                <div class="text-4xl font-bold text-foreground mb-2">✓</div>
                <div class="text-sm font-semibold text-muted-foreground">
                  {cityData.complianceStatus}
                </div>
              </div>
            </div>

            {cityData.topContaminants && (
              <div class="top-contaminants">
                <h4 class="text-xl font-serif text-foreground mb-4">
                  Most Concerning Contaminants in {cityData.name}:
                </h4>
                <div class="space-y-3">
                  {cityData.topContaminants.map((contaminant) => (
                    <div class="contaminant-item">
                      <span class="text-2xl">⚠</span>
                      <span class="font-medium text-foreground">
                        {contaminant}
                      </span>
                    </div>
                  ))}
                </div>
              </div>
            )}

            <div class="ewg-note">
              <p>
                <strong>What This Means:</strong> While {cityData.name}'s water
                meets federal drinking water standards, it contains contaminants
                at levels that exceed EWG's stricter health guidelines. Federal
                limits haven't been updated in nearly 20 years. Reverse osmosis
                filters remove virtually all these contaminants, providing an
                extra layer of protection for your family.
              </p>
            </div>

            {cityData.ewgTapwaterDatabaseUrl && (
              <div class="text-center">
                <a
                  href={cityData.ewgTapwaterDatabaseUrl}
                  target="_blank"
                  class="inline-block text-primary font-semibold py-3 px-6 border-2 border-primary rounded-lg transition-all hover:bg-primary hover:text-white"
                >
                  View Full EWG Report →
                </a>
              </div>
            )}
          </div>
        )
      }
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-3xl md:text-4xl font-serif text-center mb-12 text-foreground"
      >
        Why Reverse Osmosis for {cityData.name} Homes?
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="reason-card">
          <h3 class="text-xl font-serif mb-4 text-foreground">
            Eliminates Hard Water
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            RO removes 99%+ of dissolved minerals, eliminating scale buildup on
            fixtures, appliances, and plumbing. No more spotty dishes or clogged
            showerheads.
          </p>
        </div>

        <div class="reason-card">
          <h3 class="text-xl font-serif mb-4 text-foreground">
            Removes Contaminants
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Beyond minerals, RO removes chlorine, PFAS, heavy metals, and other
            potential contaminants that simple filters can't touch.
          </p>
        </div>

        <div class="reason-card">
          <h3 class="text-xl font-serif mb-4 text-foreground">
            Better for Your Health
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Pure water means fewer skin irritations, better hydration, and peace
            of mind knowing what's NOT in your water.
          </p>
        </div>

        <div class="reason-card">
          <h3 class="text-xl font-serif mb-4 text-foreground">
            Protects Your Investment
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Extend the life of your appliances, water heaters, and plumbing by
            preventing mineral buildup and corrosion.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-3xl md:text-4xl font-serif text-center mb-12 text-foreground"
      >
        The Blue Logic Difference in {cityData.name}
      </h2>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="difference-card">
          <div class="text-5xl mb-4">💰</div>
          <h3 class="text-lg font-semibold mb-2 text-foreground">
            Half the Cost
          </h3>
          <p class="text-muted-foreground text-sm">
            $15,000 vs $30,000+ competitors
          </p>
        </div>

        <div class="difference-card">
          <div class="text-5xl mb-4">📐</div>
          <h3 class="text-lg font-semibold mb-2 text-foreground">
            Half the Footprint
          </h3>
          <p class="text-muted-foreground text-sm">
            Compact design perfect for modern homes
          </p>
        </div>

        <div class="difference-card">
          <div class="text-5xl mb-4">🔇</div>
          <h3 class="text-lg font-semibold mb-2 text-foreground">
            10x Quieter
          </h3>
          <p class="text-muted-foreground text-sm">Whisper-quiet operation</p>
        </div>

        <div class="difference-card">
          <div class="text-5xl mb-4">🏔️</div>
          <h3 class="text-lg font-semibold mb-2 text-foreground">
            Local Expertise
          </h3>
          <p class="text-muted-foreground text-sm">
            Built for Utah water, by Utah professionals
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-obsidian py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif mb-4 text-white">
        Ready for Pure Water in {cityData.name}?
      </h2>
      <p class="text-xl text-white/90 mb-8">
        Schedule your free water purity audit today
      </p>
      <a href="/#contact" class="btn btn-primary btn-lg">Get Started</a>
    </div>
  </section>
</Layout>

<style>
  @reference "../../styles/global.css";
  .hero-gradient-dark {
    @apply bg-linear-to-br from-primary to-primary/70;
  }

  .bg-obsidian {
    background-color: var(--color-obsidian);
  }

  .stat-card {
    @apply bg-card p-8 rounded-2xl text-center;
  }

  .water-info {
    @apply bg-card p-8 rounded-2xl border border-border;
  }

  .ewg-report {
    @apply bg-linear-to-br from-card to-background border-2 border-primary rounded-2xl p-8 md:p-12 mt-12;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .ewg-header {
    @apply mb-8 border-b-2 border-primary/30 pb-6;
  }

  .ewg-stat-box {
    @apply bg-background p-6 rounded-xl text-center border-2 border-border transition-all duration-300;
  }

  .ewg-stat-box:hover {
    @apply border-primary;
    box-shadow: 0 2px 12px rgba(97, 137, 184, 0.15);
  }

  .ewg-stat-box.alert {
    @apply border-destructive bg-destructive/5;
  }

  .ewg-stat-box.info {
    @apply border-primary bg-primary/5;
  }

  .top-contaminants {
    @apply bg-background p-6 rounded-xl mb-8 border-l-4 border-destructive;
  }

  .contaminant-item {
    @apply flex items-center gap-4 p-4 bg-destructive/5 rounded-lg border border-destructive/20;
  }

  .ewg-note {
    @apply bg-accent p-6 rounded-xl border-l-4 border-accent-foreground mb-6 leading-relaxed text-accent-foreground;
  }

  .reason-card {
    @apply bg-background p-8 rounded-2xl border border-border;
  }

  .difference-card {
    @apply bg-card p-6 rounded-2xl text-center border border-border;
  }
</style>
