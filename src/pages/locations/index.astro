---
import Layout from "../../layouts/Layout.astro";
import { cities } from "../../data/cities";
import { getBreadcrumbSchema } from "../../utils/schema";
import { Image } from "astro:assets";
import hardWaterBuildup from "../../assets/water_art/AdobeStock_684626411_hard_water_buildup_showerhead.jpeg";
import spaFacialImg from "../../assets/water_art/engin-akyurt-g-m8EDc4X6Q-unsplash_spa_facial.jpg";

export const prerender = true;

// Sort cities alphabetically
const sortedCities = [...cities].sort((a, b) => a.name.localeCompare(b.name));

// Generate page-specific JSON-LD schemas
const siteUrl = Astro.site?.toString() || "https://bluelogicwater.com";
const currentUrl = new URL("/locations", siteUrl).toString();

const schemas = [
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Locations", url: "/locations" },
  ]),
];
---

<Layout
  title="Water Filtration Locations - Blue Logic Water Utah"
  description="Find Blue Logic Water reverse osmosis systems in Salt Lake City, Park City, Provo, and other Utah cities. Professional water filtration for every location."
  schema={schemas}
>
  <section class="hero-gradient-dark py-20 md:py-24 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-6xl font-serif mb-4 text-white">
        Utah Water Solutions by Location
      </h1>
      <p class="text-xl md:text-2xl text-white/90">
        Professional reverse osmosis systems serving Utah's most demanding
        neighborhoods
      </p>
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="text-lg leading-relaxed text-muted-foreground">
          Utah's water challenges vary by location. From Salt Lake City's PFAS
          contamination to Lehi's extreme arsenic levels, each region has unique
          water quality concerns. <a
            href="/the-system"
            class="text-primary hover:underline font-semibold"
            >Blue Logic Water delivers location-specific solutions</a
          > that address your community's exact water profile.
        </p>
      </div>

      <!-- The Problem: Hard Water Visual -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
        <div>
          <Image
            src={hardWaterBuildup}
            alt="Severe mineral and scale buildup on a showerhead caused by Utah's hard water"
            class="rounded-2xl shadow-2xl w-full object-cover aspect-4/3"
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 100vw, 50vw"
            quality={50}
          />
          <p class="text-sm text-muted-foreground text-center mt-4 italic">
            Hard water damage: A common sight in Utah homes
          </p>
        </div>
        <div>
          <h2 class="text-3xl md:text-4xl font-serif mb-6 text-foreground">
            Utah's Water Challenge
          </h2>
          <p class="text-lg text-muted-foreground leading-relaxed mb-6">
            Utah has some of the hardest water in the nation. The minerals that
            make our mountains beautiful also leave scale buildup on your
            fixtures, shorten appliance lifespans, and affect your family's
            health.
          </p>
          <p class="text-lg text-muted-foreground leading-relaxed mb-8">
            Every city faces unique challenges—from PFAS in northern Utah to
            arsenic in the south. <a
              href="/the-system"
              class="text-primary hover:underline font-semibold"
              >That's why Blue Logic designs location-specific solutions</a
            >.
          </p>
          <a
            href="/#contact"
            class="text-primary font-semibold text-lg hover:opacity-80 transition-opacity"
          >
            Schedule Your Local Water Audit →
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-8">
        {
          sortedCities.map((city) => (
            <a href={`/locations/${city.slug}`} class="location-card">
              <div class="card-header">
                <h2 class="text-2xl font-serif text-foreground mb-2">
                  {city.name}
                </h2>
                <p class="text-sm font-medium text-muted-foreground">
                  {city.region}
                </p>
              </div>

              <div class="card-content">
                <div class="stat-row">
                  <span class="stat-label">Water Hardness:</span>
                  <span class="stat-value">{city.hardnessLevel}</span>
                </div>

                <div class="stat-row">
                  <span class="stat-label">TDS Range:</span>
                  <span class="stat-value">{city.tdsRange}</span>
                </div>

                {city.contaminantsExceedingGuidelines && (
                  <div class="stat-row-alert">
                    <span class="stat-label">EWG Concerns:</span>
                    <span class="text-destructive font-bold">
                      {city.contaminantsExceedingGuidelines} contaminants
                    </span>
                  </div>
                )}

                <p class="text-sm text-muted-foreground leading-relaxed mt-4">
                  {city.description}
                </p>
              </div>

              <div class="card-footer">
                <span class="text-primary font-semibold">View Details →</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-3xl md:text-4xl font-serif text-center mb-12 text-foreground"
      >
        Why Location Matters
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="reason-card">
          <div class="text-5xl mb-4">🗺️</div>
          <h3 class="text-xl font-serif mb-4 text-foreground">
            Different Water Sources
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Each Utah city draws from different water sources—mountain
            watersheds, valley aquifers, or purchased surface water—each with
            <a
              href="/the-value"
              class="text-primary hover:underline font-semibold"
              >distinct mineral and contaminant profiles</a
            >.
          </p>
        </div>

        <div class="reason-card">
          <div class="text-5xl mb-4">⚡</div>
          <h3 class="text-xl font-serif mb-4 text-foreground">
            Unique Contaminants
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            From arsenic in southern valleys to PFAS in northern supplies, your
            location determines which contaminants pose the greatest health
            risk.
          </p>
        </div>

        <div class="reason-card">
          <div class="text-5xl mb-4">💰</div>
          <h3 class="text-xl font-serif mb-4 text-foreground">
            Tailored Solutions
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            <a
              href="/the-system"
              class="text-primary hover:underline font-semibold"
              >Blue Logic designs systems specifically for your location's water
              profile</a
            >, ensuring maximum contaminant removal without overengineering.
          </p>
        </div>

        <div class="reason-card">
          <div class="text-5xl mb-4">🏘️</div>
          <h3 class="text-xl font-serif mb-4 text-foreground">
            Local Expertise
          </h3>
          <a href="/our-team" class="text-primary hover:underline font-semibold"
            >Our team knows Utah water</a
          >
          <p class="text-muted-foreground leading-relaxed">
            Our team knows Utah water. We understand the seasonal variations,
            the infrastructure quirks, and the exact challenges your
            neighborhood faces.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- The Solution: Premium Results -->
  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <h2 class="text-3xl md:text-4xl font-serif mb-6 text-foreground">
            The Blue Logic Difference
          </h2>
          <p class="text-lg text-muted-foreground leading-relaxed mb-6">
            Experience what pure water feels like. Softer skin, shinier hair,
            and that spa-like sensation—every single day. No more worrying about
            what's in your water.
          </p>
          <p class="text-lg text-muted-foreground leading-relaxed mb-8">
            Our whole-home systems are engineered specifically for Utah's unique
            water challenges, delivering premium results regardless of your
            location.
          </p>
          <a
            href="/#contact"
            class="text-primary font-semibold text-lg hover:opacity-80 transition-opacity"
          >
            Find Your Location's Solution →
          </a>
        </div>
        <div class="order-1 lg:order-2">
          <Image
            src={spaFacialImg}
            alt="Woman enjoying spa-quality water treatment, glowing healthy skin"
            class="rounded-2xl shadow-2xl w-full object-cover aspect-4/3"
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 100vw, 50vw"
            quality={50}
          />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-obsidian py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif mb-4 text-white">
        Don't See Your Location?
      </h2>
      <p class="text-lg text-white/90 mb-8">
        Blue Logic Water serves the greater Salt Lake Valley and surrounding
        regions. If your city isn't listed, we likely still serve your area. <a
          href="/common-questions"
          class="underline hover:no-underline"
          >Check our FAQ for a full service list</a
        > or <a href="/#contact" class="underline hover:no-underline"
          >reach out directly</a
        >.
      </p>
      <a href="/#contact" class="btn btn-primary btn-lg"
        >Contact Us to Serve Your Area</a
      >
    </div>
  </section>
</Layout>

<style>
  @reference "../../styles/global.css";
  .hero-gradient-dark {
    @apply bg-linear-to-br from-primary to-primary/70;
  }

  .bg-obsidian {
    background-color: var(--color-obsidian);
  }

  .location-card {
    @apply flex flex-col bg-background rounded-2xl overflow-hidden no-underline border-2 border-border transition-all duration-300;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .location-card:hover {
    @apply border-primary -translate-y-1;
    box-shadow: 0 12px 32px rgba(97, 137, 184, 0.12);
  }

  .card-header {
    @apply p-6 pb-4 border-b border-border bg-card;
  }

  .card-content {
    @apply p-6 flex-1;
  }

  .stat-row {
    @apply flex justify-between items-center py-3 border-b border-border text-sm;
  }

  .stat-row:last-of-type {
    @apply border-b-0 pb-0 mb-0;
  }

  .stat-label {
    @apply font-semibold text-muted-foreground;
  }

  .stat-value {
    @apply text-foreground font-medium;
  }

  .stat-row-alert {
    @apply flex justify-between items-center p-3 rounded-lg bg-destructive/10 my-2;
  }

  .card-footer {
    @apply p-4 border-t border-border bg-card/50;
  }

  .reason-card {
    @apply bg-card p-8 rounded-2xl text-center border border-border transition-all duration-300;
  }

  .reason-card:hover {
    @apply border-primary;
    box-shadow: 0 8px 24px rgba(97, 137, 184, 0.1);
  }
</style>
