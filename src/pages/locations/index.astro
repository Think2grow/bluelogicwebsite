---
import Layout from "../../layouts/Layout.astro";
import { cities } from "../../data/cities";
import { getBreadcrumbSchema } from "../../utils/schema";

export const prerender = true;

// Sort cities alphabetically
const sortedCities = [...cities].sort((a, b) => a.name.localeCompare(b.name));

// Generate page-specific JSON-LD schemas
const siteUrl = Astro.site?.toString() || "https://bluelogicwater.com";
const currentUrl = new URL("/locations", siteUrl).toString();

const schemas = [
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Locations", url: "/locations" },
  ]),
];
---

<Layout
  title="Water Filtration Locations - Blue Logic Water Utah"
  description="Find Blue Logic Water reverse osmosis systems in Salt Lake City, Park City, Provo, and other Utah cities. Professional water filtration for every location."
  schema={schemas}
>
  <section class="hero">
    <div class="container">
      <h1>Utah Water Solutions by Location</h1>
      <p class="subtitle">
        Professional reverse osmosis systems serving Utah's most demanding
        neighborhoods
      </p>
    </div>
  </section>

  <section class="locations-directory">
    <div class="container">
      <div class="intro-text">
        <p>
          Utah's water challenges vary by location. From Salt Lake City's PFAS
          contamination to Lehi's extreme arsenic levels, each region has unique
          water quality concerns. Blue Logic Water delivers location-specific
          solutions that address your community's exact water profile.
        </p>
      </div>

      <div class="locations-grid">
        {
          sortedCities.map((city) => (
            <a href={`/locations/${city.slug}`} class="location-card">
              <div class="card-header">
                <h2 class="city-name">{city.name}</h2>
                <p class="region">{city.region}</p>
              </div>

              <div class="card-content">
                <div class="stat-row">
                  <span class="stat-label">Water Hardness:</span>
                  <span class="stat-value">{city.hardnessLevel}</span>
                </div>

                <div class="stat-row">
                  <span class="stat-label">TDS Range:</span>
                  <span class="stat-value">{city.tdsRange}</span>
                </div>

                {city.contaminantsExceedingGuidelines && (
                  <div class="stat-row risk-alert">
                    <span class="stat-label">EWG Concerns:</span>
                    <span class="stat-value alert">
                      {city.contaminantsExceedingGuidelines} contaminants
                    </span>
                  </div>
                )}

                <p class="card-description">{city.description}</p>
              </div>

              <div class="card-footer">
                <span class="cta-text">View Details →</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="why-location-matters">
    <div class="container">
      <h2>Why Location Matters</h2>

      <div class="reasons-grid">
        <div class="reason-card">
          <div class="icon">🗺️</div>
          <h3>Different Water Sources</h3>
          <p>
            Each Utah city draws from different water sources—mountain
            watersheds, valley aquifers, or purchased surface water—each with
            distinct mineral and contaminant profiles.
          </p>
        </div>

        <div class="reason-card">
          <div class="icon">⚡</div>
          <h3>Unique Contaminants</h3>
          <p>
            From arsenic in southern valleys to PFAS in northern supplies, your
            location determines which contaminants pose the greatest health
            risk.
          </p>
        </div>

        <div class="reason-card">
          <div class="icon">💰</div>
          <h3>Tailored Solutions</h3>
          <p>
            Blue Logic designs systems specifically for your location's water
            profile, ensuring maximum contaminant removal without
            overengineering.
          </p>
        </div>

        <div class="reason-card">
          <div class="icon">🏘️</div>
          <h3>Local Expertise</h3>
          <p>
            Our team knows Utah water. We understand the seasonal variations,
            the infrastructure quirks, and the exact challenges your
            neighborhood faces.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Don't See Your Location?</h2>
      <p>
        Blue Logic Water serves the greater Salt Lake Valley and surrounding
        regions. If your city isn't listed, we still serve your area.
      </p>
      <a href="/#contact" class="cta-button">Contact Us to Serve Your Area</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: linear-gradient(
      135deg,
      oklch(0.7 0.1 220) 0%,
      oklch(0.85 0.05 220) 100%
    );
    color: white;
    padding: 6rem 2rem 4rem;
    text-align: center;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  h1 {
    font-family: "Instrument Serif", serif;
    font-size: 3.5rem;
    margin: 0 0 1rem;
    font-weight: 400;
  }

  .subtitle {
    font-size: 1.5rem;
    opacity: 0.95;
    margin: 0;
  }

  section {
    padding: 4rem 2rem;
  }

  h2 {
    font-family: "Instrument Serif", serif;
    font-size: 2.5rem;
    margin: 0 0 2rem;
    text-align: center;
    font-weight: 400;
  }

  h3 {
    font-family: "Instrument Serif", serif;
    font-size: 1.75rem;
    margin: 0 0 1rem;
    font-weight: 400;
  }

  .locations-directory {
    background: oklch(0.98 0.005 220);
  }

  .intro-text {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 3rem;
    font-size: 1.1rem;
    line-height: 1.8;
    color: oklch(0.3 0.02 270);
  }

  .locations-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .location-card {
    display: flex;
    flex-direction: column;
    background: white;
    border-radius: 1rem;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    border: 2px solid oklch(0.95 0.01 90);
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .location-card:hover {
    border-color: oklch(0.7 0.1 220);
    box-shadow: 0 12px 32px rgba(97, 137, 184, 0.12);
    transform: translateY(-4px);
  }

  .card-header {
    background: linear-gradient(
      135deg,
      oklch(0.95 0.01 220),
      oklch(0.98 0.005 220)
    );
    padding: 2rem 1.5rem 1.5rem;
    border-bottom: 1px solid oklch(0.9 0.01 220);
  }

  .city-name {
    font-size: 1.75rem;
    margin: 0 0 0.5rem;
    color: oklch(0.2 0.02 270);
    font-family: "Instrument Serif", serif;
    font-weight: 400;
  }

  .region {
    font-size: 0.95rem;
    color: oklch(0.5 0.05 270);
    margin: 0;
    font-weight: 500;
  }

  .card-content {
    padding: 1.75rem 1.5rem;
    flex-grow: 1;
  }

  .stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0;
    border-bottom: 1px solid oklch(0.95 0.01 90);
    font-size: 0.95rem;
  }

  .stat-row:last-of-type {
    border-bottom: none;
    padding-bottom: 1rem;
    margin-bottom: 1rem;
  }

  .stat-label {
    font-weight: 600;
    color: oklch(0.5 0.05 270);
  }

  .stat-value {
    color: oklch(0.3 0.02 270);
    font-weight: 500;
  }

  .stat-row.risk-alert {
    background: oklch(0.98 0.005 25);
    padding: 0.75rem;
    border-radius: 0.5rem;
    border: none;
    margin: 0.5rem 0;
  }

  .stat-value.alert {
    color: oklch(0.6 0.15 25);
    font-weight: 700;
  }

  .card-description {
    font-size: 0.9rem;
    color: oklch(0.45 0.02 270);
    line-height: 1.6;
    margin: 0;
  }

  .card-footer {
    padding: 1rem 1.5rem;
    border-top: 1px solid oklch(0.95 0.01 90);
    background: oklch(0.99 0.001 90);
  }

  .cta-text {
    color: oklch(0.6 0.12 220);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .location-card:hover .cta-text {
    color: oklch(0.65 0.15 220);
  }

  .why-location-matters {
    background: white;
  }

  .reasons-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
  }

  .reason-card {
    background: oklch(0.98 0.005 220);
    padding: 2rem;
    border-radius: 1rem;
    text-align: center;
    border: 1px solid oklch(0.95 0.01 90);
    transition: all 0.3s ease;
  }

  .reason-card:hover {
    border-color: oklch(0.7 0.1 220);
    box-shadow: 0 8px 24px rgba(97, 137, 184, 0.1);
  }

  .icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .reason-card h3 {
    margin: 0 0 1rem;
    font-size: 1.25rem;
  }

  .reason-card p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: oklch(0.45 0.02 270);
  }

  .cta-section {
    background: oklch(0.2 0.02 270);
    color: white;
    text-align: center;
    padding: 5rem 2rem;
  }

  .cta-section h2 {
    color: white;
    margin-bottom: 1rem;
  }

  .cta-section p {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    opacity: 0.95;
  }

  .cta-button {
    display: inline-block;
    background: oklch(0.7 0.1 220);
    color: white;
    padding: 1.25rem 3rem;
    text-decoration: none;
    border-radius: 0.75rem;
    font-weight: 600;
    font-size: 1.125rem;
    transition: all 0.2s;
  }

  .cta-button:hover {
    background: oklch(0.75 0.12 220);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2.5rem;
    }

    .subtitle {
      font-size: 1.125rem;
    }

    h2 {
      font-size: 2rem;
    }

    section {
      padding: 3rem 1rem;
    }

    .locations-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .card-header {
      padding: 1.5rem 1.25rem 1.25rem;
    }

    .city-name {
      font-size: 1.5rem;
    }

    .card-content {
      padding: 1.25rem 1.25rem;
    }

    .reasons-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .reason-card h3 {
      font-size: 1.125rem;
    }

    .cta-button {
      padding: 1rem 2rem;
      font-size: 1rem;
    }
  }
</style>
