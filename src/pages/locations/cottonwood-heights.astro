---
import Layout from "../../layouts/Layout.astro";
import LeadForm from "../../components/LeadForm.astro";
import Reviews from "../../components/Reviews.astro";
import { getLocalBusinessSchema, getFAQSchema, getBreadcrumbSchema } from "../../utils/schema";

export const prerender = true;

const siteUrl = "https://www.bluelogicwater.com";

const faqs = [
  {
    question: "What's in Cottonwood Heights' tap water?",
    answer: "Cottonwood Heights receives water from the Salt Lake City Department of Public Utilities system — the same source as Salt Lake City and Millcreek. The EWG Tap Water Database identifies 16 contaminants above EWG health guidelines, including arsenic at 135x, PFAS (perfluorohexane sulfonate at 404x), and dichloroacetic acid at 101x. Water is hard at approximately 10–12 grains per gallon. All levels are within federal legal limits.",
  },
  {
    question: "Cottonwood Heights has newer, premium homes. Does the water quality differ from older Salt Lake City neighborhoods?",
    answer: "No. The source water is the same regardless of when the home was built or what price bracket it's in. Cottonwood Heights receives water from the same SLC Department of Public Utilities system that serves older city neighborhoods — with the same PFAS and arsenic profile. Newer plumbing means you don't have the legacy scale buildup of older pipes, but incoming water quality is identical to other SLC system-served communities.",
  },
  {
    question: "Is the premium home market in Cottonwood Heights a good fit for Blue Logic?",
    answer: "Yes — and it's one of Blue Logic's strongest markets. Premium homes in Cottonwood Heights have high-end finishes (stone counters, glass shower enclosures, premium fixtures) that show hard water and chlorine damage quickly. Homeowners in this market also tend to have higher health-consciousness around what they and their families drink and bathe in. Blue Logic's compact, quiet system design is well-suited to Cottonwood Heights' premium utility rooms.",
  },
  {
    question: "What system does Blue Logic recommend for Cottonwood Heights?",
    answer: "Given the PFAS and arsenic profile (both well above EWG guidelines) and the premium home profile of most Cottonwood Heights properties, whole-home reverse osmosis is the most complete recommendation for most homeowners. The RO membrane addresses PFAS and arsenic at the molecular level, while the pre-filtration stages handle hardness, chlorine, and taste. Your free water test confirms which configuration is right.",
  },
];

const schemas = [
  getLocalBusinessSchema(siteUrl, "Cottonwood Heights"),
  getFAQSchema(faqs),
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Locations", url: "/locations/" },
    { name: "Cottonwood Heights", url: "/locations/cottonwood-heights/" },
  ]),
];
---

<Layout
  title="Water Treatment Cottonwood Heights Utah | Blue Logic Water"
  description="Cottonwood Heights water has PFAS at 404x and arsenic at 135x the EWG health guideline — same SLC water system. Blue Logic installs whole-home RO for Cottonwood Heights. Free water test."
  schema={schemas}
>
  <section class="hero-gradient-dark py-20 md:py-28 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-widest text-white/70 mb-4">
        Salt Lake County · SLC Water System · Butler · Rudy's Farm Area
      </p>
      <h1 class="text-4xl md:text-5xl font-serif mb-6 text-white leading-tight">
        Water Treatment for Cottonwood Heights Homes
      </h1>
      <p class="text-lg md:text-xl text-white/90 max-w-3xl mx-auto mb-8 leading-relaxed">
        Cottonwood Heights draws from the Salt Lake City water system — with PFAS at 404x
        and arsenic at 135x the EWG health guideline. Blue Logic installs compact, quiet
        whole-home RO and filtration systems built for this premium market.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/free-water-test/" class="inline-block bg-white text-primary font-semibold text-lg px-8 py-4 rounded-full shadow-lg hover:bg-white/90 transition-all">
          Schedule Free Water Test →
        </a>
        <a href="tel:+18019802583" class="inline-block border-2 border-white/50 text-white font-semibold text-lg px-8 py-4 rounded-full hover:bg-white/10 transition-all">
          Call (801) 980-2583
        </a>
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif text-center mb-4 text-foreground">
        Cottonwood Heights Water Quality Profile
      </h2>
      <p class="text-xs text-muted-foreground text-center max-w-2xl mx-auto mb-10">
        Data from the EWG Tap Water Database for the Salt Lake City water system serving Cottonwood Heights.
        All levels meet federal legal standards.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
        <div class="stat-box stat-box-alert">
          <div class="text-4xl font-bold text-destructive mb-2">404x</div>
          <div class="font-semibold text-foreground mb-1">PFAS vs. EWG Guideline</div>
          <p class="text-xs text-muted-foreground">Perfluorohexane sulfonate — same SLC system data. Federally compliant.</p>
        </div>
        <div class="stat-box stat-box-alert">
          <div class="text-4xl font-bold text-destructive mb-2">135x</div>
          <div class="font-semibold text-foreground mb-1">Arsenic vs. EWG Guideline</div>
          <p class="text-xs text-muted-foreground">Naturally occurring. Same profile as Salt Lake City.</p>
        </div>
        <div class="stat-box stat-box-primary">
          <div class="text-4xl font-bold text-primary mb-2">~10–12 GPG</div>
          <div class="font-semibold text-foreground mb-1">Water Hardness</div>
          <p class="text-xs text-muted-foreground">Hard — causes scale on premium fixtures and inside appliances.</p>
        </div>
      </div>

      <div class="bg-card rounded-2xl border border-border p-6 md:p-8 mb-6">
        <h3 class="text-xl font-semibold mb-4 text-foreground">Top Contaminants Per EWG Data</h3>
        <div class="space-y-3">
          <div class="contaminant-row">
            <span class="font-medium text-foreground">Perfluorohexane sulfonate (PFAS)</span>
            <span class="badge badge-alert">404x EWG health guideline</span>
          </div>
          <div class="contaminant-row">
            <span class="font-medium text-foreground">Arsenic</span>
            <span class="badge badge-alert">135x EWG health guideline</span>
          </div>
          <div class="contaminant-row">
            <span class="font-medium text-foreground">Dichloroacetic acid (HAA)</span>
            <span class="badge badge-alert">101x EWG health guideline</span>
          </div>
          <div class="contaminant-row">
            <span class="font-medium text-foreground">Water hardness</span>
            <span class="badge badge-primary">~10–12 GPG — Hard</span>
          </div>
        </div>
        <div class="mt-5 pt-5 border-t border-border">
          <a href="https://www.ewg.org/tapwater/system.php?pws=UTAH18026" target="_blank" rel="noopener" class="text-primary text-sm underline">
            Full EWG Report for SLC Water System (serves Cottonwood Heights) →
          </a>
        </div>
      </div>

      <div class="bg-card rounded-xl border border-border p-6">
        <h3 class="text-lg font-semibold mb-3 text-foreground">Why Premium Homes Benefit Most</h3>
        <p class="text-sm text-muted-foreground leading-relaxed mb-3">
          Cottonwood Heights' upscale housing stock — with natural stone countertops, high-end glass
          shower enclosures, premium fixtures, and expensive appliances — is particularly vulnerable to
          the visible effects of hard water. Mineral deposits etch natural stone permanently. Hard water
          films on glass don't come off without acid-based cleaners. Scale inside premium appliances
          shortens their lifespan and voids some manufacturer warranties.
        </p>
        <p class="text-sm text-muted-foreground leading-relaxed">
          Blue Logic's compact system design — roughly half the physical size of traditional whole-home
          systems — fits in Cottonwood Heights' modern utility rooms without requiring reconfiguration.
          The 10x quieter operation is particularly relevant for homes where the utility room is near
          a master suite or home office.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <Reviews compact={true} heading="What Utah Homeowners Say About Blue Logic" />
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-10 text-foreground">
        Cottonwood Heights Water Treatment — Common Questions
      </h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item group">
            <summary class="faq-question">
              {faq.question}
              <span class="faq-icon group-open:rotate-45 transition-transform">+</span>
            </summary>
            <div class="faq-answer">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-card py-10 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sm font-semibold text-foreground mb-4">Also serving nearby communities:</p>
      <div class="flex flex-wrap justify-center gap-3">
        {[{name:"Salt Lake City",slug:"salt-lake-city"},{name:"Millcreek",slug:"millcreek"},{name:"Sandy",slug:"sandy"},{name:"Draper",slug:"draper"}].map((c) => (
          <a href={`/locations/${c.slug}/`} class="related-link">{c.name}</a>
        ))}
        <a href="/locations/" class="related-link">All Locations →</a>
      </div>
    </div>
  </section>

  <section class="bg-primary/5 py-16 md:py-20 px-4">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-4 text-foreground">
        Schedule Your Free Cottonwood Heights Water Test
      </h2>
      <p class="text-muted-foreground text-center mb-10">
        Blue Logic serves Cottonwood Heights and all of Salt Lake County. A specialist tests
        your water on-site — no cost, no obligation.
      </p>
      <LeadForm />
    </div>
  </section>
</Layout>

<style>
  @reference "../../styles/global.css";
  .hero-gradient-dark { @apply bg-linear-to-br from-primary to-primary/70; }
  .stat-box { @apply bg-card p-6 rounded-xl border-2 border-border text-center; }
  .stat-box-alert { @apply border-destructive/30 bg-destructive/5; }
  .stat-box-primary { @apply border-primary/30 bg-primary/5; }
  .contaminant-row { @apply flex justify-between items-center py-2 border-b border-border; }
  .badge { @apply text-xs font-semibold px-3 py-1 rounded-full shrink-0 ml-4; }
  .badge-alert { @apply bg-destructive/10 text-destructive; }
  .badge-primary { @apply bg-primary/10 text-primary; }
  .related-link { @apply px-4 py-2 bg-background border border-border rounded-full text-sm text-primary font-medium hover:border-primary transition-colors; }
  .faq-item { @apply bg-card border border-border rounded-xl overflow-hidden; }
  .faq-question { @apply flex justify-between items-center p-6 cursor-pointer font-semibold text-foreground list-none select-none hover:bg-accent/50 transition-colors; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-icon { @apply text-2xl text-primary font-light leading-none shrink-0; }
  .faq-answer { @apply px-6 pb-6 text-muted-foreground leading-relaxed; }
</style>
