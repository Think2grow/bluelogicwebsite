---
import Layout from "../../layouts/Layout.astro";
import LeadForm from "../../components/LeadForm.astro";
import Reviews from "../../components/Reviews.astro";
import { getLocalBusinessSchema, getFAQSchema, getBreadcrumbSchema } from "../../utils/schema";

export const prerender = true;

const siteUrl = "https://www.bluelogicwater.com";

const faqs = [
  {
    question: "What contaminants are in Park City's water?",
    answer: "Park City and the Snyderville Basin are served by Mountain Regional Water. The EWG Tap Water Database flags 13 contaminants above EWG health guidelines, including arsenic at 315 times the guideline, disinfection byproducts (total trihalomethanes and haloacetic acids) at 48–54 times the guideline, and PFAS 'forever chemicals' such as perfluorohexane sulfonate (PFHxS). Radium and nitrate are also detected above EWG guidelines. All levels are within federal legal limits, but several far exceed EWG's stricter health-based thresholds.",
  },
  {
    question: "Is Park City water hard?",
    answer: "Yes — Park City's mountain groundwater is hard. At that level, scale accumulates on fixtures, inside water heaters, and in appliances, and homeowners often notice spotting and reduced soap performance. A free in-home water test gives you the exact hardness reading for your specific address.",
  },
  {
    question: "Why is arsenic so high in Park City's water?",
    answer: "EWG reports arsenic at 315 times its health guideline in the Mountain Regional Water system — a level driven by the region's geology. Arsenic has no taste, color, or odor, and standard water softeners and basic carbon filters do not remove it. A reverse osmosis membrane is the most effective residential method for reducing arsenic at the tap.",
  },
  {
    question: "Does Blue Logic serve Park City and the surrounding Summit County area?",
    answer: "Yes. Blue Logic serves Park City, the Snyderville Basin, Kimball Junction, and surrounding Summit County communities on the Mountain Regional Water system. Our whole-home filtration and reverse osmosis systems are well suited to the area's arsenic, disinfection byproduct, and PFAS concerns, and to the demands of primary homes, second homes, and short-term rentals.",
  },
];

const schemas = [
  getLocalBusinessSchema(siteUrl, "Park City"),
  getFAQSchema(faqs),
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Locations", url: "/locations/" },
    { name: "Park City", url: "/locations/park-city/" },
  ]),
];
---

<Layout
  title="Water Treatment Park City Utah | Blue Logic Water"
  description="Park City's water (Mountain Regional Water) shows arsenic at 315x the EWG guideline, plus disinfection byproducts and PFAS. Blue Logic serves Park City & Summit County. Free water test."
  schema={schemas}
>
  <section class="hero-gradient-dark py-20 md:py-28 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-widest text-white/70 mb-4">
        Summit County · Mountain Regional Water · Snyderville Basin · Kimball Junction
      </p>
      <h1 class="text-4xl md:text-5xl font-serif mb-6 text-white leading-tight">
        Water Treatment for Park City Homes
      </h1>
      <p class="text-lg md:text-xl text-white/90 max-w-3xl mx-auto mb-8 leading-relaxed">
        Park City and the Snyderville Basin are served by Mountain Regional Water, where EWG testing
        flags arsenic at 315 times its health guideline — along with elevated disinfection byproducts
        and PFAS. Blue Logic serves the area with systems built for exactly these contaminants.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/free-water-test/" class="inline-block bg-white text-primary font-semibold text-lg px-8 py-4 rounded-full shadow-lg hover:bg-white/90 transition-all">
          Schedule Free Water Test →
        </a>
        <a href="tel:+18019802583" class="inline-block border-2 border-white/50 text-white font-semibold text-lg px-8 py-4 rounded-full hover:bg-white/10 transition-all">
          Call (801) 980-2583
        </a>
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-4 text-foreground">Water Quality Profile</h2>
      <p class="text-center text-muted-foreground mb-8 max-w-2xl mx-auto text-sm">
        Based on EWG Tap Water Database testing for Mountain Regional Water Special Service District (2018–2023).
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
        <div class="stat-box stat-box-alert">
          <div class="text-4xl font-bold text-destructive mb-2">13</div>
          <div class="font-semibold text-foreground mb-1">Contaminants Above EWG Thresholds</div>
          <p class="text-xs text-muted-foreground">Out of 32 total detected. Federally compliant, but above EWG health guidelines.</p>
        </div>
        <div class="stat-box stat-box-alert">
          <div class="text-4xl font-bold text-destructive mb-2">315x</div>
          <div class="font-semibold text-foreground mb-1">Arsenic Above EWG Guideline</div>
          <p class="text-xs text-muted-foreground">No taste or odor. Softeners and basic filters don't remove it — RO does.</p>
        </div>
        <div class="stat-box stat-box-alert">
          <div class="text-4xl font-bold text-destructive mb-2">PFAS</div>
          <div class="font-semibold text-foreground mb-1">Detected Above Guideline</div>
          <p class="text-xs text-muted-foreground">PFHxS and related 'forever chemicals' flagged by EWG.</p>
        </div>
      </div>

      <div class="bg-card rounded-xl border border-border p-6">
        <h3 class="text-lg font-semibold mb-3 text-foreground">Key Concerns for Park City Homeowners</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-muted-foreground">
          <div><strong class="text-foreground">Arsenic (315x):</strong> Driven by regional geology and flagged far above the EWG health guideline. A reverse osmosis membrane is the most effective residential approach.</div>
          <div><strong class="text-foreground">Disinfection byproducts:</strong> Total trihalomethanes (54x) and haloacetic acids (48x) form when surface water is chlorinated. Catalytic carbon filtration addresses these.</div>
          <div><strong class="text-foreground">PFAS:</strong> Perfluorohexane sulfonate and related compounds were detected above EWG guidelines. RO is among the most effective residential barriers to PFAS.</div>
          <div><strong class="text-foreground">Hard water:</strong> Mountain groundwater drives scale on fixtures and inside hot water systems. Softening protects appliances and improves soap performance.</div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <Reviews compact={true} heading="What Utah Homeowners Say About Blue Logic" />
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-10 text-foreground">Common Questions</h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item group">
            <summary class="faq-question">
              {faq.question}
              <span class="faq-icon group-open:rotate-45 transition-transform">+</span>
            </summary>
            <div class="faq-answer">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-card py-10 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sm font-semibold text-foreground mb-4">Also serving nearby communities:</p>
      <div class="flex flex-wrap justify-center gap-3">
        {[{name:"Salt Lake City",slug:"salt-lake-city"},{name:"Midvale",slug:"midvale"},{name:"Cottonwood Heights",slug:"cottonwood-heights"},{name:"Sandy",slug:"sandy"}].map((c) => (
          <a href={`/locations/${c.slug}/`} class="related-link">{c.name}</a>
        ))}
        <a href="/locations/" class="related-link">All Locations →</a>
      </div>
    </div>
  </section>

  <section class="bg-primary/5 py-16 md:py-20 px-4">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-4 text-foreground">Free Water Test — Park City</h2>
      <p class="text-muted-foreground text-center mb-10">Blue Logic serves Park City and Summit County. No cost, no obligation.</p>
      <LeadForm />
    </div>
  </section>
</Layout>

<style>
  @reference "../../styles/global.css";
  .hero-gradient-dark { @apply bg-linear-to-br from-primary to-primary/70; }
  .stat-box { @apply bg-card p-6 rounded-xl border-2 border-border text-center; }
  .stat-box-alert { @apply border-destructive/30 bg-destructive/5; }
  .stat-box-primary { @apply border-primary/30 bg-primary/5; }
  .related-link { @apply px-4 py-2 bg-background border border-border rounded-full text-sm text-primary font-medium hover:border-primary transition-colors; }
  .faq-item { @apply bg-card border border-border rounded-xl overflow-hidden; }
  .faq-question { @apply flex justify-between items-center p-6 cursor-pointer font-semibold text-foreground list-none select-none hover:bg-accent/50 transition-colors; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-icon { @apply text-2xl text-primary font-light leading-none shrink-0; }
  .faq-answer { @apply px-6 pb-6 text-muted-foreground leading-relaxed; }
</style>
