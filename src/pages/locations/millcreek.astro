---
import Layout from "../../layouts/Layout.astro";
import LeadForm from "../../components/LeadForm.astro";
import Reviews from "../../components/Reviews.astro";
import { getLocalBusinessSchema, getFAQSchema, getBreadcrumbSchema } from "../../utils/schema";

export const prerender = true;

const siteUrl = "https://www.bluelogicwater.com";

const faqs = [
  {
    question: "What is in Millcreek's tap water?",
    answer: "Millcreek draws from the Salt Lake City Department of Public Utilities and JVWCD systems. The EWG Tap Water Database identifies 16 contaminants above EWG health guidelines in this supply, including arsenic (at 135x EWG guideline), PFAS (perfluorohexane sulfonate at 404x EWG guideline), and dichloroacetic acid. This is the same water profile as Salt Lake City and Cottonwood Heights, as Millcreek largely draws from the same source. All levels are within federal legal limits.",
  },
  {
    question: "Millcreek became a city in 2017. Did the water quality change?",
    answer: "No. Millcreek's incorporation as a city in 2017 was a governance change — the municipal water infrastructure and supply sources remained the same. Millcreek residents continue to receive water from the SLC Department of Public Utilities and JVWCD depending on their specific neighborhood. The water quality profile is unchanged from its pre-incorporation period.",
  },
  {
    question: "Is Millcreek water the same as Salt Lake City water?",
    answer: "Largely, yes. Many Millcreek neighborhoods receive water from the Salt Lake City Department of Public Utilities system, which gives them the same water quality profile as SLC — including the PFAS detection, arsenic at 135x the EWG guideline, and 16 contaminants above EWG thresholds. Some Millcreek areas may also receive JVWCD-blended water. Your free Blue Logic water test measures your specific tap.",
  },
  {
    question: "What system makes sense for a Millcreek home?",
    answer: "Given Millcreek's PFAS and arsenic profile (from the SLC water system), whole-home reverse osmosis is the most complete option for homeowners concerned about those specific contaminants. The RO membrane addresses PFAS and arsenic at the molecular level. The whole-home filtration system is the right choice for homeowners focused primarily on hardness, chlorine, and taste/odor improvement. Your free water test guides the recommendation.",
  },
  {
    question: "Does Blue Logic serve the Holladay and Millcreek area near the Wasatch foothills?",
    answer: "Yes. Blue Logic serves Millcreek including the Holladay-adjacent neighborhoods, East Millcreek, and the foothill communities between Millcreek and Salt Lake City. We serve all of Salt Lake County.",
  },
];

const schemas = [
  getLocalBusinessSchema(siteUrl, "Millcreek"),
  getFAQSchema(faqs),
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Locations", url: "/locations/" },
    { name: "Millcreek", url: "/locations/millcreek/" },
  ]),
];
---

<Layout
  title="Water Treatment Millcreek Utah | Blue Logic Water"
  description="Millcreek water has PFAS, arsenic at 135x EWG guideline, and 16 contaminants above thresholds — the same profile as Salt Lake City. Free in-home water test. Blue Logic."
  schema={schemas}
>
  <section class="hero-gradient-dark py-20 md:py-28 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-widest text-white/70 mb-4">
        Salt Lake County · SLC Water System · East Millcreek · Holladay Area
      </p>
      <h1 class="text-4xl md:text-5xl font-serif mb-6 text-white leading-tight">
        Water Treatment for Millcreek, Utah Homes
      </h1>
      <p class="text-lg md:text-xl text-white/90 max-w-3xl mx-auto mb-8 leading-relaxed">
        Millcreek draws from the Salt Lake City water system — sharing the same PFAS detection,
        arsenic at 135x EWG guideline, and 16 contaminants above EWG thresholds.
        Blue Logic installs whole-home filtration and RO systems for Millcreek homeowners.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/free-water-test/" class="inline-block bg-white text-primary font-semibold text-lg px-8 py-4 rounded-full shadow-lg hover:bg-white/90 transition-all">
          Schedule Free Water Test →
        </a>
        <a href="tel:+18019802583" class="inline-block border-2 border-white/50 text-white font-semibold text-lg px-8 py-4 rounded-full hover:bg-white/10 transition-all">
          Call (801) 980-2583
        </a>
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif text-center mb-4 text-foreground">
        Millcreek's Water Quality Profile
      </h2>
      <p class="text-xs text-muted-foreground text-center max-w-2xl mx-auto mb-10">
        Millcreek draws primarily from the SLC Department of Public Utilities water system.
        Data from the EWG Tap Water Database. All levels meet federal legal standards.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
        <div class="stat-box stat-box-alert">
          <div class="text-4xl font-bold text-destructive mb-2">16</div>
          <div class="font-semibold text-foreground mb-1">Contaminants Above EWG Thresholds</div>
          <p class="text-xs text-muted-foreground">Same profile as Salt Lake City — including PFAS, arsenic, and haloacetic acids.</p>
        </div>
        <div class="stat-box stat-box-alert">
          <div class="text-4xl font-bold text-destructive mb-2">PFAS</div>
          <div class="font-semibold text-foreground mb-1">Detected in Supply</div>
          <p class="text-xs text-muted-foreground">Perfluorohexane sulfonate at 404x EWG health guideline. From same SLC system.</p>
        </div>
        <div class="stat-box stat-box-alert">
          <div class="text-4xl font-bold text-destructive mb-2">135x</div>
          <div class="font-semibold text-foreground mb-1">Arsenic vs. EWG Guideline</div>
          <p class="text-xs text-muted-foreground">Naturally occurring; same level as Salt Lake City supply. Federally compliant.</p>
        </div>
      </div>

      <div class="bg-card rounded-2xl border border-border p-6 md:p-8">
        <h3 class="text-xl font-semibold mb-4 text-foreground">Key Water Quality Concerns</h3>
        <div class="space-y-3">
          <div class="contaminant-row">
            <span class="font-medium text-foreground">Perfluorohexane sulfonate (PFAS)</span>
            <span class="badge badge-alert">404x EWG health guideline</span>
          </div>
          <div class="contaminant-row">
            <span class="font-medium text-foreground">Arsenic</span>
            <span class="badge badge-alert">135x EWG health guideline</span>
          </div>
          <div class="contaminant-row">
            <span class="font-medium text-foreground">Dichloroacetic acid (HAA)</span>
            <span class="badge badge-alert">101x EWG health guideline</span>
          </div>
        </div>
        <div class="mt-5 pt-5 border-t border-border text-xs text-muted-foreground">
          EWG health guidelines are stricter than federal legal limits. All levels are federally compliant.
          Water quality may vary by neighborhood based on active source blending.
          <a href="https://www.ewg.org/tapwater/system.php?pws=UTAH18026" target="_blank" rel="noopener" class="text-primary underline ml-1">EWG Report for SLC Water System →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-card py-12 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-xl font-semibold mb-6 text-foreground">Millcreek Neighborhoods Served</h2>
      <div class="flex flex-wrap justify-center gap-3 mb-4">
        {["East Millcreek", "Millcreek Canyon area", "Holladay-adjacent", "3300 South corridor",
          "Van Winkle Expressway area", "Highland Drive corridor"].map((n) => (
          <span class="px-3 py-1.5 bg-background border border-border rounded-full text-sm text-muted-foreground">{n}</span>
        ))}
      </div>
      <p class="text-sm text-muted-foreground">
        Also serving Salt Lake City · Cottonwood Heights · Murray · Sandy and surrounding Salt Lake County communities.
      </p>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <Reviews compact={true} heading="What Utah Homeowners Say About Blue Logic" />
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-10 text-foreground">
        Millcreek Water Treatment — Common Questions
      </h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item group">
            <summary class="faq-question">
              {faq.question}
              <span class="faq-icon group-open:rotate-45 transition-transform">+</span>
            </summary>
            <div class="faq-answer">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-background py-10 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sm font-semibold text-foreground mb-4">Also serving nearby communities:</p>
      <div class="flex flex-wrap justify-center gap-3">
        {[{name:"Salt Lake City",slug:"salt-lake-city"},{name:"Murray",slug:"murray"},{name:"Sandy",slug:"sandy"},{name:"Cottonwood Heights",slug:"cottonwood-heights"}].map((c) => (
          <a href={`/locations/${c.slug}/`} class="related-link">{c.name}</a>
        ))}
        <a href="/locations/" class="related-link">All Locations →</a>
      </div>
    </div>
  </section>

  <section class="bg-primary/5 py-16 md:py-20 px-4">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-4 text-foreground">
        Schedule Your Free Millcreek Water Test
      </h2>
      <p class="text-muted-foreground text-center mb-10">
        Blue Logic serves Millcreek and all of Salt Lake County. Free in-home water test —
        no cost, no obligation.
      </p>
      <LeadForm />
    </div>
  </section>
</Layout>

<style>
  @reference "../../styles/global.css";
  .hero-gradient-dark { @apply bg-linear-to-br from-primary to-primary/70; }
  .stat-box { @apply bg-card p-6 rounded-xl border-2 border-border text-center; }
  .stat-box-alert { @apply border-destructive/30 bg-destructive/5; }
  .contaminant-row { @apply flex justify-between items-center py-2 border-b border-border; }
  .badge { @apply text-xs font-semibold px-3 py-1 rounded-full shrink-0 ml-4; }
  .badge-alert { @apply bg-destructive/10 text-destructive; }
  .related-link { @apply px-4 py-2 bg-background border border-border rounded-full text-sm text-primary font-medium hover:border-primary transition-colors; }
  .faq-item { @apply bg-card border border-border rounded-xl overflow-hidden; }
  .faq-question { @apply flex justify-between items-center p-6 cursor-pointer font-semibold text-foreground list-none select-none hover:bg-accent/50 transition-colors; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-icon { @apply text-2xl text-primary font-light leading-none shrink-0; }
  .faq-answer { @apply px-6 pb-6 text-muted-foreground leading-relaxed; }
</style>
