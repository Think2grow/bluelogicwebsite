---
import Layout from "../../layouts/Layout.astro";
import LeadForm from "../../components/LeadForm.astro";
import Reviews from "../../components/Reviews.astro";
import { getLocalBusinessSchema, getFAQSchema, getBreadcrumbSchema } from "../../utils/schema";

export const prerender = true;

const siteUrl = "https://www.bluelogicwater.com";

const faqs = [
  {
    question: "West Jordan is a large city — does the water quality vary by neighborhood?",
    answer: "West Jordan is served primarily by the Jordan Valley Water Conservancy District (JVWCD) with some areas blending in local well sources. The JVWCD supply is relatively consistent across the city, but proximity to local distribution infrastructure and the age of neighborhood pipes can affect what comes out of your specific tap. A free in-home water test gives you the actual reading for your address rather than a city-wide average.",
  },
  {
    question: "What is hexavalent chromium and why is it in West Jordan's water?",
    answer: "Hexavalent chromium (chromium-6) is a form of the element chromium associated with industrial and natural geological sources. West Jordan's chromium-6 at 93x the EWG health guideline is one of the highest readings in the Salt Lake Valley. It is primarily naturally occurring in Utah's source water geology. The EPA regulates total chromium but does not yet have a specific hexavalent chromium standard. EWG's research suggests the current federal total chromium limit is insufficient for the more toxic hexavalent form. Reverse osmosis is among the most effective residential technologies for chromium-6 reduction.",
  },
  {
    question: "How does West Jordan's water compare to neighboring South Jordan and Sandy?",
    answer: "All three cities receive primarily JVWCD-sourced water and face similar disinfection byproduct and hard water challenges. West Jordan is distinguished by its notably high chromium-6 levels (93x EWG guideline) and arsenic (275x EWG guideline). South Jordan has the highest HAA9 disinfection byproducts in the valley. Sandy has elevated HAA5 levels. All three are well above EWG thresholds for multiple contaminants while meeting federal legal standards.",
  },
  {
    question: "What Blue Logic system is recommended for West Jordan?",
    answer: "Given West Jordan's chromium-6, arsenic, and chloroform concerns alongside very hard water (~18 GPG), whole-home reverse osmosis provides the most complete coverage. The RO membrane addresses chromium-6, arsenic, and chloroform at the molecular level — contaminants that standard filtration and softening alone don't fully reach. The whole-home filtration system is also a meaningful upgrade, particularly for homeowners focused primarily on hardness, chlorine taste/odor, and HAA reduction.",
  },
  {
    question: "Does Blue Logic offer financing for West Jordan homeowners?",
    answer: "Yes. Blue Logic offers in-house financing with half down at installation and flexible repayment terms. No third-party lender or credit check required. Blue Logic also offers a written price-match guarantee — if you have a competing quote from any licensed water treatment company in the West Jordan area, we'll match or beat it.",
  },
];

const schemas = [
  getLocalBusinessSchema(siteUrl, "West Jordan"),
  getFAQSchema(faqs),
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Locations", url: "/locations/" },
    { name: "West Jordan", url: "/locations/west-jordan/" },
  ]),
];
---

<Layout
  title="Water Treatment West Jordan Utah | Blue Logic Water"
  description="West Jordan water has chromium-6 at 93x and arsenic at 275x the EWG health guideline. Blue Logic installs whole-home RO and filtration in West Jordan. Free water test."
  schema={schemas}
>
  <section class="hero-gradient-dark py-20 md:py-28 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-widest text-white/70 mb-4">
        Salt Lake County · JVWCD · Herriman Border · Daybreak Area
      </p>
      <h1 class="text-4xl md:text-5xl font-serif mb-6 text-white leading-tight">
        Water Treatment for West Jordan, Utah Homes
      </h1>
      <p class="text-lg md:text-xl text-white/90 max-w-3xl mx-auto mb-8 leading-relaxed">
        West Jordan's water supply contains chromium-6 at 93 times the EWG health guideline
        and arsenic at 275 times — among the highest combined contaminant levels in Salt Lake County.
        Blue Logic serves West Jordan with whole-home filtration and RO systems.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/free-water-test/" class="inline-block bg-white text-primary font-semibold text-lg px-8 py-4 rounded-full shadow-lg hover:bg-white/90 transition-all">
          Schedule Free Water Test →
        </a>
        <a href="tel:+18019802583" class="inline-block border-2 border-white/50 text-white font-semibold text-lg px-8 py-4 rounded-full hover:bg-white/10 transition-all">
          Call (801) 980-2583
        </a>
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif text-center mb-4 text-foreground">
        West Jordan's Water Quality Profile
      </h2>
      <p class="text-xs text-muted-foreground text-center max-w-2xl mx-auto mb-10">
        Data from the EWG Tap Water Database. All levels meet federal legal standards.
        EWG health guidelines reflect stricter, more recently researched thresholds.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
        <div class="stat-box stat-box-alert">
          <div class="text-5xl font-bold text-destructive mb-2">93x</div>
          <div class="font-semibold text-foreground mb-1">Chromium-6 vs. EWG Guideline</div>
          <p class="text-xs text-muted-foreground">One of the highest chromium-6 levels in Salt Lake County. Federally compliant; EWG guideline is far stricter.</p>
        </div>
        <div class="stat-box stat-box-alert">
          <div class="text-5xl font-bold text-destructive mb-2">275x</div>
          <div class="font-semibold text-foreground mb-1">Arsenic vs. EWG Guideline</div>
          <p class="text-xs text-muted-foreground">Naturally occurring; among the highest arsenic levels in Salt Lake County.</p>
        </div>
        <div class="stat-box stat-box-primary">
          <div class="text-4xl font-bold text-primary mb-2">~18 GPG</div>
          <div class="font-semibold text-foreground mb-1">Water Hardness</div>
          <p class="text-xs text-muted-foreground">Very hard — scale buildup on fixtures, appliances, and hot water systems.</p>
        </div>
      </div>

      <div class="bg-card rounded-2xl border border-border p-6 md:p-8">
        <h3 class="text-xl font-semibold mb-4 text-foreground">Top Contaminants Per EWG Data</h3>
        <div class="space-y-3">
          <div class="contaminant-row">
            <span class="font-medium text-foreground">Chromium (hexavalent / chromium-6)</span>
            <span class="badge badge-alert">93x EWG health guideline</span>
          </div>
          <div class="contaminant-row">
            <span class="font-medium text-foreground">Arsenic</span>
            <span class="badge badge-alert">275x EWG health guideline</span>
          </div>
          <div class="contaminant-row">
            <span class="font-medium text-foreground">Chloroform (disinfection byproduct)</span>
            <span class="badge badge-alert">51x EWG health guideline</span>
          </div>
          <div class="contaminant-row">
            <span class="font-medium text-foreground">Water hardness</span>
            <span class="badge badge-primary">~18 GPG — Very Hard</span>
          </div>
        </div>
        <div class="mt-5 pt-5 border-t border-border flex items-center justify-between flex-wrap gap-3">
          <p class="text-xs text-muted-foreground">15 total contaminants above EWG health guidelines. Source:</p>
          <a href="https://www.ewg.org/tapwater/system.php?pws=UTAH18020" target="_blank" rel="noopener" class="text-primary text-sm underline">
            Full EWG Report for West Jordan →
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-card py-12 md:py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-serif text-center mb-8 text-foreground">
        West Jordan's Large, Growing Community
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="scenario-card">
          <h3 class="font-semibold text-foreground mb-2">Established Neighborhoods — Decades of Scale</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            West Jordan's older neighborhoods have accumulated years of hard water mineral buildup
            in plumbing, water heaters, and appliances. Homes on untreated water for 10–20+ years
            often have measurably narrowed hot water pipes and significantly scaled water heaters
            operating at reduced efficiency. A whole-home system stops future accumulation and
            reduces the mineral load on aging infrastructure.
          </p>
        </div>
        <div class="scenario-card">
          <h3 class="font-semibold text-foreground mb-2">Newer Development Near Herriman Border</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            The southwestern edge of West Jordan bordering Herriman has seen significant new
            residential development. These newer homes receive the same JVWCD water supply —
            with the same chromium-6, arsenic, and hardness profile. Installing a whole-home
            system at move-in protects new fixtures and premium appliances from the start.
          </p>
        </div>
        <div class="scenario-card">
          <h3 class="font-semibold text-foreground mb-2">Families Concerned About Chromium-6</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            West Jordan's chromium-6 at 93x the EWG health guideline is a concern for many
            families with young children. The whole-home RO system addresses chromium-6 at the
            molecular level through the RO membrane — providing purified water at every tap,
            including bath and shower water.
          </p>
        </div>
        <div class="scenario-card">
          <h3 class="font-semibold text-foreground mb-2">Price Comparison</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            West Jordan has several water treatment dealers competing for business. Blue Logic's
            systems are competitively priced at $5,995–$19,999 with a written price-match guarantee on any competing quote.
            With a written price-match guarantee and in-house financing, Blue Logic is the right
            starting point for any West Jordan homeowner evaluating their options.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background py-10 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-xl font-semibold mb-6 text-foreground">West Jordan Areas Served</h2>
      <div class="flex flex-wrap justify-center gap-3 mb-4">
        {["Decker Lake", "Redwood Road corridor", "Mountain View Corridor", "Old Bingham Hwy",
          "South West Jordan", "West Jordan Hills", "Bordering Herriman"].map((area) => (
          <span class="px-3 py-1.5 bg-card border border-border rounded-full text-sm text-muted-foreground">{area}</span>
        ))}
      </div>
      <p class="text-sm text-muted-foreground">
        Also serving South Jordan · Sandy · Draper · Salt Lake City and all of Salt Lake County.
        <a href="/locations/" class="text-primary font-medium ml-1">View all service areas →</a>
      </p>
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <Reviews compact={true} heading="What Utah Homeowners Say About Blue Logic" />
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-10 text-foreground">
        West Jordan Water Treatment — Common Questions
      </h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item group">
            <summary class="faq-question">
              {faq.question}
              <span class="faq-icon group-open:rotate-45 transition-transform">+</span>
            </summary>
            <div class="faq-answer">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-card py-10 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sm font-semibold text-foreground mb-4">Also serving nearby communities:</p>
      <div class="flex flex-wrap justify-center gap-3">
        {[{name:"Herriman",slug:"herriman"},{name:"South Jordan",slug:"south-jordan"},{name:"Sandy",slug:"sandy"},{name:"Draper",slug:"draper"}].map((c) => (
          <a href={`/locations/${c.slug}/`} class="related-link">{c.name}</a>
        ))}
        <a href="/locations/" class="related-link">All Locations →</a>
      </div>
    </div>
  </section>

  <section class="bg-primary/5 py-16 md:py-20 px-4">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-4 text-foreground">
        Schedule Your Free West Jordan Water Test
      </h2>
      <p class="text-muted-foreground text-center mb-10">
        A Blue Logic specialist will come to your West Jordan home, test your water on-site,
        and recommend the right system. No cost, no obligation.
      </p>
      <LeadForm />
    </div>
  </section>
</Layout>

<style>
  @reference "../../styles/global.css";
  .hero-gradient-dark { @apply bg-linear-to-br from-primary to-primary/70; }
  .stat-box { @apply bg-card p-6 rounded-xl border-2 border-border text-center; }
  .stat-box-alert { @apply border-destructive/30 bg-destructive/5; }
  .stat-box-primary { @apply border-primary/30 bg-primary/5; }
  .contaminant-row { @apply flex justify-between items-center py-2 border-b border-border; }
  .badge { @apply text-xs font-semibold px-3 py-1 rounded-full shrink-0 ml-4; }
  .badge-alert { @apply bg-destructive/10 text-destructive; }
  .badge-primary { @apply bg-primary/10 text-primary; }
  .scenario-card { @apply bg-background p-6 rounded-xl border border-border border-l-4 border-l-primary; }
  .related-link { @apply px-4 py-2 bg-background border border-border rounded-full text-sm text-primary font-medium hover:border-primary transition-colors; }
  .faq-item { @apply bg-card border border-border rounded-xl overflow-hidden; }
  .faq-question { @apply flex justify-between items-center p-6 cursor-pointer font-semibold text-foreground list-none select-none hover:bg-accent/50 transition-colors; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-icon { @apply text-2xl text-primary font-light leading-none shrink-0; }
  .faq-answer { @apply px-6 pb-6 text-muted-foreground leading-relaxed; }
</style>
