---
import Layout from "../../layouts/Layout.astro";
import LeadForm from "../../components/LeadForm.astro";
import Reviews from "../../components/Reviews.astro";
import { getLocalBusinessSchema, getFAQSchema, getBreadcrumbSchema } from "../../utils/schema";

export const prerender = true;

const siteUrl = "https://www.bluelogicwater.com";

const faqs = [
  {
    question: "What is in Taylorsville's water?",
    answer: "Taylorsville receives water from the Jordan Valley Water Conservancy District — the same supply as neighboring Sandy and Murray. The water has very hard water at approximately 18 GPG and elevated haloacetic acid disinfection byproducts above EWG health guidelines (dichloroacetic acid at 104x EWG guideline, HAA5 at 306x). All levels are within federal legal limits.",
  },
  {
    question: "How hard is Taylorsville water?",
    answer: "Taylorsville water is very hard — approximately 18 GPG (grains per gallon). Scale accumulates rapidly on fixtures, showerheads, and inside hot water systems. At 18 GPG, water heater efficiency drops measurably within a few years of installation without softening.",
  },
  {
    question: "Does Blue Logic serve Taylorsville?",
    answer: "Yes. Blue Logic serves all of Taylorsville and surrounding mid-Salt Lake County communities. Most Taylorsville installations are completed in a single day.",
  },
  {
    question: "What Blue Logic system is recommended for Taylorsville?",
    answer: "Given Taylorsville's elevated HAA disinfection byproducts and 18 GPG hardness, the whole-home filtration system addresses both concerns — softening for scale, catalytic carbon for chlorine and HAA precursor reduction. For homeowners who also want to address arsenic, the whole-home RO upgrade provides the most complete coverage. Your free water test confirms which is right for your home.",
  },
];

const schemas = [
  getLocalBusinessSchema(siteUrl, "Taylorsville"),
  getFAQSchema(faqs),
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Locations", url: "/locations/" },
    { name: "Taylorsville", url: "/locations/taylorsville/" },
  ]),
];
---

<Layout
  title="Water Treatment Taylorsville Utah | Blue Logic Water"
  description="Taylorsville water has HAA disinfection byproducts at 306x EWG guideline and 18 GPG hardness. Blue Logic serves Taylorsville with whole-home filtration and RO. Free water test."
  schema={schemas}
>
  <section class="hero-gradient-dark py-20 md:py-28 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-widest text-white/70 mb-4">
        Salt Lake County · JVWCD · Near Sandy and Murray
      </p>
      <h1 class="text-4xl md:text-5xl font-serif mb-6 text-white leading-tight">
        Water Treatment for Taylorsville Homes
      </h1>
      <p class="text-lg md:text-xl text-white/90 max-w-3xl mx-auto mb-8 leading-relaxed">
        Taylorsville receives JVWCD surface water with haloacetic acid disinfection byproducts
        at 306x the EWG health guideline and very hard water at 18 GPG.
        Blue Logic installs whole-home filtration and RO systems throughout Taylorsville.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/free-water-test/" class="inline-block bg-white text-primary font-semibold text-lg px-8 py-4 rounded-full shadow-lg hover:bg-white/90 transition-all">Schedule Free Water Test →</a>
        <a href="tel:+18019802583" class="inline-block border-2 border-white/50 text-white font-semibold text-lg px-8 py-4 rounded-full hover:bg-white/10 transition-all">Call (801) 980-2583</a>
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-4 text-foreground">Water Quality Profile</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
        <div class="stat-box stat-box-alert">
          <div class="text-4xl font-bold text-destructive mb-2">306x</div>
          <div class="font-semibold text-foreground mb-1">HAA5 vs. EWG Guideline</div>
          <p class="text-xs text-muted-foreground">Same JVWCD supply as Sandy. Disinfection byproducts from mountain surface water chlorination.</p>
        </div>
        <div class="stat-box stat-box-alert">
          <div class="text-4xl font-bold text-destructive mb-2">104x</div>
          <div class="font-semibold text-foreground mb-1">Dichloroacetic Acid vs. EWG</div>
          <p class="text-xs text-muted-foreground">Haloacetic acid disinfection byproduct above EWG health guideline. Federally compliant.</p>
        </div>
        <div class="stat-box stat-box-primary">
          <div class="text-4xl font-bold text-primary mb-2">~18 GPG</div>
          <div class="font-semibold text-foreground mb-1">Water Hardness</div>
          <p class="text-xs text-muted-foreground">Very hard — rapid scale on fixtures, appliances, and plumbing.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <Reviews compact={true} heading="What Utah Homeowners Say About Blue Logic" />
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-10 text-foreground">Common Questions</h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item group">
            <summary class="faq-question">{faq.question}<span class="faq-icon group-open:rotate-45 transition-transform">+</span></summary>
            <div class="faq-answer">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-card py-10 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sm font-semibold text-foreground mb-4">Also serving nearby:</p>
      <div class="flex flex-wrap justify-center gap-3">
        {[{name:"Sandy",slug:"sandy"},{name:"Murray",slug:"murray"},{name:"Midvale",slug:"midvale"},{name:"Salt Lake City",slug:"salt-lake-city"}].map((c) => (
          <a href={`/locations/${c.slug}/`} class="related-link">{c.name}</a>
        ))}
        <a href="/locations/" class="related-link">All Locations →</a>
      </div>
    </div>
  </section>

  <section class="bg-primary/5 py-16 md:py-20 px-4">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-4 text-foreground">Free Water Test — Taylorsville</h2>
      <p class="text-muted-foreground text-center mb-10">Blue Logic serves Taylorsville and all of Salt Lake County. No cost, no obligation.</p>
      <LeadForm />
    </div>
  </section>
</Layout>

<style>
  @reference "../../styles/global.css";
  .hero-gradient-dark { @apply bg-linear-to-br from-primary to-primary/70; }
  .stat-box { @apply bg-card p-6 rounded-xl border-2 border-border text-center; }
  .stat-box-alert { @apply border-destructive/30 bg-destructive/5; }
  .stat-box-primary { @apply border-primary/30 bg-primary/5; }
  .related-link { @apply px-4 py-2 bg-background border border-border rounded-full text-sm text-primary font-medium hover:border-primary transition-colors; }
  .faq-item { @apply bg-card border border-border rounded-xl overflow-hidden; }
  .faq-question { @apply flex justify-between items-center p-6 cursor-pointer font-semibold text-foreground list-none select-none hover:bg-accent/50 transition-colors; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-icon { @apply text-2xl text-primary font-light leading-none shrink-0; }
  .faq-answer { @apply px-6 pb-6 text-muted-foreground leading-relaxed; }
</style>
