---
import Layout from "../../layouts/Layout.astro";
import LeadForm from "../../components/LeadForm.astro";
import Reviews from "../../components/Reviews.astro";
import { getLocalBusinessSchema, getFAQSchema, getBreadcrumbSchema } from "../../utils/schema";

export const prerender = true;

const siteUrl = "https://www.bluelogicwater.com";

const faqs = [
  {
    question: "What is in Murray's tap water?",
    answer: "Murray receives water from the Jordan Valley Water Conservancy District (JVWCD), which sources primarily from Wasatch mountain surface water. Murray's water is very hard — typically 15–18 grains per gallon — and the chlorination of organic-rich surface water produces disinfection byproducts including haloacetic acids and chloroform above EWG health guidelines. Arsenic has also been flagged above EWG thresholds. All levels are within federal legal limits.",
  },
  {
    question: "Is Murray City part of Salt Lake City's water system?",
    answer: "Murray City operates its own water utility (Murray City Water) that purchases treated water from JVWCD rather than drawing directly from the Salt Lake City Department of Public Utilities system. The water quality profile is similar to other JVWCD-served Salt Lake County communities — hard, chlorinated surface water with disinfection byproduct and arsenic concerns.",
  },
  {
    question: "What Blue Logic system is right for a Murray home?",
    answer: "Murray's primary water concerns are hard water scale, chlorine taste/odor from disinfection, and elevated disinfection byproducts. The whole-home filtration system addresses all of these — softening, carbon filtration for chlorine/HAA reduction, and iron/manganese stages. For Murray homeowners also concerned about arsenic, the whole-home RO upgrade provides the most complete coverage. Your free water test confirms which is the right fit.",
  },
  {
    question: "Does Blue Logic serve Murray's industrial and mixed-use areas?",
    answer: "Blue Logic installs residential whole-home water treatment systems for homeowners. Murray's mix of residential neighborhoods — from older established areas near State Street to newer developments off Vine Street — all receive the same municipal water supply and qualify for Blue Logic's service. We don't serve commercial or industrial properties.",
  },
];

const schemas = [
  getLocalBusinessSchema(siteUrl, "Murray"),
  getFAQSchema(faqs),
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Locations", url: "/locations/" },
    { name: "Murray", url: "/locations/murray/" },
  ]),
];
---

<Layout
  title="Water Treatment Murray Utah | Blue Logic Water"
  description="Murray water is very hard with disinfection byproduct and arsenic concerns from JVWCD supply. Blue Logic serves Murray with whole-home filtration and RO. Free water test."
  schema={schemas}
>
  <section class="hero-gradient-dark py-20 md:py-28 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-widest text-white/70 mb-4">
        Salt Lake County · Murray City Water · JVWCD Supply
      </p>
      <h1 class="text-4xl md:text-5xl font-serif mb-6 text-white leading-tight">
        Water Treatment for Murray, Utah Homes
      </h1>
      <p class="text-lg md:text-xl text-white/90 max-w-3xl mx-auto mb-8 leading-relaxed">
        Murray receives hard JVWCD surface water with disinfection byproduct and arsenic
        concerns above EWG health guidelines. Blue Logic installs whole-home filtration
        and RO systems for Murray homeowners.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/free-water-test/" class="inline-block bg-white text-primary font-semibold text-lg px-8 py-4 rounded-full shadow-lg hover:bg-white/90 transition-all">
          Schedule Free Water Test →
        </a>
        <a href="tel:+18019802583" class="inline-block border-2 border-white/50 text-white font-semibold text-lg px-8 py-4 rounded-full hover:bg-white/10 transition-all">
          Call (801) 980-2583
        </a>
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif text-center mb-4 text-foreground">
        Murray's Water Quality Profile
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
        <div class="stat-box stat-box-alert">
          <div class="text-4xl font-bold text-destructive mb-2">14</div>
          <div class="font-semibold text-foreground mb-1">Contaminants Above EWG Thresholds</div>
          <p class="text-xs text-muted-foreground">Including arsenic, HAA, and chloroform. Federally compliant.</p>
        </div>
        <div class="stat-box stat-box-primary">
          <div class="text-4xl font-bold text-primary mb-2">~15–18 GPG</div>
          <div class="font-semibold text-foreground mb-1">Water Hardness</div>
          <p class="text-xs text-muted-foreground">Very hard — rapid scale on fixtures and in appliances.</p>
        </div>
        <div class="stat-box">
          <div class="text-3xl font-bold text-foreground mb-2">JVWCD</div>
          <div class="font-semibold text-foreground mb-1">Water Source</div>
          <p class="text-xs text-muted-foreground">Purchased treated surface water — same system as Sandy, West Jordan, and South Jordan.</p>
        </div>
      </div>

      <div class="bg-card rounded-2xl border border-border p-6 md:p-8">
        <h3 class="text-xl font-semibold mb-4 text-foreground">Key Water Quality Concerns</h3>
        <div class="space-y-3">
          <div class="contaminant-row">
            <span class="font-medium text-foreground">Arsenic</span>
            <span class="badge badge-alert">Above EWG health guideline</span>
          </div>
          <div class="contaminant-row">
            <span class="font-medium text-foreground">Haloacetic acids (HAA)</span>
            <span class="badge badge-alert">Above EWG health guideline</span>
          </div>
          <div class="contaminant-row">
            <span class="font-medium text-foreground">Chloroform</span>
            <span class="badge badge-alert">Above EWG health guideline</span>
          </div>
          <div class="contaminant-row">
            <span class="font-medium text-foreground">Water hardness</span>
            <span class="badge badge-primary">~15–18 GPG — Very Hard</span>
          </div>
        </div>
        <p class="text-xs text-muted-foreground mt-5 pt-5 border-t border-border">
          EWG health guidelines are stricter than federal legal limits. Murray's water is federally compliant.
          <a href="https://www.ewg.org/tapwater/state.php?stab=UT" target="_blank" rel="noopener" class="text-primary underline ml-1">EWG Utah database →</a>
        </p>
      </div>
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <Reviews compact={true} heading="What Utah Homeowners Say About Blue Logic" />
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-10 text-foreground">
        Murray Water Treatment — Common Questions
      </h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item group">
            <summary class="faq-question">
              {faq.question}
              <span class="faq-icon group-open:rotate-45 transition-transform">+</span>
            </summary>
            <div class="faq-answer">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-card py-10 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sm font-semibold text-foreground mb-4">Also serving nearby communities:</p>
      <div class="flex flex-wrap justify-center gap-3">
        {[{name:"Salt Lake City",slug:"salt-lake-city"},{name:"Millcreek",slug:"millcreek"},{name:"Sandy",slug:"sandy"},{name:"Draper",slug:"draper"}].map((c) => (
          <a href={`/locations/${c.slug}/`} class="related-link">{c.name}</a>
        ))}
        <a href="/locations/" class="related-link">All Locations →</a>
      </div>
    </div>
  </section>

  <section class="bg-primary/5 py-16 md:py-20 px-4">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-4 text-foreground">
        Schedule Your Free Murray Water Test
      </h2>
      <p class="text-muted-foreground text-center mb-10">
        Blue Logic serves Murray and all of Salt Lake County. A specialist tests your water
        on-site — no cost, no obligation.
      </p>
      <LeadForm />
    </div>
  </section>
</Layout>

<style>
  @reference "../../styles/global.css";
  .hero-gradient-dark { @apply bg-linear-to-br from-primary to-primary/70; }
  .stat-box { @apply bg-card p-6 rounded-xl border-2 border-border text-center; }
  .stat-box-alert { @apply border-destructive/30 bg-destructive/5; }
  .stat-box-primary { @apply border-primary/30 bg-primary/5; }
  .contaminant-row { @apply flex justify-between items-center py-2 border-b border-border; }
  .badge { @apply text-xs font-semibold px-3 py-1 rounded-full shrink-0 ml-4; }
  .badge-alert { @apply bg-destructive/10 text-destructive; }
  .badge-primary { @apply bg-primary/10 text-primary; }
  .related-link { @apply px-4 py-2 bg-background border border-border rounded-full text-sm text-primary font-medium hover:border-primary transition-colors; }
  .faq-item { @apply bg-card border border-border rounded-xl overflow-hidden; }
  .faq-question { @apply flex justify-between items-center p-6 cursor-pointer font-semibold text-foreground list-none select-none hover:bg-accent/50 transition-colors; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-icon { @apply text-2xl text-primary font-light leading-none shrink-0; }
  .faq-answer { @apply px-6 pb-6 text-muted-foreground leading-relaxed; }
</style>
