---
import Layout from "../../layouts/Layout.astro";
import LeadForm from "../../components/LeadForm.astro";
import Reviews from "../../components/Reviews.astro";
import { getLocalBusinessSchema, getFAQSchema, getBreadcrumbSchema } from "../../utils/schema";

export const prerender = true;

const siteUrl = "https://www.bluelogicwater.com";

const faqs = [
  {
    question: "What is hexavalent chromium and why is it in Orem's water?",
    answer: "Hexavalent chromium (chromium-6) is a form of the element chromium that is a known carcinogen at high exposures. It occurs both naturally in geology and as a result of industrial activity. In Orem's case, it is primarily naturally occurring — present in the source water at levels that exceed EWG's health guideline (36x). The EPA regulates total chromium but does not yet have a specific standard for the hexavalent form. EWG's guideline for chromium-6 specifically is far stricter than the federal total chromium limit. Reverse osmosis is effective at reducing chromium-6.",
  },
  {
    question: "How hard is Orem's water?",
    answer: "Orem water is very hard — typically around 18 grains per gallon (approximately 301 mg/L). This places it in the 'very hard' category per WQA standards. At 18 GPG, scale builds up rapidly on showerheads, faucet aerators, and inside appliances. Water heater efficiency is meaningfully reduced. Orem homeowners on untreated water often notice white mineral deposits within weeks of moving in.",
  },
  {
    question: "Is Orem's water the same as Provo's?",
    answer: "Orem and Provo are adjacent cities but draw water from partially different sources through the Central Utah Water Conservancy District and JVWCD systems. Orem's water has distinct contaminant levels from Provo's — notably, Orem has higher hexavalent chromium and higher HAA9 levels per EWG data. Your specific water profile depends on your neighborhood and utility blend. A free in-home water test gives you the actual picture for your home.",
  },
  {
    question: "Which Blue Logic system is recommended for Orem?",
    answer: "Given Orem's combination of chromium-6, arsenic, high HAA9 disinfection byproducts, and very hard water (18 GPG), whole-home reverse osmosis is the most comprehensive solution. The RO membrane addresses chromium-6, arsenic, and HAA compounds at the molecular level — contaminants that standard filtration and softening alone don't fully reach. The recommendation is always confirmed by your free in-home water test results.",
  },
  {
    question: "Does Blue Logic serve all of Orem, including Sharon area and Vineyard?",
    answer: "Yes. Blue Logic serves all of Orem including the Sharon area, Vineyard, and the newer developments along the Vineyard/Lindon corridor. We also serve American Fork, Pleasant Grove, and all surrounding Utah County communities from the same service area.",
  },
];

const schemas = [
  getLocalBusinessSchema(siteUrl, "Orem"),
  getFAQSchema(faqs),
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Locations", url: "/locations/" },
    { name: "Orem", url: "/locations/orem/" },
  ]),
];
---

<Layout
  title="Water Treatment Orem Utah | Blue Logic Water"
  description="Orem water has chromium-6 at 36x, arsenic at 131x, and HAA9 at 272x the EWG health guideline. Blue Logic installs whole-home RO and filtration in Orem. Free water test."
  schema={schemas}
>
  <section class="hero-gradient-dark py-20 md:py-28 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-widest text-white/70 mb-4">
        Utah County · Central Utah Water · JVWCD · Vineyard · Sharon
      </p>
      <h1 class="text-4xl md:text-5xl font-serif mb-6 text-white leading-tight">
        Water Treatment for Orem, Utah Homes
      </h1>
      <p class="text-lg md:text-xl text-white/90 max-w-3xl mx-auto mb-8 leading-relaxed">
        Orem's water supply contains hexavalent chromium (chromium-6) at 36 times the EWG health
        guideline, arsenic at 131 times, and haloacetic acid disinfection byproducts at 272 times —
        all while remaining federally compliant. Blue Logic addresses all three.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/free-water-test/" class="inline-block bg-white text-primary font-semibold text-lg px-8 py-4 rounded-full shadow-lg hover:bg-white/90 transition-all">
          Schedule Free Water Test →
        </a>
        <a href="tel:+18019802583" class="inline-block border-2 border-white/50 text-white font-semibold text-lg px-8 py-4 rounded-full hover:bg-white/10 transition-all">
          Call (801) 980-2583
        </a>
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif text-center mb-4 text-foreground">
        Orem's Water Quality Profile
      </h2>
      <p class="text-xs text-muted-foreground text-center max-w-2xl mx-auto mb-10">
        Data from the EWG Tap Water Database for the Orem City water system. All levels are within federal legal limits.
        EWG health guidelines reflect stricter, more recently researched thresholds.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
        <div class="stat-box stat-box-alert">
          <div class="text-5xl font-bold text-destructive mb-2">36x</div>
          <div class="font-semibold text-foreground mb-1">Chromium-6 vs. EWG Guideline</div>
          <p class="text-xs text-muted-foreground">Hexavalent chromium — naturally occurring. Not currently regulated separately by EPA.</p>
        </div>
        <div class="stat-box stat-box-alert">
          <div class="text-5xl font-bold text-destructive mb-2">272x</div>
          <div class="font-semibold text-foreground mb-1">HAA9 vs. EWG Guideline</div>
          <p class="text-xs text-muted-foreground">Haloacetic acid disinfection byproducts from chlorination of organic-rich surface water.</p>
        </div>
        <div class="stat-box stat-box-primary">
          <div class="text-4xl font-bold text-primary mb-2">~18 GPG</div>
          <div class="font-semibold text-foreground mb-1">Water Hardness</div>
          <p class="text-xs text-muted-foreground">Very hard — causes rapid scale, appliance damage, and dry skin from bathing.</p>
        </div>
      </div>

      <div class="bg-card rounded-2xl border border-border p-6 md:p-8 mb-6">
        <h3 class="text-xl font-semibold mb-4 text-foreground">Top Contaminants Per EWG Data</h3>
        <div class="space-y-3">
          <div class="contaminant-row">
            <span class="font-medium text-foreground">Chromium (hexavalent / chromium-6)</span>
            <span class="badge badge-alert">36x EWG health guideline</span>
          </div>
          <div class="contaminant-row">
            <span class="font-medium text-foreground">Arsenic</span>
            <span class="badge badge-alert">131x EWG health guideline</span>
          </div>
          <div class="contaminant-row">
            <span class="font-medium text-foreground">Haloacetic acids (HAA9)</span>
            <span class="badge badge-alert">272x EWG health guideline</span>
          </div>
          <div class="contaminant-row">
            <span class="font-medium text-foreground">Water hardness</span>
            <span class="badge badge-primary">~18 GPG — Very Hard</span>
          </div>
        </div>
        <div class="mt-5 pt-5 border-t border-border flex items-center justify-between flex-wrap gap-3">
          <p class="text-xs text-muted-foreground">13 total contaminants above EWG health guidelines. Source:</p>
          <a href="https://www.ewg.org/tapwater/system.php?pws=UTAH25020" target="_blank" rel="noopener" class="text-primary text-sm underline">
            Full EWG Report for Orem →
          </a>
        </div>
      </div>

      <div class="bg-card rounded-xl border border-border p-6">
        <h3 class="text-lg font-semibold mb-3 text-foreground">Orem's Water Source</h3>
        <p class="text-sm text-muted-foreground leading-relaxed mb-3">
          Orem receives treated water purchased from the Jordan Valley Water Conservancy District (JVWCD)
          system, primarily from mountain surface water sources processed through the regional treatment
          infrastructure. Orem is served by the same broader JVWCD supply chain as many Salt Lake County
          communities, but its specific blend, local storage, and distribution infrastructure produce a
          distinct contaminant profile — particularly the elevated chromium-6 and arsenic levels that
          differentiate Orem from its neighbors.
        </p>
        <p class="text-sm text-muted-foreground leading-relaxed">
          The haloacetic acid levels reflect the chlorination of surface water with naturally high
          organic content — a characteristic of Utah mountain watershed water that produces disinfection
          byproducts during treatment.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-card py-12 md:py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-serif text-center mb-8 text-foreground">
        What Orem Homeowners Should Know
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="scenario-card">
          <h3 class="font-semibold text-foreground mb-2">The Chromium-6 Concern</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Hexavalent chromium became widely known through the Erin Brockovich case and subsequent
            research linking long-term exposure to adverse health outcomes. The EPA regulates total
            chromium but does not yet have a specific limit for the hexavalent form. EWG's research
            suggests the current federal limit is insufficient for the hexavalent form specifically.
            Reverse osmosis is one of the most effective residential technologies for chromium-6 reduction.
          </p>
        </div>
        <div class="scenario-card">
          <h3 class="font-semibold text-foreground mb-2">Families with Young Children</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Orem is a family-oriented community with a high proportion of households with children.
            For families concerned about chromium-6, arsenic, and HAA compounds in water used for
            drinking, cooking, and bathing, whole-home reverse osmosis provides coverage at every
            tap — not just at the kitchen sink.
          </p>
        </div>
        <div class="scenario-card">
          <h3 class="font-semibold text-foreground mb-2">Hard Water on Modern Fixtures</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            At 18 GPG, Orem's water is in the very hard category. Fixtures, showerheads, and
            glass shower doors in untreated Orem homes show visible calcium deposits within weeks
            of installation. Tankless water heaters — increasingly common in Orem new builds —
            are especially vulnerable to scale damage at these hardness levels.
          </p>
        </div>
        <div class="scenario-card">
          <h3 class="font-semibold text-foreground mb-2">Vineyard and New Construction</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            The Vineyard area on the west side of Orem near Utah Lake is one of the fastest-growing
            communities in Utah County. New construction here receives the same regional water supply
            as established Orem neighborhoods. New homeowners in Vineyard face the same water quality
            profile as long-time Orem residents.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background py-10 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-xl font-semibold mb-6 text-foreground">Orem Areas Served</h2>
      <div class="flex flex-wrap justify-center gap-3 mb-4">
        {["East Orem", "West Orem", "Vineyard", "Sharon", "North Orem", "Orem Hills",
          "Geneva Road corridor", "University Parkway area"].map((area) => (
          <span class="px-3 py-1.5 bg-card border border-border rounded-full text-sm text-muted-foreground">{area}</span>
        ))}
      </div>
      <p class="text-sm text-muted-foreground">
        Also serving Provo · American Fork · Lindon · Pleasant Grove and surrounding Utah County communities.
        <a href="/locations/" class="text-primary font-medium ml-1">View all service areas →</a>
      </p>
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <Reviews compact={true} heading="What Utah Homeowners Say About Blue Logic" />
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-10 text-foreground">
        Orem Water Treatment — Common Questions
      </h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item group">
            <summary class="faq-question">
              {faq.question}
              <span class="faq-icon group-open:rotate-45 transition-transform">+</span>
            </summary>
            <div class="faq-answer">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-card py-10 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sm font-semibold text-foreground mb-4">Also serving nearby communities:</p>
      <div class="flex flex-wrap justify-center gap-3">
        {[{name:"Provo",slug:"provo"},{name:"Lehi",slug:"lehi"},{name:"American Fork",slug:"american-fork"}].map((c) => (
          <a href={`/locations/${c.slug}/`} class="related-link">{c.name}</a>
        ))}
        <a href="/locations/" class="related-link">All Locations →</a>
      </div>
    </div>
  </section>

  <section class="bg-primary/5 py-16 md:py-20 px-4">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-4 text-foreground">
        Schedule Your Free Orem Water Test
      </h2>
      <p class="text-muted-foreground text-center mb-10">
        Blue Logic serves all of Orem and Utah County. A specialist will test your water
        on-site and recommend the right system. No cost, no obligation.
      </p>
      <LeadForm />
    </div>
  </section>
</Layout>

<style>
  @reference "../../styles/global.css";
  .hero-gradient-dark { @apply bg-linear-to-br from-primary to-primary/70; }
  .stat-box { @apply bg-card p-6 rounded-xl border-2 border-border text-center; }
  .stat-box-alert { @apply border-destructive/30 bg-destructive/5; }
  .stat-box-primary { @apply border-primary/30 bg-primary/5; }
  .contaminant-row { @apply flex justify-between items-center py-2 border-b border-border; }
  .badge { @apply text-xs font-semibold px-3 py-1 rounded-full shrink-0 ml-4; }
  .badge-alert { @apply bg-destructive/10 text-destructive; }
  .badge-primary { @apply bg-primary/10 text-primary; }
  .scenario-card { @apply bg-background p-6 rounded-xl border border-border border-l-4 border-l-primary; }
  .related-link { @apply px-4 py-2 bg-background border border-border rounded-full text-sm text-primary font-medium hover:border-primary transition-colors; }
  .faq-item { @apply bg-card border border-border rounded-xl overflow-hidden; }
  .faq-question { @apply flex justify-between items-center p-6 cursor-pointer font-semibold text-foreground list-none select-none hover:bg-accent/50 transition-colors; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-icon { @apply text-2xl text-primary font-light leading-none shrink-0; }
  .faq-answer { @apply px-6 pb-6 text-muted-foreground leading-relaxed; }
</style>
