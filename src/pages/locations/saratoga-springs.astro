---
import Layout from "../../layouts/Layout.astro";
import LeadForm from "../../components/LeadForm.astro";
import Reviews from "../../components/Reviews.astro";
import { getLocalBusinessSchema, getFAQSchema, getBreadcrumbSchema } from "../../utils/schema";

export const prerender = true;

const siteUrl = "https://www.bluelogicwater.com";

const faqs = [
  {
    question: "What's in Saratoga Springs' tap water?",
    answer: "Saratoga Springs receives treated water from the Jordan Valley Water Conservancy District (JVWCD) — the same supply system as Lehi, American Fork, and much of Utah County. The water profile includes arsenic above EWG health guidelines, hexavalent chromium, and haloacetic acid disinfection byproducts — the same contaminant concerns as neighboring Lehi, which has the highest arsenic levels on the Wasatch Front. Water is very hard at approximately 14–18 GPG. All levels are within federal legal limits.",
  },
  {
    question: "Is Saratoga Springs water the same as Lehi's?",
    answer: "Very similar. Both cities draw from the JVWCD system with the same mountain surface water sourcing. Saratoga Springs' contaminant profile closely mirrors Lehi's — including arsenic well above EWG health guidelines and chromium-6 concerns. Your specific address may draw from slightly different blends depending on local infrastructure, which is why a free in-home water test that measures your actual tap is the most accurate starting point.",
  },
  {
    question: "I just bought a new home in Saratoga Springs. Is the water fine?",
    answer: "New construction doesn't change the source water. Saratoga Springs is one of Utah's fastest-growing cities precisely because of its new housing stock — but every home, new or old, connects to the same JVWCD municipal supply. New plumbing is an advantage (no legacy scale buildup), but the arsenic and hardness profile is the same as an older home on the same system. Installing a water system at move-in protects your new appliances and fixtures from day one.",
  },
  {
    question: "What system does Blue Logic recommend for Saratoga Springs?",
    answer: "Given the arsenic and chromium-6 profile shared with Lehi and the very hard water, whole-home reverse osmosis is the most complete option — the RO membrane addresses arsenic and chromium-6 at the molecular level, which filtration alone does not reach. The whole-home filtration system is also a meaningful upgrade for homeowners focused on hardness, chlorine, and taste. Your free water test confirms which configuration is right.",
  },
];

const schemas = [
  getLocalBusinessSchema(siteUrl, "Saratoga Springs"),
  getFAQSchema(faqs),
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Locations", url: "/locations/" },
    { name: "Saratoga Springs", url: "/locations/saratoga-springs/" },
  ]),
];
---

<Layout
  title="Water Treatment Saratoga Springs Utah | Blue Logic Water"
  description="Saratoga Springs water shares Lehi's arsenic and chromium-6 concerns from JVWCD supply. Blue Logic installs whole-home RO and filtration. Free in-home water test."
  schema={schemas}
>
  <section class="hero-gradient-dark py-20 md:py-28 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-widest text-white/70 mb-4">
        Utah County · JVWCD · Fast-Growing · New Construction
      </p>
      <h1 class="text-4xl md:text-5xl font-serif mb-6 text-white leading-tight">
        Water Treatment for Saratoga Springs Homes
      </h1>
      <p class="text-lg md:text-xl text-white/90 max-w-3xl mx-auto mb-8 leading-relaxed">
        Saratoga Springs receives JVWCD water with the same arsenic, chromium-6, and hard water
        profile as neighboring Lehi — one of the highest contaminant levels on the Wasatch Front.
        Blue Logic serves Saratoga Springs with compact, quiet whole-home systems.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/free-water-test/" class="inline-block bg-white text-primary font-semibold text-lg px-8 py-4 rounded-full shadow-lg hover:bg-white/90 transition-all">
          Schedule Free Water Test →
        </a>
        <a href="tel:+18019802583" class="inline-block border-2 border-white/50 text-white font-semibold text-lg px-8 py-4 rounded-full hover:bg-white/10 transition-all">
          Call (801) 980-2583
        </a>
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-4 text-foreground">Water Quality Profile</h2>
      <p class="text-xs text-muted-foreground text-center max-w-2xl mx-auto mb-10">
        Saratoga Springs draws from JVWCD — same supply as Lehi. EWG data below. All levels federally compliant.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
        <div class="stat-box stat-box-alert">
          <div class="text-4xl font-bold text-destructive mb-2">Arsenic</div>
          <div class="font-semibold text-foreground mb-1">Above EWG Guideline</div>
          <p class="text-xs text-muted-foreground">Same JVWCD Utah County source as Lehi (484x EWG). Naturally occurring.</p>
        </div>
        <div class="stat-box stat-box-alert">
          <div class="text-4xl font-bold text-destructive mb-2">Chromium-6</div>
          <div class="font-semibold text-foreground mb-1">Above EWG Guideline</div>
          <p class="text-xs text-muted-foreground">Hexavalent chromium detected. Same concern as Orem and West Jordan.</p>
        </div>
        <div class="stat-box stat-box-primary">
          <div class="text-4xl font-bold text-primary mb-2">14–18 GPG</div>
          <div class="font-semibold text-foreground mb-1">Water Hardness</div>
          <p class="text-xs text-muted-foreground">Very hard. Rapid scale on new construction fixtures and appliances.</p>
        </div>
      </div>

      <div class="bg-card rounded-xl border border-border p-6">
        <h3 class="text-lg font-semibold mb-3 text-foreground">Why New Construction Here Needs Water Treatment</h3>
        <p class="text-sm text-muted-foreground leading-relaxed">
          Saratoga Springs has exploded with new residential development — beautiful homes with premium finishes
          connecting directly to JVWCD municipal water with the same contaminant profile as every other home on
          the system. New plumbing is the one advantage: no legacy scale accumulation. Installing a Blue Logic
          system at move-in preserves that advantage permanently — protecting new fixtures, new appliances, and
          your family's water quality from the first day you turn on the tap.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <Reviews compact={true} heading="What Utah Homeowners Say About Blue Logic" />
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-10 text-foreground">Common Questions</h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item group">
            <summary class="faq-question">
              {faq.question}
              <span class="faq-icon group-open:rotate-45 transition-transform">+</span>
            </summary>
            <div class="faq-answer">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-card py-10 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sm font-semibold text-foreground mb-4">Also serving nearby communities:</p>
      <div class="flex flex-wrap justify-center gap-3">
        {[{name:"Lehi",slug:"lehi"},{name:"Eagle Mountain",slug:"eagle-mountain"},{name:"American Fork",slug:"american-fork"},{name:"Orem",slug:"orem"}].map((c) => (
          <a href={`/locations/${c.slug}/`} class="related-link">{c.name}</a>
        ))}
        <a href="/locations/" class="related-link">All Locations →</a>
      </div>
    </div>
  </section>

  <section class="bg-primary/5 py-16 md:py-20 px-4">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-4 text-foreground">
        Free Water Test — Saratoga Springs
      </h2>
      <p class="text-muted-foreground text-center mb-10">
        Blue Logic serves Saratoga Springs and all of Utah County. No cost, no obligation.
      </p>
      <LeadForm />
    </div>
  </section>
</Layout>

<style>
  @reference "../../styles/global.css";
  .hero-gradient-dark { @apply bg-linear-to-br from-primary to-primary/70; }
  .stat-box { @apply bg-card p-6 rounded-xl border-2 border-border text-center; }
  .stat-box-alert { @apply border-destructive/30 bg-destructive/5; }
  .stat-box-primary { @apply border-primary/30 bg-primary/5; }
  .related-link { @apply px-4 py-2 bg-background border border-border rounded-full text-sm text-primary font-medium hover:border-primary transition-colors; }
  .faq-item { @apply bg-card border border-border rounded-xl overflow-hidden; }
  .faq-question { @apply flex justify-between items-center p-6 cursor-pointer font-semibold text-foreground list-none select-none hover:bg-accent/50 transition-colors; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-icon { @apply text-2xl text-primary font-light leading-none shrink-0; }
  .faq-answer { @apply px-6 pb-6 text-muted-foreground leading-relaxed; }
</style>
