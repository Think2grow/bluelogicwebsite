---
import Layout from "../layouts/Layout.astro";
import LeadForm from "../components/LeadForm.astro";
import ParallaxHero from "../components/ParallaxHero.astro";
import ProductExplosion from "../components/ProductExplosion.astro";
import { getBreadcrumbSchema } from "../utils/schema";

// Generate homepage-specific schema
const siteUrl = Astro.site?.toString() || "https://bluelogicwater.com";

const schemas = [getBreadcrumbSchema(siteUrl, [{ name: "Home", url: "/" }])];
---

<Layout
  title="Blue Logic Water - Premium RO Systems for Salt Lake City"
  schema={schemas}
>
  <!-- Localized Parallax Hero (Task 3.2) -->
  <ParallaxHero
    title="Your Family, Unfiltered."
    subtitle="Professional reverse osmosis systems for the health-conscious home"
    tagline="Half the cost. Half the footprint. 10x quieter."
    ctaText="Schedule Free Water Audit"
    ctaHref="#contact"
  />

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-serif mb-8 text-foreground">
        Purity Without the Premium
      </h2>
      <p
        class="text-lg leading-relaxed text-muted-foreground mb-6 max-w-3xl mx-auto"
      >
        We believe every family deserves access to the purest water without the
        inflated price tag. Blue Logic Water delivers professional-grade reverse
        osmosis systems at half the industry cost—$15k instead of $30k.
      </p>
      <p
        class="text-lg leading-relaxed text-muted-foreground max-w-3xl mx-auto"
      >
        Our mission is simple: provide Salt Lake City homes with the same
        advanced water purification technology used in commercial facilities,
        without the unnecessary markup.
      </p>
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-3xl md:text-4xl font-serif text-center mb-12 text-foreground"
      >
        The Blue Logic Difference
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        <div class="text-center p-8 bg-background rounded-2xl">
          <h3 class="text-2xl md:text-3xl font-semibold mb-4 text-primary">
            1/2 the Cost
          </h3>
          <p class="text-muted-foreground">
            $15,000 vs $30,000+ from competitors
          </p>
        </div>
        <div class="text-center p-8 bg-background rounded-2xl">
          <h3 class="text-2xl md:text-3xl font-semibold mb-4 text-primary">
            1/2 the Footprint
          </h3>
          <p class="text-muted-foreground">
            Sleek, compact design for modern homes
          </p>
        </div>
        <div class="text-center p-8 bg-background rounded-2xl">
          <h3 class="text-2xl md:text-3xl font-semibold mb-4 text-primary">
            10x Quieter
          </h3>
          <p class="text-muted-foreground">
            Advanced sound-dampening technology
          </p>
        </div>
      </div>
      <a
        href="/the-system"
        class="block text-center text-primary font-semibold text-lg hover:opacity-80 transition-opacity"
      >
        Explore The System →
      </a>
    </div>
  </section>

  <!-- Product Explosion Animation (Task 3.1) -->
  <ProductExplosion
    title="Engineering Excellence"
    subtitle="Premium components working in perfect harmony to deliver the purest water for your family"
  />

  <!-- Social Proof Section -->
  <section class="bg-background py-16 md:py-24 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif mb-4 text-foreground">
          Trusted by 500+ Homes in the Wasatch Front
        </h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          From Park City to Draper, families throughout the Salt Lake Valley
          trust Blue Logic for their water purification needs.
        </p>
      </div>

      <!-- Location Trust Grid -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        <a
          href="/locations/salt-lake-city"
          class="group p-4 md:p-6 bg-card rounded-xl border border-border hover:border-primary/30 transition-all hover:shadow-md"
        >
          <div class="text-sm text-muted-foreground mb-1">Salt Lake City</div>
          <div
            class="text-lg font-semibold text-foreground group-hover:text-primary transition-colors"
          >
            200+ Installations
          </div>
        </a>
        <a
          href="/locations/draper"
          class="group p-4 md:p-6 bg-card rounded-xl border border-border hover:border-primary/30 transition-all hover:shadow-md"
        >
          <div class="text-sm text-muted-foreground mb-1">Draper</div>
          <div
            class="text-lg font-semibold text-foreground group-hover:text-primary transition-colors"
          >
            85+ Installations
          </div>
        </a>
        <a
          href="/locations/park-city"
          class="group p-4 md:p-6 bg-card rounded-xl border border-border hover:border-primary/30 transition-all hover:shadow-md"
        >
          <div class="text-sm text-muted-foreground mb-1">Park City</div>
          <div
            class="text-lg font-semibold text-foreground group-hover:text-primary transition-colors"
          >
            120+ Installations
          </div>
        </a>
        <a
          href="/locations/sandy"
          class="group p-4 md:p-6 bg-card rounded-xl border border-border hover:border-primary/30 transition-all hover:shadow-md"
        >
          <div class="text-sm text-muted-foreground mb-1">Sandy</div>
          <div
            class="text-lg font-semibold text-foreground group-hover:text-primary transition-colors"
          >
            95+ Installations
          </div>
        </a>
      </div>

      <div class="text-center mt-8">
        <a
          href="/locations"
          class="text-primary hover:text-primary/80 font-medium transition-colors"
        >
          View All Service Areas →
        </a>
      </div>
    </div>
  </section>

  <LeadForm />
</Layout>
