---
import Layout from "../layouts/Layout.astro";
import LeadForm from "../components/LeadForm.astro";
---

<Layout title="Blue Logic Water - Premium RO Systems for Salt Lake City">
  <section class="hero">
    <div class="hero-content">
      <h1>Your Family, Unfiltered.</h1>
      <p class="hero-subtitle">
        Professional reverse osmosis systems for the health-conscious home
      </p>
      <p class="hero-description">
        Half the cost. Half the footprint. 10x quieter.
      </p>
      <a href="#contact" class="cta-button">Schedule Free Water Audit</a>
    </div>
  </section>

  <section class="mission">
    <div class="container">
      <h2>Purity Without the Premium</h2>
      <p>
        We believe every family deserves access to the purest water without the
        inflated price tag. Blue Logic Water delivers professional-grade reverse
        osmosis systems at half the industry cost—$15k instead of $30k.
      </p>
      <p>
        Our mission is simple: provide Salt Lake City homes with the same
        advanced water purification technology used in commercial facilities,
        without the unnecessary markup.
      </p>
    </div>
  </section>

  <section class="value-snapshot">
    <div class="container">
      <h2>The Blue Logic Difference</h2>
      <div class="value-grid">
        <div class="value-item">
          <h3>1/2 the Cost</h3>
          <p>$15,000 vs $30,000+ from competitors</p>
        </div>
        <div class="value-item">
          <h3>1/2 the Footprint</h3>
          <p>Sleek, compact design for modern homes</p>
        </div>
        <div class="value-item">
          <h3>10x Quieter</h3>
          <p>Advanced sound-dampening technology</p>
        </div>
      </div>
      <a href="/the-system" class="link-button">Explore The System →</a>
    </div>
  </section>

  <section class="trust">
    <div class="container">
      <h2>Trusted by 500+ Homes in the Wasatch Front</h2>
      <p>
        From Park City to Draper, families throughout the Salt Lake Valley trust
        Blue Logic for their water purification needs.
      </p>
    </div>
  </section>

  <LeadForm />
</Layout>

<style>
  .hero {
    background: linear-gradient(
      135deg,
      oklch(0.95 0.01 90) 0%,
      oklch(0.85 0.05 220) 100%
    );
    padding: 8rem 2rem 6rem;
    text-align: center;
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero h1 {
    font-size: 4rem;
    font-family: "Instrument Serif", Georgia, serif;
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .hero-subtitle {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: oklch(0.4 0.02 270);
  }

  .hero-description {
    font-size: 1.25rem;
    margin-bottom: 2rem;
    color: oklch(0.5 0.02 270);
  }

  .cta-button {
    display: inline-block;
    background-color: oklch(0.7 0.1 220);
    color: white;
    padding: 1rem 2.5rem;
    text-decoration: none;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 1.125rem;
    transition: opacity 0.2s;
  }

  .cta-button:hover {
    opacity: 0.9;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .mission {
    background-color: white;
  }

  .mission h2 {
    font-size: 2.5rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  .mission p {
    font-size: 1.125rem;
    line-height: 1.8;
    max-width: 800px;
    margin: 0 auto 1.5rem;
    text-align: center;
    color: oklch(0.4 0.02 270);
  }

  .value-snapshot {
    background-color: oklch(0.98 0.01 90);
  }

  .value-snapshot h2 {
    font-size: 2.5rem;
    text-align: center;
    margin-bottom: 3rem;
  }

  .value-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .value-item {
    text-align: center;
    padding: 2rem;
    background-color: white;
    border-radius: 1rem;
  }

  .value-item h3 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    color: oklch(0.7 0.1 220);
  }

  .value-item p {
    color: oklch(0.4 0.02 270);
  }

  .link-button {
    display: block;
    text-align: center;
    color: oklch(0.7 0.1 220);
    font-weight: 600;
    font-size: 1.125rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .link-button:hover {
    opacity: 0.7;
  }

  .trust {
    background-color: white;
    text-align: center;
  }

  .trust h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .trust p {
    font-size: 1.125rem;
    color: oklch(0.4 0.02 270);
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2.5rem;
    }

    .hero-subtitle {
      font-size: 1.25rem;
    }

    .hero {
      padding: 4rem 1rem 3rem;
    }

    .value-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
