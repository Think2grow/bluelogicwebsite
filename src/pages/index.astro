---
import Layout from "../layouts/Layout.astro";
import LeadForm from "../components/LeadForm.astro";
import ParallaxHero from "../components/ParallaxHero.astro";
import ProductExplosion from "../components/ProductExplosion.astro";
import Reviews from "../components/Reviews.astro";
import { getBreadcrumbSchema, getAggregateRatingSchema } from "../utils/schema";
import { Image } from "astro:assets";
import fatherDaughterImg from "../assets/water_art/AdobeStock_302662231_father_daughter_faucet.jpeg";
import babyBathImg from "../assets/water_art/AdobeStock_600699653_baby_in_bubble_bath.jpeg";
import BrochureDownload from "../components/BrochureDownload.astro";

export const prerender = true;

// Generate homepage-specific schema
const siteUrl = Astro.site?.toString() || "https://bluelogicwater.com";

const schemas = [
  getBreadcrumbSchema(siteUrl, [{ name: "Home", url: "/" }]),
  getAggregateRatingSchema(`${siteUrl}/`, 5.0, 10),
];
---

<Layout
  title="Water Treatment Utah | Blue Logic Water — Wasatch Front"
  description="Whole-home reverse osmosis and filtration systems for Utah's Wasatch Front. Competitively priced with a written price-match guarantee. Free in-home water test. Serving Ogden to Springville."
  schema={schemas}
>
  <!-- Localized Parallax Hero (Task 3.2) -->
  <ParallaxHero
    title="Your Family, Unfiltered."
    subtitle="Whole home reverse osmosis systems for the health-conscious home"
    tagline="Half the cost. Half the footprint. 10x quieter."
    ctaText="Schedule Free Water Test"
    ctaHref="/free-water-test/"
  />

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-serif mb-8 text-foreground">
        Purity Without the Premium
      </h2>
      <p class="text-lg leading-relaxed text-muted-foreground mb-6 max-w-3xl mx-auto">
        Blue Logic installs professional-grade <a href="/whole-home-reverse-osmosis-utah/" class="text-primary hover:underline font-semibold">whole-home reverse osmosis systems</a>, <a href="/whole-home-water-filtration/" class="text-primary hover:underline font-semibold">whole-home filtration</a>, and <a href="/water-softener-utah/" class="text-primary hover:underline font-semibold">water softeners</a> across Utah's Wasatch Front — backed by a written price-match guarantee on any competing quote.
      </p>
      <p class="text-lg leading-relaxed text-muted-foreground max-w-3xl mx-auto">
        Every system starts with a <a href="/free-water-test/" class="text-primary hover:underline font-semibold">free in-home water test</a>. We serve <a href="/locations/salt-lake-city/" class="text-primary hover:underline font-semibold">Salt Lake City</a>, <a href="/locations/provo/" class="text-primary hover:underline font-semibold">Provo</a>, <a href="/locations/lehi/" class="text-primary hover:underline font-semibold">Lehi</a>, <a href="/locations/draper/" class="text-primary hover:underline font-semibold">Draper</a>, and the full Wasatch Front.
      </p>
    </div>
  </section>

  <!-- Services Hub -->
  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif text-center mb-4 text-foreground">
        Water Treatment Systems for Utah Homes
      </h2>
      <p class="text-muted-foreground text-center max-w-2xl mx-auto mb-10">
        Three levels of water treatment — each starting with an integrated water softener and building from there.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <a href="/water-softener-utah/" class="service-card group">
          <div class="service-icon">💧</div>
          <h3 class="text-xl font-semibold text-foreground mb-2 group-hover:text-primary transition-colors">Water Softener</h3>
          <p class="text-sm text-muted-foreground leading-relaxed mb-4">Addresses hard water, scale, and appliance damage. Integrated softening using 75% less salt than traditional units.</p>
          <span class="text-primary text-sm font-semibold">Learn more →</span>
        </a>
        <a href="/whole-home-water-filtration/" class="service-card group border-primary/30">
          <div class="service-icon">🔵</div>
          <h3 class="text-xl font-semibold text-foreground mb-2 group-hover:text-primary transition-colors">Whole-Home Filtration</h3>
          <p class="text-sm text-muted-foreground leading-relaxed mb-4">Softening plus 7-layer media filtration for chlorine, chloramines, iron, manganese, and taste. Includes free under-sink RO.</p>
          <span class="text-primary text-sm font-semibold">Learn more →</span>
        </a>
        <a href="/whole-home-reverse-osmosis-utah/" class="service-card group bg-primary/5 border-primary/40">
          <div class="service-icon">✨</div>
          <div class="text-xs font-bold uppercase tracking-wide text-primary mb-2">Most Complete</div>
          <h3 class="text-xl font-semibold text-foreground mb-2 group-hover:text-primary transition-colors">Whole-Home RO</h3>
          <p class="text-sm text-muted-foreground leading-relaxed mb-4">Everything in filtration plus a commercial-grade RO membrane. Pure water at every tap. Addresses arsenic, PFAS, and heavy metals.</p>
          <span class="text-primary text-sm font-semibold">Learn more →</span>
        </a>
      </div>
      <div class="text-center">
        <a href="/water-softener-vs-whole-home-filtration/" class="text-primary font-semibold text-sm hover:opacity-80 transition-opacity">
          Not sure which is right for your home? Compare all options →
        </a>
      </div>
    </div>
  </section>

  <!-- Family Trust Section with Image -->
  <section class="bg-card py-16 md:py-24 px-4 overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <h2 class="text-3xl md:text-4xl font-serif mb-6 text-foreground">
            Pure Water for Your Family
          </h2>
          <p class="text-lg text-muted-foreground leading-relaxed mb-6">
            Every glass, every bath, every meal—your family deserves water you
            can trust completely. Our whole-home systems ensure pure water flows
            from every tap.
          </p>
          <p class="text-lg text-muted-foreground leading-relaxed mb-8">
            No more worrying about what's in your water. From your newborn's
            first bath to your morning coffee, experience the peace of mind that
            comes with <a
              href="/the-system/"
              class="text-primary hover:underline font-semibold"
              >up to 99% contaminant removal</a
            >.
          </p>
          <a
            href="/the-system/"
            class="inline-flex w-full justify-center px-5 py-3 rounded-full bg-primary text-primary-foreground font-semibold text-lg shadow-md border border-primary/30 transition-all md:w-auto md:bg-transparent md:text-primary md:shadow-none md:border-0 md:px-0 md:py-0 md:hover:opacity-80 md:transition-opacity"
          >
            Learn How It Works →
          </a>
        </div>
        <div class="order-1 lg:order-2">
          <div class="relative">
            <Image
              src={fatherDaughterImg}
              alt="Father and daughter enjoying pure water together at the kitchen sink"
              class="rounded-2xl shadow-2xl w-full object-cover aspect-4/3"
              widths={[400, 600, 800]}
              sizes="(max-width: 768px) 100vw, 50vw"
              quality={50}
            />
            <div
              class="absolute -bottom-4 -right-4 bg-primary text-primary-foreground px-6 py-3 rounded-xl font-semibold shadow-lg"
            >
              Water You Can Trust
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-3xl md:text-4xl font-serif text-center mb-12 text-foreground"
      >
        The Blue Logic Difference
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        <div class="text-center p-8 bg-background rounded-2xl">
          <h3 class="text-2xl md:text-3xl font-semibold mb-4 text-primary">
            1/2 the Cost
          </h3>
          <p class="text-muted-foreground">Half the price of competitors</p>
        </div>
        <div class="text-center p-8 bg-background rounded-2xl">
          <h3 class="text-2xl md:text-3xl font-semibold mb-4 text-primary">
            1/2 the Footprint
          </h3>
          <p class="text-muted-foreground">
            Sleek, compact design for modern homes
          </p>
        </div>
        <div class="text-center p-8 bg-background rounded-2xl">
          <h3 class="text-2xl md:text-3xl font-semibold mb-4 text-primary">
            10x Quieter
          </h3>
          <p class="text-muted-foreground">
            Advanced sound-dampening technology
          </p>
        </div>
      </div>
      <a
        href="/the-system/"
        class="inline-flex w-full justify-center px-5 py-3 rounded-full bg-primary text-primary-foreground font-semibold text-lg shadow-md border border-primary/30 transition-all md:w-auto md:bg-transparent md:text-primary md:shadow-none md:border-0 md:px-0 md:py-0 md:hover:opacity-80 md:transition-opacity"
      >
        Explore The System →
      </a>
    </div>
  </section>

  <!-- Product Explosion Animation (Task 3.1) -->
  <ProductExplosion
    title="Engineering Excellence"
    subtitle="Premium components working in perfect harmony to deliver the purest water for your family"
  />

  <!-- Social Proof Section -->
  <section class="bg-background py-16 md:py-24 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
        <div>
          <Image
            src={babyBathImg}
            alt="Happy baby enjoying a gentle bubble bath in pure, filtered water"
            class="rounded-2xl shadow-xl w-full object-cover aspect-square"
            widths={[400, 600]}
            sizes="(max-width: 768px) 100vw, 50vw"
            quality={50}
          />
        </div>
        <div>
          <h2 class="text-3xl md:text-4xl font-serif mb-4 text-foreground">
            Safe from the First Bath
          </h2>
          <p class="text-lg text-muted-foreground mb-6 leading-relaxed">
            A baby's skin absorbs what's in the water. Our whole-home systems
            remove chlorine, PFAS, and contaminants from every faucet so bath
            time is pure, gentle, and worry-free.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            Because protecting your family means pure water everywhere, not just
            at the kitchen sink.
          </p>
        </div>
      </div>

      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif mb-4 text-foreground">
          Protection That Starts Before You Can See the Threat
        </h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          From Park City to Draper and everywhere in between, our whole-home reverse osmosis systems are designed to protect your home, your family, and your life, even when contaminants move through the pipes unnoticed.        </p>
      </div>

      <!-- Location Trust Grid -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        <a
          href="/locations/salt-lake-city/"
          class="group p-4 md:p-6 bg-card rounded-xl border border-border hover:border-primary/30 transition-all hover:shadow-md"
        >
          <div class="text-sm text-muted-foreground mb-1">Salt Lake City</div>
          <div
            class="text-lg font-semibold text-foreground group-hover:text-primary transition-colors"
          >
            Arsenic - 135 times the health guideline.
          </div>
        </a>
        <a
          href="/locations/draper/"
          class="group p-4 md:p-6 bg-card rounded-xl border border-border hover:border-primary/30 transition-all hover:shadow-md"
        >
          <div class="text-sm text-muted-foreground mb-1">Draper</div>
          <div
            class="text-lg font-semibold text-foreground group-hover:text-primary transition-colors"
          >
            Arsenic - 450 times the health guideline.
          </div>
        </a>
        <a
          href="/locations/park-city/"
          class="group p-4 md:p-6 bg-card rounded-xl border border-border hover:border-primary/30 transition-all hover:shadow-md"
        >
          <div class="text-sm text-muted-foreground mb-1">Park City</div>
          <div
            class="text-lg font-semibold text-foreground group-hover:text-primary transition-colors"
          >
            Arsenic - 343 times the health guideline.
          </div>
        </a>
        <a
          href="/locations/sandy/"
          class="group p-4 md:p-6 bg-card rounded-xl border border-border hover:border-primary/30 transition-all hover:shadow-md"
        >
          <div class="text-sm text-muted-foreground mb-1">Sandy</div>
          <div
            class="text-lg font-semibold text-foreground group-hover:text-primary transition-colors"
          >
            Haloacetic acids (HAA9) - 409 times the health guideline.
          </div>
        </a>
      </div>

      <div class="text-center mt-8">
        <a
          href="/locations/"
          class="inline-flex w-full justify-center px-5 py-3 rounded-full bg-primary text-primary-foreground font-semibold shadow-md border border-primary/30 transition-all md:w-auto md:bg-transparent md:text-primary md:shadow-none md:border-0 md:px-0 md:py-0 md:hover:text-primary/80"
        >
          View All Service Areas →
        </a>
      </div>

    </div>
  </section>

  <!-- Reviews -->
  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <Reviews max={6} />
      <div class="text-center mt-10">
        <a
          href="https://maps.app.goo.gl/SRHLVoVec7bkQx566"
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary font-semibold hover:opacity-80 transition-opacity text-sm"
        >
          See all reviews on Google →
        </a>
      </div>
    </div>
  </section>

  <section class="bg-card justify-center py-16 md:py-20 px-4">
    <BrochureDownload />
  </section>

  <LeadForm />
</Layout>

<style>
  @reference "../styles/global.css";
  .service-card {
    @apply flex flex-col bg-background border-2 border-border rounded-2xl p-6 no-underline hover:border-primary hover:-translate-y-1 transition-all duration-200 shadow-sm hover:shadow-md;
  }
  .service-icon {
    @apply text-3xl mb-3;
  }
</style>
