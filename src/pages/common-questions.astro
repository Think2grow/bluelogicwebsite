---
import Layout from "../layouts/Layout.astro";
import { getFAQSchema, getBreadcrumbSchema } from "../utils/schema";
import { Image } from "astro:assets";
import cleanWaterSinkImg from "../assets/water_art/AdobeStock_706544309_clean_water_in_sink.jpeg";
import toddlerWaterImg from "../assets/water_art/AdobeStock_689029947_toddler_with_water.jpeg";

export const prerender = true;

interface FAQ {
  question: string;
  answer: string;
}

const faqs: FAQ[] = [
  {
    question:
      "How is the Blue Logic Whole-Home Purification System different from a regular filter or softener?",
    answer:
      "Most systems filter some contaminants - but Blue Logic purifies at the molecular level. Our <a href='/the-system' class='text-primary hover:underline font-semibold'>Whole-Home Purification System</a> combines advanced pretreatment with reverse osmosis technology to remove up to 99% of contaminants at every tap, not just one faucet.",
  },
  {
    question: "What does the Whole-Home Filtration System actually remove?",
    answer:
      "Our 7-layer filtration media targets chlorine, chloramines, PFAS, pesticides, pharmaceuticals, heavy metals, and hard water minerals. It's a full-spectrum reduction system - designed to make your home's water cleaner, healthier, and better-tasting. <a href='/the-system' class='text-primary hover:underline font-semibold'>Learn how it works</a>.",
  },
  {
    question: "Will this replace my water softener?",
    answer:
      "Yes. Blue Logic Filtration softens and conditions water naturally without the slick, slimy feel or added salt from traditional softeners. You’ll still get that clean, soft-water experience - but without the maintenance headaches.",
  },
  {
    question: "What kind of maintenance is required?",
    answer:
      "Very little. Both our filtration and purification systems are designed for high efficiency and long service life. Typically, media and filters are serviced once per year during your annual check-up - that’s it.",
  },
  {
    question: "How much does a Blue Logic RO system cost?",
    answer:
      "Our professional whole-home reverse osmosis systems are competitively priced at roughly half the cost of competitors while using the same commercial-grade components. Final pricing depends on your home's size, layout, and specific requirements. <a href='/the-value' class='text-primary hover:underline font-semibold'>Contact us for a free consultation and transparent quote—no hidden fees or upsells</a>.",
  },
  {
    question: "How long does installation take?",
    answer:
      "Most installations are completed in one day (4-8 hours depending on your home's layout). Our team works efficiently while maintaining meticulous attention to detail. We'll provide a specific timeline during your consultation.",
  },
  {
    question: "How much water is wasted during the RO process?",
    answer:
      "Modern RO systems are far more efficient than older models. Our systems waste approximately 3-4 gallons for every gallon of purified water produced. While this may seem like a lot, it's significantly better than older systems (which could waste 8-10 gallons per gallon) and ensures optimal purification.",
  },
  {
    question: "Will this remove the minerals from my water?",
    answer:
      "Yes, reverse osmosis removes up to 99% of all dissolved solids, including minerals. This is precisely why RO is so effective—it removes both harmful contaminants and hardness-causing minerals, giving you pure water that's healthier for drinking and better for your home.",
  },
  {
    question: "Do you serve my area?",
    answer:
      "We serve the entire <a href='/locations' class='text-primary hover:underline font-semibold'>Wasatch Front including Salt Lake City, Park City, Draper, Sandy, Cottonwood Heights, Holladay, Murray, Millcreek, and surrounding areas</a>. Contact us to confirm service availability for your specific location.",
  },
  {
    question: "What contaminants does RO remove?",
    answer:
      "Reverse osmosis removes up to 99% of total dissolved solids (TDS) including heavy metals (lead, arsenic, mercury), chlorine, fluoride, PFAS (forever chemicals), pesticides, bacteria, and viruses. It's the most comprehensive water purification available for residential use.",
  },
  {
    question: "Why is your system quieter than others?",
    answer:
      "We use advanced sound-dampening technology and premium components designed for quiet operation. While traditional systems can be quite noisy during cycling, our system operates at approximately 1/10th the noise level—quiet enough that you'll barely notice it's running.",
  },
  {
    question: "What's included in the installation?",
    answer:
      "Everything: the complete RO system, professional installation, all necessary plumbing connections, initial water quality testing, system startup and calibration, and comprehensive warranty. We provide transparent, all-inclusive pricing with no hidden costs or surprise fees.",
  },
  {
    question: "How does Utah's hard water affect RO systems?",
    answer:
      "Utah has some of the hardest water in the country with high TDS levels (300-500+ ppm in many areas). This is actually where RO systems shine—they're specifically designed to handle hard water and reduce TDS to near-zero levels. <a href='/the-system' class='text-primary hover:underline font-semibold'>The high mineral content in Utah water makes RO the most effective purification method available</a>.",
  },
  {
    question: "What warranty do you offer?",
    answer:
      "We provide a comprehensive warranty covering parts and labor. Specific terms vary by component, but we stand behind our installations. As a local company, we're here for ongoing support—not just for the sale.",
  },
  {
    question: "Can I install this myself to save money?",
    answer:
      "While technically possible, we strongly recommend professional installation. RO systems require precise plumbing connections, pressure adjustments, and proper drainage setup. Improper installation can lead to leaks, poor performance, or system damage. Our installation is included in the price and ensures everything works perfectly from day one.",
  },
];

// Generate FAQ page-specific schema
const siteUrl = Astro.site?.toString() || "https://bluelogicwater.com";

const schemas = [
  getFAQSchema(faqs),
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "FAQ", url: "/common-questions" },
  ]),
];
---

<Layout
  title="FAQ - Blue Logic Water Common Questions"
  description="Common questions about reverse osmosis systems, installation, cost, maintenance, and water quality in Salt Lake City."
  schema={schemas}
>
  <section class="hero-gradient py-20 md:py-24 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-6xl font-serif mb-4 text-foreground">
        Common Questions
      </h1>
      <p class="text-xl md:text-2xl text-muted-foreground">
        Everything you need to know about Blue Logic Water systems
      </p>
    </div>
  </section>

  <!-- Trust-building Image Section -->
  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <Image
            src={cleanWaterSinkImg}
            alt="Crystal clear purified water flowing into a modern kitchen sink"
            class="rounded-2xl shadow-xl w-full object-cover aspect-4/3"
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 100vw, 50vw"
            quality={50}
          />
        </div>
        <div>
          <h2 class="text-3xl md:text-4xl font-serif mb-6 text-foreground">
            Your Questions, Answered
          </h2>
          <p class="text-lg text-muted-foreground leading-relaxed mb-6">
            Investing in a water purification system is a big decision. We've
            compiled the most common questions from Utah homeowners to help you
            make an informed choice.
          </p>
          <p class="text-lg text-muted-foreground leading-relaxed">
            Still have questions? Our team of local water experts is here to
            help—with honest answers, not sales pressure.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-lg text-muted-foreground">
          Have a question not answered here? <a
            href="/#contact"
            class="text-primary font-semibold hover:underline">Contact us</a
          > and we'll be happy to help.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        {
          faqs.map((faq, index) => (
            <div
              class="faq-item"
              id={`faq-${faq.answer.replace(/\s+/g, "-").toLowerCase()}`}
            >
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls={`answer-${index}`}
              >
                <span>{faq.question}</span>
                <span class="faq-icon">+</span>
              </button>
              <div class="faq-answer" id={`answer-${index}`}>
                <p
                  class="pb-6 text-muted-foreground leading-relaxed"
                  set:html={faq.answer}
                />
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Family Safety Image Section -->
  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <h2 class="text-3xl md:text-4xl font-serif mb-6 text-foreground">
            Pure Water at Every Stage
          </h2>
          <p class="text-lg text-muted-foreground leading-relaxed mb-6">
            From a baby's first sip to daily hydration, your family's water
            matters at every age. Our whole-home systems ensure every drop is
            pure—whether it's for drinking, cooking, or bathing.
          </p>
          <p class="text-lg text-muted-foreground leading-relaxed">
            That's the Blue Logic difference: complete peace of mind, not just
            at one tap.
          </p>
        </div>
        <div class="order-1 lg:order-2">
          <Image
            src={toddlerWaterImg}
            alt="Happy toddler safely drinking pure filtered water"
            class="rounded-2xl shadow-xl w-full object-cover aspect-4/3"
            widths={[400, 600]}
            sizes="(max-width: 768px) 100vw, 50vw"
            quality={50}
          />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif mb-4 text-foreground">
        Still Have Questions?
      </h2>
      <p class="text-xl text-muted-foreground mb-8">
        Schedule a free consultation with our team
      </p>
      <a href="/#contact" class="btn btn-primary btn-lg w-full md:w-auto">Get in Touch</a>
    </div>
  </section>
</Layout>

<style>
  @reference "../styles/global.css";
  .faq-item {
    @apply border-b border-border;
  }

  .faq-question {
    @apply w-full flex justify-between items-center py-6 bg-transparent border-none cursor-pointer text-left text-lg md:text-xl font-semibold text-foreground transition-colors duration-200;
  }

  .faq-question:hover {
    @apply text-primary;
  }

  .faq-icon {
    @apply text-2xl text-primary font-light transition-transform duration-300 shrink-0 ml-4;
  }

  .faq-question[aria-expanded="true"] .faq-icon {
    @apply rotate-45;
  }

  .faq-answer {
    @apply max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out;
  }

  .faq-answer.open {
    transition: max-height 0.3s ease-in;
  }
</style>

<script>
  function setupAccordion() {
    const faqButtons = document.querySelectorAll(".faq-question");

    faqButtons.forEach((button) => {
      // Remove existing listeners to prevent duplicates
      const newButton = button.cloneNode(true) as HTMLButtonElement;
      button.replaceWith(newButton);

      newButton.addEventListener("click", () => {
        const isExpanded = newButton.getAttribute("aria-expanded") === "true";
        const answerId = newButton.getAttribute("aria-controls");
        const answer = answerId ? document.getElementById(answerId) : null;

        // Close all other answers
        document.querySelectorAll(".faq-question").forEach((otherButton) => {
          if (otherButton !== newButton) {
            otherButton.setAttribute("aria-expanded", "false");
            const otherAnswerId = otherButton.getAttribute("aria-controls");
            const otherAnswer = otherAnswerId
              ? document.getElementById(otherAnswerId)
              : null;
            if (otherAnswer) {
              otherAnswer.style.maxHeight = "0";
              otherAnswer.classList.remove("open");
            }
          }
        });

        // Toggle current answer
        if (!isExpanded && answer) {
          answer.style.maxHeight = answer.scrollHeight + "px";
          answer.classList.add("open");
        } else if (answer) {
          answer.style.maxHeight = "0";
          answer.classList.remove("open");
        }
        newButton.setAttribute("aria-expanded", String(!isExpanded));
      });
    });
  }

  // Run on initial load
  setupAccordion();

  // Run on every View Transition navigation
  document.addEventListener("astro:page-load", setupAccordion);
</script>
