---
import Layout from "../layouts/Layout.astro";
import { getFAQSchema, getBreadcrumbSchema } from "../utils/schema";
import { Image } from "astro:assets";
import cleanWaterSinkImg from "../assets/water_art/AdobeStock_706544309_clean_water_in_sink.jpeg";
import toddlerWaterImg from "../assets/water_art/AdobeStock_689029947_toddler_with_water.jpeg";

export const prerender = true;

interface FAQ {
  question: string;
  answer: string;
}

const faqs: FAQ[] = [
  {
    question:
      "How is the Blue Logic Whole-Home Purification System different from a regular filter or softener?",
    answer:
      "Most systems filter some contaminants - but Blue Logic purifies at the molecular level. Our <a href='/the-system/' class='text-primary hover:underline font-semibold'>Whole-Home Purification System</a> combines advanced pretreatment with reverse osmosis technology to remove up to 99% of contaminants at every tap, not just one faucet.",
  },
  {
    question: "What does the Whole-Home Filtration System actually remove?",
    answer:
      "Our 7-layer filtration media targets chlorine, chloramines, PFAS, pesticides, pharmaceuticals, heavy metals, and hard water minerals. It's a full-spectrum reduction system - designed to make your home's water cleaner, healthier, and better-tasting. <a href='/the-system/' class='text-primary hover:underline font-semibold'>Learn how it works</a>.",
  },
  {
    question: "Will this replace my water softener?",
    answer:
      "Yes. Blue Logic Filtration softens and conditions water naturally without the slick, slimy feel or added salt from traditional softeners. You’ll still get that clean, soft-water experience - but without the maintenance headaches.",
  },
  {
    question: "What kind of maintenance is required?",
    answer:
      "Minimal ongoing maintenance. You'll need to periodically refill salt for the water softener component (both systems include water softening as part of the pre-treatment process). Additionally, media and filters are serviced once per year during your annual check-up. Salt usage varies by household but typically requires refilling every few months.",
  },
  {
    question: "How much does a Blue Logic RO system cost?",
    answer:
      "Blue Logic whole-home systems are priced at $5,995–$19,999 depending on your home's size, layout, and the system selected — confirmed at your free water test with no hidden fees. We also offer a written price-match guarantee on any competing quote from a licensed Utah water treatment company. <a href='/free-water-test/' class='text-primary hover:underline font-semibold'>Schedule your free water test for a transparent quote</a>.",
  },
  {
    question: "How long does installation take?",
    answer:
      "Most installations are completed in one day (4-8 hours depending on your home's layout). Our certified installation partners work efficiently while maintaining meticulous attention to detail. We'll provide a specific timeline during your consultation.",
  },
  {
    question: "How much water is wasted during the RO process?",
    answer:
      "Modern RO systems are far more efficient than older models. Our systems produce approximately 3 gallons of purified water for every 1 gallon of waste water (75% efficiency). This is significantly better than older systems which could waste 8-10 gallons per gallon of purified water produced, and ensures optimal purification performance.",
  },
  {
    question: "Will this remove the minerals from my water?",
    answer:
      "Yes, reverse osmosis removes up to 99% of all dissolved solids, including minerals. This is precisely why RO is so effective—it removes both harmful contaminants and hardness-causing minerals, giving you pure water that's healthier for drinking and better for your home. Note: Remineralization options are available upon request.",
  },
  {
    question: "Do you serve my area?",
    answer:
      "Blue Logic serves Utah's Wasatch Front from Ogden to Springville — <a href='/locations/' class='text-primary hover:underline font-semibold'>including Salt Lake City, Provo, Orem, Lehi, Sandy, Draper, Ogden, Layton, Bountiful, American Fork, Spanish Fork, Springville, and surrounding communities</a> across Weber, Davis, Salt Lake, and Utah Counties.",
  },
  {
    question: "What contaminants does RO remove?",
    answer:
      "Reverse osmosis works at the molecular level, addressing a broad range of dissolved inorganic contaminants including heavy metals (lead, arsenic, uranium), chlorine, fluoride, PFAS ('forever chemicals'), pharmaceutical residues, and dissolved solids. It is the most comprehensive residential water purification technology available. For specific contaminant concerns, your free water test and your city's EWG data are the best starting points.",
  },
  {
    question: "Why is your system quieter than others?",
    answer:
      "We use state-of-the-art premium components designed for quiet operation. While traditional systems can be quite noisy during cycling, our system operates at approximately 1/10th the noise level—quiet enough that you'll barely notice it's running.",
  },
  {
    question: "How does Utah's hard water affect RO systems?",
    answer:
      "Utah has some of the hardest water in the country — most Wasatch Front communities deliver water in the 10–25 grains-per-gallon range. This is where Blue Logic's integrated pre-filtration stage is critical: it removes hardness minerals before they reach the RO membrane, protecting the membrane and extending its service life. Without proper pre-treatment, hard water would scale and degrade an RO membrane rapidly. <a href='/utah-hard-water/' class='text-primary hover:underline font-semibold'>Learn more about Utah hard water</a>.",
  },
  {
    question: "What warranty do you offer?",
    answer:
      "We provide a limited 1-year warranty covering parts. Specific terms vary by component, but we stand behind every system. As a local company, we're here for ongoing support—not just for the sale.",
  },
  {
    question: "Can I install this myself to save money?",
    answer:
      "While technically possible, we strongly recommend professional installation. RO systems require precise plumbing connections, pressure adjustments, and proper drainage setup. Improper installation can lead to leaks, poor performance, or system damage. Our installation is included in the price and ensures everything works perfectly from day one.",
  },

  // Utah-specific and buyer-decision FAQs
  {
    question: "Do you offer financing?",
    answer:
      "Yes. Blue Logic offers in-house financing with half down at the time of installation. Repayment terms are flexible and arranged directly with Blue Logic — no third-party lender or credit check required. Specific terms are discussed at your free water test appointment based on the system you choose.",
  },
  {
    question: "Do you work on well water systems?",
    answer:
      "Blue Logic's primary focus is municipal water treatment for single-family homes on city water supplies. Well water typically requires additional pre-treatment (iron removal, pH adjustment, bacterial testing) before an RO system can be installed. If you're on well water, mention it when you schedule your free water test — our specialist will assess whether your well water is a good fit and what pre-treatment may be needed.",
  },
  {
    question: "What is remineralization and do I need it?",
    answer:
      "Reverse osmosis removes virtually all dissolved minerals from water, including calcium and magnesium. Some people prefer to add trace minerals back for taste or health reasons — this is called remineralization. Blue Logic can discuss remineralization options at your water test appointment. It is not required for the system to function correctly, and many homeowners find they prefer the clean, neutral taste of RO water without added minerals.",
  },
  {
    question: "Can I start with filtration and add RO purification later?",
    answer:
      "Yes. Blue Logic's systems are designed in stages. The whole-home filtration system (Stages 1–2) operates as a complete standalone system. The RO purification upgrade (Stages 3–4: RO membrane, pressurized storage tank, and delivery pump) can be added later without replacing the filtration foundation. Your specialist will explain the upgrade path and cost difference at your water test.",
  },
  {
    question: "What happens if my system needs a repair after the 1-year warranty?",
    answer:
      "Blue Logic is a local Utah company — we're not going anywhere. After the 1-year warranty, service and repairs are available on a per-visit basis. System components are designed for an 8–10 year lifespan with proper maintenance. Annual check-ups (scheduled by Jared at the time of installation) catch most issues before they become problems. Parts for Blue Logic systems are commercially sourced and not proprietary, so you're never locked into a single-source service arrangement.",
  },
  {
    question: "Does installing a whole-home system require a permit in Utah?",
    answer:
      "In most cases, a whole-home water treatment system installation in Utah does not require a separate permit if it connects to existing plumbing without significant modifications. Requirements vary by city and installation specifics. Your Blue Logic specialist will confirm permit requirements during the free water test site assessment. We handle or advise on any permit requirements as part of the installation process.",
  },
  {
    question: "Will my water pressure drop after the RO system is installed?",
    answer:
      "No — and this is one of the most common concerns. Blue Logic's whole-home purification system includes a dedicated delivery pump that restores your home's water pressure after the RO stage. The pressurized 165-gallon (or 250-gallon) storage tank ensures purified water is always available on demand. Most homeowners report no noticeable change in household water pressure.",
  },
  {
    question: "What is the annual maintenance cost after installation?",
    answer:
      "The primary ongoing cost is salt for the water softening stage — typically one to two bags every 2–3 months for a typical Utah household (roughly $40–$80 per year, significantly less than a traditional softener). The annual service check-up is scheduled by your technician and covers system inspection and filter media review. Salt is available at most home improvement stores.",
  },
  {
    question: "How do I know if the system is working properly?",
    answer:
      "Blue Logic walks you through the system indicators at installation. For most homeowners, the clearest sign is immediate: water tastes and smells different, scale stops forming on fixtures, and soap lathers more easily. Your specialist shows you what to look for and schedules an annual check-up to verify performance. If something seems off between check-ups, you can call or text Blue Logic directly — we're a local team, not a call center.",
  },
  {
    question: "What's the difference between Blue Logic and a Berkey or countertop gravity filter?",
    answer:
      "Countertop gravity filters like Berkey treat water at a single point — typically your kitchen — at a very slow flow rate. They require manual refilling and don't treat shower water, bath water, laundry water, or the water going into your appliances. Blue Logic's whole-home system treats every tap and fixture in your house simultaneously at full household flow rate. For whole-home protection against hard water, chlorine, and contaminants, there is no comparison to a point-of-use gravity filter.",
  },
];

const siteUrl = "https://www.bluelogicwater.com";

const schemas = [
  getFAQSchema(faqs),
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "FAQ", url: "/common-questions/" },
  ]),
];
---

<Layout
  title="Water Treatment FAQs | Blue Logic Water — Utah"
  description="Answers to the most common questions Utah homeowners ask about whole-home reverse osmosis, water softeners, filtration systems, cost, installation, and maintenance."
  schema={schemas}
>
  <section class="hero-gradient py-20 md:py-24 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-6xl font-serif mb-4 text-foreground">
        Common Questions
      </h1>
      <p class="text-xl md:text-2xl text-muted-foreground">
        Everything you need to know about Blue Logic Water systems
      </p>
    </div>
  </section>

  <!-- Trust-building Image Section -->
  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <Image
            src={cleanWaterSinkImg}
            alt="Crystal clear purified water flowing into a modern kitchen sink"
            class="rounded-2xl shadow-xl w-full object-cover aspect-4/3"
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 100vw, 50vw"
            quality={50}
          />
        </div>
        <div>
          <h2 class="text-3xl md:text-4xl font-serif mb-6 text-foreground">
            Your Questions, Answered
          </h2>
          <p class="text-lg text-muted-foreground leading-relaxed mb-6">
            Investing in a water purification system is a big decision. We've
            compiled the most common questions from Utah homeowners to help you
            make an informed choice.
          </p>
          <p class="text-lg text-muted-foreground leading-relaxed">
            Still have questions? Our team of local water experts is here to
            help—with honest answers, not sales pressure.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-lg text-muted-foreground">
          Have a question not answered here? <a
            href="/free-water-test/"
            class="text-primary font-semibold hover:underline">Contact us</a
          > and we'll be happy to help.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        {
          faqs.map((faq, index) => (
            <div
              class="faq-item"
              id={`faq-${faq.answer.replace(/\s+/g, "-").toLowerCase()}`}
            >
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls={`answer-${index}`}
              >
                <span>{faq.question}</span>
                <span class="faq-icon">+</span>
              </button>
              <div class="faq-answer" id={`answer-${index}`}>
                <p
                  class="pb-6 text-muted-foreground leading-relaxed"
                  set:html={faq.answer}
                />
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Family Safety Image Section -->
  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <h2 class="text-3xl md:text-4xl font-serif mb-6 text-foreground">
            Pure Water at Every Stage
          </h2>
          <p class="text-lg text-muted-foreground leading-relaxed mb-6">
            From a baby's first sip to daily hydration, your family's water
            matters at every age. Our whole-home systems ensure every drop is
            pure—whether it's for drinking, cooking, or bathing.
          </p>
          <p class="text-lg text-muted-foreground leading-relaxed">
            That's the Blue Logic difference: complete peace of mind, not just
            at one tap.
          </p>
        </div>
        <div class="order-1 lg:order-2">
          <Image
            src={toddlerWaterImg}
            alt="Happy toddler safely drinking pure filtered water"
            class="rounded-2xl shadow-xl w-full object-cover aspect-4/3"
            widths={[400, 600]}
            sizes="(max-width: 768px) 100vw, 50vw"
            quality={50}
          />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif mb-4 text-foreground">
        Still Have Questions?
      </h2>
      <p class="text-xl text-muted-foreground mb-8">
        Schedule a free consultation with our team
      </p>
      <a href="/free-water-test/" class="btn btn-primary btn-lg w-full md:w-auto">Get in Touch</a>
    </div>
  </section>
</Layout>

<style>
  @reference "../styles/global.css";
  .faq-item {
    @apply border-b border-border;
  }

  .faq-question {
    @apply w-full flex justify-between items-center py-6 bg-transparent border-none cursor-pointer text-left text-lg md:text-xl font-semibold text-foreground transition-colors duration-200;
  }

  .faq-question:hover {
    @apply text-primary;
  }

  .faq-icon {
    @apply text-2xl text-primary font-light transition-transform duration-300 shrink-0 ml-4;
  }

  .faq-question[aria-expanded="true"] .faq-icon {
    @apply rotate-45;
  }

  .faq-answer {
    @apply max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out;
  }

  .faq-answer.open {
    transition: max-height 0.3s ease-in;
  }
</style>

<script>
  function setupAccordion() {
    const faqButtons = document.querySelectorAll(".faq-question");

    faqButtons.forEach((button) => {
      // Remove existing listeners to prevent duplicates
      const newButton = button.cloneNode(true) as HTMLButtonElement;
      button.replaceWith(newButton);

      newButton.addEventListener("click", () => {
        const isExpanded = newButton.getAttribute("aria-expanded") === "true";
        const answerId = newButton.getAttribute("aria-controls");
        const answer = answerId ? document.getElementById(answerId) : null;

        // Close all other answers
        document.querySelectorAll(".faq-question").forEach((otherButton) => {
          if (otherButton !== newButton) {
            otherButton.setAttribute("aria-expanded", "false");
            const otherAnswerId = otherButton.getAttribute("aria-controls");
            const otherAnswer = otherAnswerId
              ? document.getElementById(otherAnswerId)
              : null;
            if (otherAnswer) {
              otherAnswer.style.maxHeight = "0";
              otherAnswer.classList.remove("open");
            }
          }
        });

        // Toggle current answer
        if (!isExpanded && answer) {
          answer.style.maxHeight = answer.scrollHeight + "px";
          answer.classList.add("open");
        } else if (answer) {
          answer.style.maxHeight = "0";
          answer.classList.remove("open");
        }
        newButton.setAttribute("aria-expanded", String(!isExpanded));
      });
    });
  }

  // Run on initial load
  setupAccordion();

  // Run on every View Transition navigation
  document.addEventListener("astro:page-load", setupAccordion);
</script>
