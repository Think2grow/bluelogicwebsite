---
import Layout from "../layouts/Layout.astro";
import { getFAQSchema, getBreadcrumbSchema } from "../utils/schema";

const faqs = [
  {
    question:
      "How is the Blue Logic Whole-Home Purification System different from a regular filter or softener?",
    answer:
      "Most systems filter some contaminants - but Blue Logic purifies at the molecular level. Our Whole-Home Purification System combines advanced pretreatment with reverse osmosis technology to deliver 99.8% pure water to every tap, not just one faucet.",
  },
  {
    question: "What does the Whole-Home Filtration System actually remove?",
    answer:
      "Our 7-layer filtration media targets chlorine, chloramines, PFAS, pesticides, pharmaceuticals, heavy metals, and hard water minerals. It’s a full-spectrum reduction system - designed to make your home’s water cleaner, healthier, and better-tasting.",
  },
  {
    question: "Will this replace my water softener?",
    answer:
      "Yes. Blue Logic Filtration softens and conditions water naturally without the slick, slimy feel or added salt from traditional softeners. You’ll still get that clean, soft-water experience - but without the maintenance headaches.",
  },
  {
    question: "What kind of maintenance is required?",
    answer:
      "Very little. Both our filtration and purification systems are designed for high efficiency and long service life. Typically, media and filters are serviced once per year during your annual check-up - that’s it.",
  },
  {
    question: "How much does a Blue Logic RO system cost?",
    answer:
      "Our professional whole-home reverse osmosis systems are $15,000 installed. This is roughly half the cost of competitors while using the same commercial-grade components. No hidden fees, no upsells—just transparent, fair pricing.",
  },
  {
    question: "How long does installation take?",
    answer:
      "Most installations are completed in one day (4-8 hours depending on your home's layout). Our team works efficiently while maintaining meticulous attention to detail. We'll provide a specific timeline during your consultation.",
  },
  {
    question: "How much water is wasted during the RO process?",
    answer:
      "Modern RO systems are far more efficient than older models. Our systems waste approximately 3-4 gallons for every gallon of purified water produced. While this may seem like a lot, it's significantly better than older systems (which could waste 8-10 gallons per gallon) and ensures optimal purification.",
  },
  {
    question: "Will this remove the minerals from my water?",
    answer:
      "Yes, reverse osmosis removes 99%+ of all dissolved solids, including minerals. However, our systems include a remineralization stage that adds back beneficial minerals for taste and health. You get pure water with the minerals you want, none of the contaminants you don't.",
  },
  {
    question: "Do you serve my area?",
    answer:
      "We serve the entire Wasatch Front including Salt Lake City, Park City, Draper, Sandy, Cottonwood Heights, Holladay, Murray, Millcreek, and surrounding areas. Contact us to confirm service availability for your specific location.",
  },
  {
    question: "What contaminants does RO remove?",
    answer:
      "Reverse osmosis removes 99%+ of total dissolved solids (TDS) including heavy metals (lead, arsenic, mercury), chlorine, fluoride, PFAS (forever chemicals), pesticides, bacteria, and viruses. It's the most comprehensive water purification available for residential use.",
  },
  {
    question: "Why is your system quieter than others?",
    answer:
      "We use advanced sound-dampening technology and premium components designed for quiet operation. While traditional systems can be quite noisy during cycling, our system operates at approximately 1/10th the noise level—quiet enough that you'll barely notice it's running.",
  },
  {
    question: "What's included in the $15,000 price?",
    answer:
      "Everything: the complete RO system, professional installation, all necessary plumbing connections, initial water quality testing, system startup and calibration, and comprehensive warranty. No hidden costs or surprise fees.",
  },
  {
    question: "How does Utah's hard water affect RO systems?",
    answer:
      "Utah has some of the hardest water in the country with high TDS levels (300-500+ ppm in many areas). This is actually where RO systems shine—they're specifically designed to handle hard water and reduce TDS to near-zero levels. The high mineral content in Utah water makes RO the most effective purification method available.",
  },
  {
    question: "What warranty do you offer?",
    answer:
      "We provide a comprehensive warranty covering parts and labor. Specific terms vary by component, but we stand behind our installations. As a local company, we're here for ongoing support—not just for the sale.",
  },
  {
    question: "Can I install this myself to save money?",
    answer:
      "While technically possible, we strongly recommend professional installation. RO systems require precise plumbing connections, pressure adjustments, and proper drainage setup. Improper installation can lead to leaks, poor performance, or system damage. Our installation is included in the price and ensures everything works perfectly from day one.",
  },
];

// Generate FAQ page-specific schema
const siteUrl = Astro.site?.toString() || "https://bluelogicwater.com";

const schemas = [
  getFAQSchema(faqs),
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "FAQ", url: "/common-questions" },
  ]),
];
---

<Layout
  title="FAQ - Blue Logic Water Common Questions"
  description="Common questions about reverse osmosis systems, installation, cost, maintenance, and water quality in Salt Lake City."
  schema={schemas}
>
  <section class="hero">
    <div class="container">
      <h1>Common Questions</h1>
      <p class="subtitle">
        Everything you need to know about Blue Logic Water systems
      </p>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <div class="faq-intro">
        <p>
          Have a question not answered here? <a href="/#contact">Contact us</a> and
          we'll be happy to help.
        </p>
      </div>

      <div class="faq-list">
        {
          faqs.map((faq, index) => (
            <div class="faq-item">
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls={`answer-${index}`}
              >
                <span>{faq.question}</span>
                <span class="faq-icon">+</span>
              </button>
              <div class="faq-answer" id={`answer-${index}`}>
                <p>{faq.answer}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container center">
      <h2>Still Have Questions?</h2>
      <p>Schedule a free consultation with our team</p>
      <a href="/#contact" class="cta-button">Get in Touch</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: linear-gradient(
      135deg,
      oklch(0.95 0.01 90) 0%,
      oklch(0.85 0.05 220) 100%
    );
    padding: 6rem 2rem 4rem;
    text-align: center;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .container.center {
    text-align: center;
  }

  h1 {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    font-family: "Instrument Serif", Georgia, serif;
  }

  .subtitle {
    font-size: 1.5rem;
    color: oklch(0.4 0.02 270);
  }

  h2 {
    font-size: 2.5rem;
    margin-bottom: 2rem;
  }

  .faq-section {
    background-color: white;
  }

  .faq-intro {
    text-align: center;
    margin-bottom: 3rem;
  }

  .faq-intro p {
    font-size: 1.125rem;
    color: oklch(0.4 0.02 270);
  }

  .faq-intro a {
    color: oklch(0.7 0.1 220);
    font-weight: 600;
  }

  .faq-list {
    max-width: 900px;
    margin: 0 auto;
  }

  .faq-item {
    border-bottom: 1px solid oklch(0.9 0.01 90);
  }

  .faq-question {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-size: 1.25rem;
    font-weight: 600;
    color: oklch(0.2 0.02 270);
    transition: color 0.2s;
  }

  .faq-question:hover {
    color: oklch(0.7 0.1 220);
  }

  .faq-icon {
    font-size: 1.5rem;
    color: oklch(0.7 0.1 220);
    font-weight: 300;
    transition: transform 0.3s;
    flex-shrink: 0;
    margin-left: 1rem;
  }

  .faq-question[aria-expanded="true"] .faq-icon {
    transform: rotate(45deg);
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out;
  }

  .faq-answer.open {
    max-height: 500px;
    transition: max-height 0.5s ease-in;
  }

  .faq-answer p {
    padding-bottom: 1.5rem;
    color: oklch(0.4 0.02 270);
    line-height: 1.7;
    font-size: 1.0625rem;
  }

  .cta-section {
    background-color: oklch(0.98 0.01 90);
  }

  .cta-section h2 {
    margin-bottom: 1rem;
  }

  .cta-section p {
    font-size: 1.25rem;
    color: oklch(0.4 0.02 270);
    margin-bottom: 2rem;
  }

  .cta-button {
    display: inline-block;
    background-color: oklch(0.7 0.1 220);
    color: white;
    padding: 1rem 2.5rem;
    text-decoration: none;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 1.125rem;
    transition: opacity 0.2s;
  }

  .cta-button:hover {
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2.5rem;
    }

    .hero {
      padding: 4rem 1rem 3rem;
    }

    .faq-question {
      font-size: 1.125rem;
    }
  }
</style>

<script>
  // FAQ accordion functionality
  document.addEventListener("DOMContentLoaded", () => {
    const faqButtons = document.querySelectorAll(".faq-question");

    faqButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const isExpanded = button.getAttribute("aria-expanded") === "true";
        const answerId = button.getAttribute("aria-controls");
        const answer = document.getElementById(answerId!);

        // Close all other answers
        faqButtons.forEach((otherButton) => {
          if (otherButton !== button) {
            otherButton.setAttribute("aria-expanded", "false");
            const otherAnswerId = otherButton.getAttribute("aria-controls");
            const otherAnswer = document.getElementById(otherAnswerId!);
            otherAnswer?.classList.remove("open");
          }
        });

        // Toggle current answer
        button.setAttribute("aria-expanded", String(!isExpanded));
        answer?.classList.toggle("open");
      });
    });
  });
</script>
