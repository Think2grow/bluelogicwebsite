---
import Layout from "../layouts/Layout.astro";
import { getProductSchema, getBreadcrumbSchema } from "../utils/schema";
import FilterFlowParallax from "../components/FilterFlowParallax.astro";
import { Image } from "astro:assets";
import dirtyCleanGlassesImg from "../assets/water_art/AdobeStock_259519171_dirty_water_clean_water_glasses.jpeg";
import filtersInHandsImg from "../assets/water_art/AdobeStock_479744195_filters_in_tech_hands.jpeg";
import BrochureDownload from "../components/BrochureDownload.astro";

export const prerender = true;

// Generate product page-specific schema
const siteUrl = Astro.site?.toString() || "https://bluelogicwater.com";

const schemas = [
  getProductSchema(`${siteUrl}/the-system`),
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "The System", url: "/the-system" },
  ]),
];
---

<Layout
  title="The System - Blue Logic Water"
  description="Advanced reverse osmosis technology. Half the footprint, 10x quieter, professional-grade water purification."
  schema={schemas}
>
  <section class="hero-gradient py-20 md:py-24 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-6xl font-serif mb-4 text-foreground">
        The Blue Logic System
      </h1>
      <p class="text-xl md:text-2xl text-muted-foreground">
        Professional-grade water purification, engineered for your home
      </p>
    </div>
  </section>

  <!-- Visual Impact: Before/After -->
  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <Image
            src={dirtyCleanGlassesImg}
            alt="Comparison of contaminated water versus pure filtered water in glasses"
            class="rounded-2xl shadow-2xl w-full object-cover aspect-4/3"
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 100vw, 50vw"
            quality={50}
          />
        </div>
        <div>
          <h2 class="text-3xl md:text-4xl font-serif mb-6 text-foreground">
            See the Difference
          </h2>
          <p class="text-lg text-muted-foreground leading-relaxed mb-6">
            <a
              href="/the-value"
              class="text-primary hover:underline font-semibold"
              >Utah's water carries invisible contaminants</a
            >—heavy metals, PFAS, chlorine byproducts, and dissolved solids that
            affect taste, health, and your home's infrastructure.
          </p>
          <p class="text-lg text-muted-foreground leading-relaxed">
            Our systems transform municipal water into crystal-clear,
            great-tasting water that's purer than bottled—at every tap in your
            home.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-3xl md:text-4xl font-serif text-center mb-6 text-foreground"
      >
        Three Approaches to Water Treatment
      </h2>
      <p
        class="text-lg text-center text-muted-foreground max-w-3xl mx-auto mb-12"
      >
        Not all water treatment is created equal. Here's how softeners,
        filtration, and purification stack up.
      </p>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="approach-card approach-basic">
          <div class="mb-4">
            <h3 class="text-2xl font-semibold mb-2 text-foreground">
              Water Softener
            </h3>
            <p
              class="text-sm font-bold uppercase tracking-wider text-muted-foreground"
            >
              ≈30% Solution
            </p>
          </div>
          <p class="text-lg font-semibold mb-4 text-foreground/80">
            The Illusion of Clean Water
          </p>
          <p class="text-muted-foreground leading-relaxed mb-6">
            Softeners remove calcium and magnesium to prevent scale buildup and
            extend appliance life. They make water feel better—but don't improve
            safety or purity.
          </p>
          <div class="mb-6">
            <h4
              class="text-sm font-bold uppercase tracking-wider mb-3 text-foreground/80"
            >
              What it does:
            </h4>
            <ul class="space-y-2">
              <li class="approach-list-item">
                Prevents mineral scale in pipes and appliances
              </li>
              <li class="approach-list-item">
                Makes soap and detergents more effective
              </li>
              <li class="approach-list-item">
                Reduces water spots on dishes and fixtures
              </li>
            </ul>
          </div>
          <div
            class="pt-4 border-t border-border text-sm text-muted-foreground"
          >
            <strong class="text-foreground">Verdict:</strong> Does not remove chemicals,
            toxins, or contaminants. Does not improve taste, odor, or drinking safety.
          </div>
        </div>

        <div class="approach-card approach-better">
          <div class="mb-4">
            <h3 class="text-2xl font-semibold mb-2 text-foreground">
              Whole-Home Filtration
            </h3>
            <p class="text-sm font-bold uppercase tracking-wider text-primary">
              ≈85% Solution
            </p>
          </div>
          <p class="text-lg font-semibold mb-4 text-foreground/80">
            Real Protection for Your Home
          </p>
          <p class="text-muted-foreground leading-relaxed mb-6">
            Blue Logic's proprietary 7-layer media system targets the full
            spectrum of contaminants—from chlorine and PFAS to heavy metals and
            hardness minerals.
          </p>
          <div class="mb-6">
            <h4
              class="text-sm font-bold uppercase tracking-wider mb-3 text-foreground/80"
            >
              What it does:
            </h4>
            <ul class="space-y-2">
              <li class="approach-list-item">
                Full-spectrum contaminant reduction
              </li>
              <li class="approach-list-item">
                Softened water using 75% less salt than standard softeners
              </li>
              <li class="approach-list-item">
                Cleaner, fresher taste at every tap
              </li>
              <li class="approach-list-item">
                Low maintenance and long lifespan
              </li>
            </ul>
          </div>
          <div
            class="pt-4 border-t border-border text-sm text-muted-foreground"
          >
            <strong class="text-foreground">Verdict:</strong> The best whole-home
            filtration on the market—smart, balanced, and built to last.
          </div>
        </div>

        <div class="approach-card approach-best">
          <div class="mb-4">
            <h3 class="text-2xl font-semibold mb-2 text-foreground">
              Whole-Home Purification
            </h3>
            <p class="text-sm font-bold uppercase tracking-wider text-success">
              ≈99% Solution
            </p>
          </div>
          <p class="text-lg font-semibold mb-4 text-foreground/80">
            The Ultimate in Clean Water
          </p>
          <p class="text-muted-foreground leading-relaxed mb-6">
            Our reverse osmosis system removes contaminants at the molecular
            level—delivering better-than-bottled water quality from every tap in
            your home.
          </p>
          <div class="mb-6">
            <h4
              class="text-sm font-bold uppercase tracking-wider mb-3 text-foreground/80"
            >
              What it does:
            </h4>
            <ul class="space-y-2">
              <li class="approach-list-item">
                Removes up to 99% of contaminants
              </li>
              <li class="approach-list-item">
                Eliminates PFAS, arsenic, pharmaceuticals, microplastics
              </li>
              <li class="approach-list-item">
                Pure water for every sink, shower, and appliance
              </li>
              <li class="approach-list-item">
                Engineered for reliability and simplicity
              </li>
            </ul>
          </div>
          <div
            class="pt-4 border-t border-border text-sm text-muted-foreground"
          >
            <strong class="text-foreground">Verdict:</strong> The only true purification
            solution—better than bottled water at every tap.
          </div>
        </div>
      </div>

      <div
        class="max-w-4xl mx-auto mt-16 bg-primary/5 border-2 border-primary rounded-2xl p-8 md:p-12"
      >
        <h3
          class="text-2xl md:text-3xl font-serif mb-6 text-center text-foreground"
        >
          Two Complete Systems, One Expert Team
        </h3>
        <p class="text-lg text-muted-foreground mb-6 leading-relaxed">
          Blue Logic offers two comprehensive whole-home water solutions
          tailored to your needs and budget:
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
          <div class="bg-card p-6 rounded-xl">
            <h4 class="text-xl font-semibold mb-3 text-primary">
              Whole-Home Filtration
            </h4>
            <p class="text-muted-foreground mb-4">
              Our standalone 7-layer filtration system with integrated water
              softening. Perfect for comprehensive contaminant reduction and
              softened water throughout your home.
            </p>
            <p class="text-sm font-semibold text-foreground">
              Includes: Water Softener + 7-Layer Media Filtration
            </p>
          </div>
          <div class="bg-card p-6 rounded-xl border-2 border-primary">
            <h4 class="text-xl font-semibold mb-3 text-primary">
              Whole-Home Purification
            </h4>
            <p class="text-muted-foreground mb-4">
              Everything from our filtration system PLUS reverse osmosis
              purification and storage for the ultimate in water purity at every
              tap.
            </p>
            <p class="text-sm font-semibold text-foreground">
              Includes: Filtration System + Commercial RO Unit + 165-Gallon Tank
              + Delivery Pump
            </p>
          </div>
        </div>
        <p class="text-center text-muted-foreground italic">
          Our purification system builds on our proven filtration foundation—the
          softener and filters protect the RO membranes and extend system life.
        </p>
      </div>
    </div>
  </section>

  <!-- Interactive Filter Flow Visualization -->
  <FilterFlowParallax />

  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-3xl md:text-4xl font-serif text-center mb-6 text-foreground"
      >
        Whole-Home Purification
      </h2>
      <p
        class="text-lg text-center text-muted-foreground max-w-3xl mx-auto mb-12"
      >
        Our reverse osmosis system isn't just smaller and quieter—it's
        fundamentally better engineered. Removes up to 99% of contaminants to
        deliver pure water at every tap in your home.
      </p>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-12">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="p-8 bg-card rounded-2xl">
            <h3 class="text-xl font-semibold mb-4 text-primary">
              Molecular-Level Purification
            </h3>
            <p class="font-semibold mb-2 text-foreground">
              Removes up to 99% of contaminants
            </p>
            <p class="text-muted-foreground leading-relaxed">
              Removes dissolved solids, heavy metals, PFAS, pharmaceuticals, and
              microplastics at the molecular level.
            </p>
          </div>

          <div class="p-8 bg-card rounded-2xl">
            <h3 class="text-xl font-semibold mb-4 text-primary">
              Compact Design
            </h3>
            <p class="font-semibold mb-2 text-foreground">
              50% smaller than traditional RO systems
            </p>
            <p class="text-muted-foreground leading-relaxed">
              Fits seamlessly in modern utility spaces without the massive
              footprint of competitor systems.
            </p>
          </div>

          <div class="p-8 bg-card rounded-2xl">
            <h3 class="text-xl font-semibold mb-4 text-primary">
              Silent Operation
            </h3>
            <p class="font-semibold mb-2 text-foreground">
              10x quieter than standard units
            </p>
            <p class="text-muted-foreground leading-relaxed">
              Advanced sound-dampening technology means you'll forget it's even
              running.
            </p>
          </div>

          <div class="p-8 bg-card rounded-2xl">
            <h3 class="text-xl font-semibold mb-4 text-primary">
              Premium Build Quality
            </h3>
            <p class="font-semibold mb-2 text-foreground">
              Commercial-grade components
            </p>
            <p class="text-muted-foreground leading-relaxed">
              Engineered for long-term reliability with NSF-certified materials
              throughout.
            </p>
          </div>
        </div>
        <div>
          <Image
            src={filtersInHandsImg}
            alt="Professional technician carefully handling precision water filtration components"
            class="rounded-2xl shadow-2xl w-full object-cover aspect-3/4"
            widths={[400, 600]}
            sizes="(max-width: 768px) 100vw, 50vw"
            quality={50}
          />
          <p class="text-sm text-muted-foreground text-center mt-4 italic">
            Precision engineering in every component
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-3xl md:text-4xl font-serif text-center mb-6 text-foreground"
      >
        7-Layer Whole-Home Filtration
      </h2>
      <p
        class="text-lg text-center text-muted-foreground max-w-3xl mx-auto mb-12"
      >
        For those seeking advanced filtration without full purification, our
        proprietary 7-layer system delivers exceptional protection and softened
        water throughout your home.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="filtration-card">
          <h3 class="text-xl font-semibold mb-4 text-foreground">
            🧪 Advanced Multi-Media Technology
          </h3>
          <p class="text-muted-foreground leading-relaxed mb-4">
            Seven distinct filtration layers work in concert to target
            everything from heavy metals and chlorine to microplastics and
            hardness minerals.
          </p>
          <ul class="space-y-3">
            <li class="text-muted-foreground text-sm leading-relaxed">
              <strong class="text-foreground">Zinc-Infused Carbon</strong> — Reduces
              bacteria and removes chlorine
            </li>
            <li class="text-muted-foreground text-sm leading-relaxed">
              <strong class="text-foreground">Copper-Infused Carbon</strong> — Additional
              antimicrobial protection
            </li>
            <li class="text-muted-foreground text-sm leading-relaxed">
              <strong class="text-foreground">Catalytic Carbon</strong> — Eliminates
              chloramines and organic compounds
            </li>
            <li class="text-muted-foreground text-sm leading-relaxed">
              <strong class="text-foreground">EvoResin</strong> — Targets hardness
              minerals efficiently
            </li>
            <li class="text-muted-foreground text-sm leading-relaxed">
              <strong class="text-foreground">Katalox</strong> — Removes iron, manganese,
              and hydrogen sulfide
            </li>
            <li class="text-muted-foreground text-sm leading-relaxed">
              <strong class="text-foreground">Aluminosilicate</strong> — Polishes
              water clarity
            </li>
            <li class="text-muted-foreground text-sm leading-relaxed">
              <strong class="text-foreground">Garnet</strong> — Final sediment filtration
            </li>
          </ul>
        </div>

        <div class="filtration-card">
          <h3 class="text-xl font-semibold mb-4 text-foreground">
            💧 Softened Without the Slick
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Enjoy water that feels smooth and fresh without the slippery residue
            of traditional salt-based softeners. Uses 75% less salt while
            delivering superior results.
          </p>
        </div>

        <div class="filtration-card">
          <h3 class="text-xl font-semibold mb-4 text-foreground">
            🏡 Whole-Home Coverage
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Clean, healthy water flows to every tap, shower, and appliance.
            Protects your investment and your family simultaneously.
          </p>
        </div>

        <div class="filtration-card">
          <h3 class="text-xl font-semibold mb-4 text-foreground">
            ⚙️ Built to Last
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Designed for high-flow homes with minimal maintenance requirements.
            Engineered for longevity, not planned obsolescence.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-3xl md:text-4xl font-serif text-center mb-6 text-foreground"
      >
        How Whole-Home Purification Works
      </h2>
      <p
        class="text-lg text-center text-muted-foreground max-w-3xl mx-auto mb-8"
      >
        Our purification system combines filtration and reverse osmosis in four
        integrated stages. Stages 1-2 (the filtration system) can operate
        standalone, or pair with stages 3-4 for complete purification.
      </p>
      <div
        class="text-center mb-12 bg-accent/50 py-4 px-6 rounded-xl max-w-2xl mx-auto"
      >
        <p class="text-foreground font-semibold">
          💡 The filtration pretreatment isn't optional—it protects the RO
          membranes and ensures optimal purification performance.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="step-card">
          <div class="step-number">1</div>
          <h3 class="text-lg font-semibold mb-3 text-foreground">
            Softening + Pretreatment
          </h3>
          <p class="text-sm text-muted-foreground mb-2">
            <span
              class="inline-block bg-primary/10 text-primary text-xs font-bold px-2 py-1 rounded mb-2"
              >FILTRATION SYSTEM</span
            >
          </p>
          <p class="text-sm text-muted-foreground mb-4">
            Water softener and multi-layer filtration prepare water for
            purification or serve as standalone filtration
          </p>
          <ul class="space-y-2 text-left">
            <li class="text-sm text-muted-foreground">
              <strong class="text-foreground">Sediment Filter</strong> — Removes particles
              and debris
            </li>
            <li class="text-sm text-muted-foreground">
              <strong class="text-foreground">Carbon Block Filter</strong> — Eliminates
              chlorine and organics
            </li>
            <li class="text-sm text-muted-foreground">
              <strong class="text-foreground">Phosphate Additive</strong> — Protects
              the RO membrane from scale buildup
            </li>
          </ul>
        </div>

        <div class="step-card">
          <div class="step-number">2</div>
          <h3 class="text-lg font-semibold mb-3 text-foreground">
            Reverse Osmosis Unit
          </h3>
          <p class="text-sm text-muted-foreground mb-2">
            <span
              class="inline-block bg-success/10 text-success text-xs font-bold px-2 py-1 rounded mb-2"
              >PURIFICATION UPGRADE</span
            >
          </p>
          <p class="text-sm text-muted-foreground mb-4">
            Commercial-grade RO removes contaminants at molecular level
          </p>
          <ul class="space-y-2 text-left">
            <li class="text-sm text-muted-foreground">
              0.0001 micron membrane filtration
            </li>
            <li class="text-sm text-muted-foreground">
              Removes up to 99% of contaminants including heavy metals, PFAS,
              and dissolved solids
            </li>
            <li class="text-sm text-muted-foreground">
              Designed for continuous whole-home capacity
            </li>
          </ul>
        </div>

        <div class="step-card">
          <div class="step-number">3</div>
          <h3 class="text-lg font-semibold mb-3 text-foreground">
            165-Gallon Holding Tank
          </h3>
          <p class="text-sm text-muted-foreground mb-2">
            <span
              class="inline-block bg-success/10 text-success text-xs font-bold px-2 py-1 rounded mb-2"
              >PURIFICATION UPGRADE</span
            >
          </p>
          <p class="text-sm text-muted-foreground mb-4">
            High-capacity storage maintains consistent flow throughout your home
          </p>
          <ul class="space-y-2 text-left">
            <li class="text-sm text-muted-foreground">
              Ensures purified water is always ready on demand
            </li>
            <li class="text-sm text-muted-foreground">
              Prevents pressure drops during peak usage
            </li>
            <li class="text-sm text-muted-foreground">
              NSF-certified food-grade materials
            </li>
          </ul>
        </div>

        <div class="step-card">
          <div class="step-number">4</div>
          <h3 class="text-lg font-semibold mb-3 text-foreground">
            Delivery Pump
          </h3>
          <p class="text-sm text-muted-foreground mb-2">
            <span
              class="inline-block bg-success/10 text-success text-xs font-bold px-2 py-1 rounded mb-2"
              >PURIFICATION UPGRADE</span
            >
          </p>
          <p class="text-sm text-muted-foreground mb-4">
            Restores—and often improves—your home's water pressure
          </p>
          <ul class="space-y-2 text-left">
            <li class="text-sm text-muted-foreground">
              Maintains optimal pressure to every fixture
            </li>
            <li class="text-sm text-muted-foreground">
              Quiet, efficient operation
            </li>
            <li class="text-sm text-muted-foreground">
              Automatic pressure regulation
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif mb-4 text-foreground">
        Ready to Experience the Difference?
      </h2>
      <p class="text-xl text-muted-foreground mb-6">
        Schedule a free water quality assessment
      </p>
      <a href="/#contact" class="btn btn-primary btn-lg">Get Started</a>
      <BrochureDownload />
      <p class="text-muted-foreground mt-8">
        Want to understand the cost benefits? See <a
          href="/the-value"
          class="text-primary hover:underline font-semibold"
          >why our systems cost half the industry standard</a
        >.
      </p>
    </div>
  </section>
</Layout>

<style>
  @reference "../styles/global.css";
  .approach-card {
    @apply bg-card p-8 rounded-2xl border-t-4 border-primary;
  }

  .approach-basic {
    @apply border-t-error;
  }

  .approach-better {
    @apply border-t-primary;
  }

  .approach-best {
    @apply border-t-success bg-linear-to-br from-card to-accent;
  }

  .approach-list-item {
    @apply pl-6 relative text-muted-foreground text-sm leading-relaxed;
  }

  .approach-list-item::before {
    content: "✓";
    @apply absolute left-0 text-primary font-bold;
  }

  .filtration-card {
    @apply bg-card p-8 rounded-2xl border-l-4 border-primary;
  }

  .step-card {
    @apply text-center p-8 bg-background rounded-2xl;
  }

  .step-number {
    @apply w-14 h-14 bg-primary text-primary-foreground rounded-full flex items-center justify-center text-xl font-bold mx-auto mb-4;
  }
</style>
