---
import Layout from "../layouts/Layout.astro";
import { getProductSchema, getBreadcrumbSchema } from "../utils/schema";

// Generate product page-specific schema
const siteUrl = Astro.site?.toString() || "https://bluelogicwater.com";

const schemas = [
  getProductSchema(`${siteUrl}/the-system`),
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "The System", url: "/the-system" },
  ]),
];
---

<Layout
  title="The System - Blue Logic Water"
  description="Advanced reverse osmosis technology. Half the footprint, 10x quieter, professional-grade water purification."
  schema={schemas}
>
  <section class="hero">
    <div class="container">
      <h1>The Blue Logic System</h1>
      <p class="subtitle">
        Professional-grade water purification, engineered for your home
      </p>
    </div>
  </section>

  <section class="specs">
    <div class="container">
      <h2>Engineering Excellence</h2>
      <p class="intro">
        Our reverse osmosis system isn't just smaller and quieter—it's
        fundamentally better engineered. We've eliminated the bulk and noise of
        traditional systems without sacrificing performance.
      </p>

      <div class="spec-grid">
        <div class="spec-card">
          <h3>Compact Design</h3>
          <p><strong>50% smaller</strong> than traditional RO systems</p>
          <p>
            Fits seamlessly in modern utility spaces without the massive tank
            and equipment footprint of competitor systems.
          </p>
        </div>

        <div class="spec-card">
          <h3>Silent Operation</h3>
          <p><strong>10x quieter</strong> than standard units</p>
          <p>
            Advanced sound-dampening technology means you'll forget it's even
            running. No more disruptive cycling noise.
          </p>
        </div>

        <div class="spec-card">
          <h3>High Flow Rate</h3>
          <p><strong>Premium filtration</strong> at practical speeds</p>
          <p>
            Fast enough for whole-home use without compromising on water quality
            or purity standards.
          </p>
        </div>

        <div class="spec-card">
          <h3>Multi-Stage Filtration</h3>
          <p><strong>5-stage purification</strong> process</p>
          <p>
            Removes sediment, chlorine, heavy metals, PFAS, and 99%+ of total
            dissolved solids.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="technology">
    <div class="container">
      <h2>How It Works</h2>
      <div class="process-steps">
        <div class="step">
          <div class="step-number">1</div>
          <h3>Pre-Filtration</h3>
          <p>Sediment and carbon filters remove large particles and chlorine</p>
        </div>

        <div class="step">
          <div class="step-number">2</div>
          <h3>Reverse Osmosis</h3>
          <p>Semi-permeable membrane removes 99%+ of contaminants</p>
        </div>

        <div class="step">
          <div class="step-number">3</div>
          <h3>Post-Filtration</h3>
          <p>Final carbon polish ensures perfect taste and clarity</p>
        </div>

        <div class="step">
          <div class="step-number">4</div>
          <h3>Remineralization</h3>
          <p>Adds beneficial minerals back for health and taste</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container center">
      <h2>Ready to Experience the Difference?</h2>
      <p>Schedule a free water quality assessment</p>
      <a href="/#contact" class="cta-button">Get Started</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: linear-gradient(
      135deg,
      oklch(0.95 0.01 90) 0%,
      oklch(0.85 0.05 220) 100%
    );
    padding: 6rem 2rem 4rem;
    text-align: center;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .container.center {
    text-align: center;
  }

  h1 {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    font-family: "Instrument Serif", Georgia, serif;
  }

  .subtitle {
    font-size: 1.5rem;
    color: oklch(0.4 0.02 270);
  }

  h2 {
    font-size: 2.5rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .intro {
    font-size: 1.25rem;
    line-height: 1.8;
    max-width: 800px;
    margin: 0 auto 3rem;
    text-align: center;
    color: oklch(0.4 0.02 270);
  }

  .spec-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .spec-card {
    background-color: oklch(0.98 0.01 90);
    padding: 2rem;
    border-radius: 1rem;
  }

  .spec-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: oklch(0.7 0.1 220);
  }

  .spec-card p {
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }

  .spec-card strong {
    color: oklch(0.2 0.02 270);
  }

  .technology {
    background-color: oklch(0.98 0.01 90);
  }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .step {
    text-align: center;
    padding: 2rem;
    background-color: white;
    border-radius: 1rem;
  }

  .step-number {
    width: 60px;
    height: 60px;
    background-color: oklch(0.7 0.1 220);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 auto 1rem;
  }

  .step h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .step p {
    color: oklch(0.4 0.02 270);
  }

  .cta-section {
    background-color: white;
  }

  .cta-section h2 {
    margin-bottom: 1rem;
  }

  .cta-section p {
    font-size: 1.25rem;
    color: oklch(0.4 0.02 270);
    margin-bottom: 2rem;
  }

  .cta-button {
    display: inline-block;
    background-color: oklch(0.7 0.1 220);
    color: white;
    padding: 1rem 2.5rem;
    text-decoration: none;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 1.125rem;
    transition: opacity 0.2s;
  }

  .cta-button:hover {
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2.5rem;
    }

    .hero {
      padding: 4rem 1rem 3rem;
    }

    .spec-grid,
    .process-steps {
      grid-template-columns: 1fr;
    }
  }
</style>
