---
import Layout from "../layouts/Layout.astro";
import { getBreadcrumbSchema } from "../utils/schema";
import ReviewCarousel from "../components/ReviewCarousel.tsx";

export const prerender = true;

const siteUrl = "https://www.bluelogicwater.com";
const schemas = [
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Pure Water for Your Family", url: "/vsl/" },
  ]),
];
---

<Layout
  title="Transform Your Home's Water Quality | Blue Logic Water"
  description="Discover how our whole home reverse osmosis system can give your family the cleanest, healthiest water from every tap in your home."
  schema={schemas}
>
  <!-- VSL Hero Section with Video -->
  <section class="relative w-full min-h-screen bg-obsidian flex flex-col items-center justify-center px-4 py-20">
    <div class="max-w-5xl w-full mx-auto">
      <!-- Pre-Video Headline -->
      <div class="text-center mb-8">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif text-white mb-4">
          What If Every Tap in Your Home<br />Delivered Pure, Healthy Water?
        </h1>
        <p class="text-xl md:text-2xl text-quartz/80 max-w-3xl mx-auto">
          Watch this short video to discover how Blue Logic's whole home reverse osmosis system transforms your family's health and lifestyle.
        </p>
      </div>

      <!-- YouTube Video Embed -->
      <div class="relative w-full aspect-video rounded-2xl overflow-hidden shadow-2xl border-4 border-primary/20">
        <iframe
          width="100%"
          height="100%"
          src="https://www.youtube.com/embed/U6t_ZmBujMU?rel=0&modestbranding=1"
          title="Blue Logic Water System Video"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          class="absolute inset-0 w-full h-full border-0"
        ></iframe>
      </div>

      <!-- Post-Video CTA -->
      <div class="text-center mt-8">
        <a
          href="#contact"
          class="inline-block bg-primary text-white px-10 py-5 rounded-full text-xl font-semibold hover:bg-primary/90 transition-all duration-300 transform hover:scale-105 shadow-lg"
        >
          Get Your Free Water Quality Assessment →
        </a>
        <p class="text-quartz/60 mt-4 text-sm">
          No obligation • Free consultation • Limited availability
        </p>
      </div>
    </div>
  </section>

  <!-- Key Benefits Section -->
  <section class="bg-background py-16 md:py-24 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif text-center mb-12 text-foreground">
        Transform Every Drop of Water in Your Home
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Benefit 1 -->
        <div class="bg-card p-8 rounded-2xl border-l-4 border-primary">
          <div class="text-4xl mb-4">💧</div>
          <h3 class="text-xl font-semibold mb-3 text-foreground">
            Pure Water, Every Tap
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Drink, cook, shower, and clean with water that's 99.9% contaminant-free throughout your entire home.
          </p>
        </div>

        <!-- Benefit 2 -->
        <div class="bg-card p-8 rounded-2xl border-l-4 border-primary">
          <div class="text-4xl mb-4">🏡</div>
          <h3 class="text-xl font-semibold mb-3 text-foreground">
            Protect Your Investment
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Extend the life of appliances, prevent scale buildup, and maintain your home's plumbing systems.
          </p>
        </div>

        <!-- Benefit 3 -->
        <div class="bg-card p-8 rounded-2xl border-l-4 border-primary">
          <div class="text-4xl mb-4">👨‍👩‍👧‍👦</div>
          <h3 class="text-xl font-semibold mb-3 text-foreground">
            Family Health First
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Remove chlorine, heavy metals, PFAS, and hundreds of other contaminants that affect your family's health.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Google Reviews Carousel -->
  <section class="bg-card py-16 md:py-24 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif text-center mb-4 text-foreground">
        Trusted by Families Across the Wasatch Front
      </h2>
      <p class="text-center text-muted-foreground mb-12 text-lg">
        See what our customers are saying on Google
      </p>

      <ReviewCarousel client:load />
    </div>
  </section>

  <!-- Trust Signals Section -->
  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-serif mb-12 text-foreground">
        Why Choose Blue Logic Water?
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
        <div class="flex items-start">
          <div class="text-primary text-2xl mr-4 shrink-0">✓</div>
          <div>
            <h3 class="font-semibold text-lg mb-2 text-foreground">Local Utah Company</h3>
            <p class="text-muted-foreground">Family-owned business serving the Wasatch Front since 2015</p>
          </div>
        </div>

        <div class="flex items-start">
          <div class="text-primary text-2xl mr-4 shrink-0">✓</div>
          <div>
            <h3 class="font-semibold text-lg mb-2 text-foreground">Premium Quality Systems</h3>
            <p class="text-muted-foreground">Top-tier RO systems engineered for durability and performance</p>
          </div>
        </div>

        <div class="flex items-start">
          <div class="text-primary text-2xl mr-4 shrink-0">✓</div>
          <div>
            <h3 class="font-semibold text-lg mb-2 text-foreground">Lifetime Support</h3>
            <p class="text-muted-foreground">Ongoing maintenance and customer support included</p>
          </div>
        </div>

        <div class="flex items-start">
          <div class="text-primary text-2xl mr-4 shrink-0">✓</div>
          <div>
            <h3 class="font-semibold text-lg mb-2 text-foreground">Premium Technology</h3>
            <p class="text-muted-foreground">State-of-the-art reverse osmosis and remineralization</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA Section with Urgency -->
  <section class="bg-primary py-16 md:py-24 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl md:text-5xl font-serif text-white mb-6">
        Ready to Transform Your Home's Water?
      </h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Schedule your free water quality assessment today. We'll test your water, show you exactly what's in it, and design a custom solution for your home.
      </p>

      <a
        href="#contact"
        class="inline-block bg-white text-primary px-10 py-5 rounded-full text-xl font-semibold hover:bg-quartz transition-all duration-300 transform hover:scale-105 shadow-xl"
      >
        Schedule Free Assessment →
      </a>

      <p class="text-white/70 mt-6 text-sm">
        📞 Call or text: <a href="tel:+18019802583" class="underline hover:text-white">(801) 980-2583</a>
      </p>

      <div class="mt-12 pt-12 border-t border-white/20">
        <p class="text-white/90 text-lg mb-4">
          ⚡ Limited Time: Free Installation Upgrade
        </p>
        <p class="text-white/70 text-sm">
          Schedule your consultation this month and we'll pay for your installation! (A $1700 value) Don't miss out on this exclusive offer to get the best water system for your home.
        </p>
      </div>
    </div>
  </section>

  <!-- Lead Form Section -->
  <section id="contact" class="bg-obsidian py-16 md:py-24 px-4">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif text-white mb-4">
          Get Your Free Water Quality Assessment
        </h2>
        <p class="text-quartz/80 text-lg">
          Fill out the form below and we'll contact you within 24 hours to schedule your free consultation and water testing.
        </p>
      </div>

      <!-- Lead Form -->
      <form id="leadForm" class="space-y-6 bg-card p-8 rounded-2xl shadow-2xl">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="firstName" class="block text-sm font-medium text-foreground mb-2">
              First Name *
            </label>
            <input
              type="text"
              id="firstName"
              name="firstName"
              required
              class="input-field w-full"
              placeholder="John"
            />
          </div>

          <div>
            <label for="lastName" class="block text-sm font-medium text-foreground mb-2">
              Last Name *
            </label>
            <input
              type="text"
              id="lastName"
              name="lastName"
              required
              class="input-field w-full"
              placeholder="Smith"
            />
          </div>
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-foreground mb-2">
            Email Address *
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="input-field w-full"
            placeholder="john@example.com"
          />
        </div>

        <div>
          <label for="phone" class="block text-sm font-medium text-foreground mb-2">
            Phone Number *
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            required
            class="input-field w-full"
            placeholder="(801) 555-1234"
          />
        </div>

        <div>
          <label for="zipCode" class="block text-sm font-medium text-foreground mb-2">
            Zip Code *
          </label>
          <input
            type="text"
            id="zipCode"
            name="zipCode"
            required
            pattern="[0-9]{5}"
            class="input-field w-full"
            placeholder="84101"
          />
        </div>

        <button
          type="submit"
          class="w-full bg-primary text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-primary/90 transition-all duration-300 transform hover:scale-105"
        >
          Request Free Assessment →
        </button>

        <p class="text-sm text-muted-foreground text-center">
          By submitting this form, you agree to receive communications from Blue Logic Water. We respect your privacy.
        </p>
      </form>

      <!-- Success/Error Messages -->
      <div id="formStatus" class="mt-6 text-center hidden">
        <p id="statusMessage" class="text-lg"></p>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Lead Form Submission Handler
  const form = document.getElementById('leadForm') as HTMLFormElement;
  const formStatus = document.getElementById('formStatus') as HTMLElement;
  const statusMessage = document.getElementById('statusMessage') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const response = await fetch('https://services.leadconnectorhq.com/hooks/Nd8el709gXwDJdVuixdV/webhook-trigger/ea841b49-85b0-436e-b298-541b997461c0', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(data),
      });

      if (response.ok || response.status === 200) {
        // Redirect to thank you page
        window.location.href = '/thank-you';
      } else {
        throw new Error('Form submission failed');
      }
    } catch (error) {
      formStatus.classList.remove('hidden');
      statusMessage.textContent = 'Something went wrong. Please call us at (801) 509-3877.';
      statusMessage.classList.add('text-error');
    }
  });

  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e: Event) {
      e.preventDefault();
      const href = (e.currentTarget as HTMLAnchorElement).getAttribute('href');
      const target = href ? document.querySelector(href) : null;
      if (target) {
        target.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    });
  });
</script>

<style>
  /* Video container responsive styles */
  .aspect-video {
    aspect-ratio: 16 / 9;
  }

  /* Smooth scroll behavior */
  html {
    scroll-behavior: smooth;
  }
</style>
