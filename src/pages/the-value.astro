---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import boyExaminesGlassImg from "../assets/water_art/AdobeStock_549367021_boy_examines_glass.jpeg";
import fancyShowerImg from "../assets/water_art/AdobeStock_1404179907_fancy_shower.jpeg";
---

<Layout
  title="Why Blue Logic - The Value Difference"
  description="$15,000 vs $30,000. Same professional quality, half the price. See how we deliver premium RO systems without the premium markup."
>
  <section class="hero-gradient py-20 md:py-24 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-6xl font-serif mb-4 text-foreground">
        The $15k Value Proposition
      </h1>
      <p class="text-xl md:text-2xl text-muted-foreground">
        Professional quality without the inflated price tag
      </p>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-3xl md:text-4xl font-serif text-center mb-6 text-foreground"
      >
        Blue Logic vs. The Competition
      </h2>
      <p
        class="text-lg text-center text-muted-foreground max-w-3xl mx-auto mb-12"
      >
        We deliver the same professional-grade components and installation
        quality as competitors charging $30,000+. Here's how we do it—and why
        you shouldn't pay more. Learn more about <a
          href="/the-system"
          class="text-primary hover:underline font-semibold"
          >how our system works</a
        >.
      </p>

      <div class="max-w-4xl mx-auto bg-card rounded-2xl overflow-hidden">
        <div
          class="grid grid-cols-3 gap-4 p-6 bg-secondary text-secondary-foreground font-bold text-sm uppercase tracking-wider"
        >
          <div>Feature</div>
          <div class="text-center">Blue Logic</div>
          <div class="text-center">Competitors</div>
        </div>

        <div class="comparison-row">
          <div class="font-semibold">Price</div>
          <div class="text-center text-primary font-bold">$15,000</div>
          <div class="text-center">$30,000+</div>
        </div>

        <div class="comparison-row">
          <div class="font-semibold">Professional Installation</div>
          <div class="text-center">✓ Included</div>
          <div class="text-center">✓ Included</div>
        </div>

        <div class="comparison-row">
          <div class="font-semibold">Commercial-Grade Components</div>
          <div class="text-center">✓ Yes</div>
          <div class="text-center">✓ Yes</div>
        </div>

        <div class="comparison-row">
          <div class="font-semibold">Compact Footprint</div>
          <div class="text-center text-primary font-bold">50% smaller</div>
          <div class="text-center">Standard bulk</div>
        </div>

        <div class="comparison-row">
          <div class="font-semibold">Noise Level</div>
          <div class="text-center text-primary font-bold">10x quieter</div>
          <div class="text-center">Standard</div>
        </div>

        <div class="comparison-row">
          <div class="font-semibold">Marketing & Overhead</div>
          <div class="text-center text-primary font-bold">Minimal</div>
          <div class="text-center">Heavy markup</div>
        </div>

        <div class="comparison-row">
          <div class="font-semibold">Local Service</div>
          <div class="text-center">✓ Wasatch Front</div>
          <div class="text-center">✓ Various</div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-3xl md:text-4xl font-serif text-center mb-12 text-foreground"
      >
        Why We Can Charge Half
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="p-8 bg-background rounded-2xl">
          <h3 class="text-xl font-semibold mb-4 text-primary">
            Direct Business Model
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            We cut out the middlemen and excessive marketing spend. No celebrity
            endorsements, no massive ad campaigns—just word of mouth and
            exceptional service.
          </p>
        </div>

        <div class="p-8 bg-background rounded-2xl">
          <h3 class="text-xl font-semibold mb-4 text-primary">
            Efficient Engineering
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Our <a
              href="/the-system"
              class="text-primary hover:underline font-semibold"
              >compact design uses advanced engineering</a
            > to reduce material costs and installation time without sacrificing quality
            or performance.
          </p>
        </div>

        <div class="p-8 bg-background rounded-2xl">
          <h3 class="text-xl font-semibold mb-4 text-primary">Local Focus</h3>
          <p class="text-muted-foreground leading-relaxed">
            By serving only the <a
              href="/locations"
              class="text-primary hover:underline font-semibold"
              >Wasatch Front</a
            >, we optimize logistics, reduce overhead, and build deep
            relationships with suppliers and customers.
          </p>
        </div>

        <div class="p-8 bg-background rounded-2xl">
          <h3 class="text-xl font-semibold mb-4 text-primary">
            Fair Pricing Philosophy
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            We believe premium water shouldn't require premium income. Our
            pricing reflects our actual costs plus a fair margin—nothing more.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-3xl md:text-4xl font-serif text-center mb-6 text-foreground"
      >
        What You're Protecting Against
      </h2>
      <p
        class="text-lg text-center text-muted-foreground max-w-3xl mx-auto mb-12"
      >
        Clean water isn't just about taste. It's about removing invisible
        threats that affect your family's health, your home's longevity, and
        your peace of mind.
      </p>

      <!-- Image + Content Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 mb-12">
        <div class="lg:col-span-2">
          <Image
            src={boyExaminesGlassImg}
            alt="Young boy thoughtfully examining a glass of water, curious about what's inside"
            class="rounded-2xl shadow-2xl w-full object-cover aspect-[3/4] sticky top-8"
            widths={[400, 600]}
            sizes="(max-width: 768px) 100vw, 40vw"
          />
          <p class="text-sm text-muted-foreground text-center mt-4 italic">
            What's really in your family's water?
          </p>
        </div>
        <div class="lg:col-span-3 grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="threat-card">
            <div class="text-4xl mb-4">⚗️</div>
            <h3 class="text-xl font-bold mb-4 text-foreground">
              PFAS & Forever Chemicals
            </h3>
            <p class="text-muted-foreground text-sm leading-relaxed">
              Industrial chemicals that persist in the environment and
              accumulate in your body. Linked to cancer, hormone disruption, and
              immune system damage—found in water supplies across Utah.
            </p>
          </div>

          <div class="threat-card">
            <div class="text-4xl mb-4">🧬</div>
            <h3 class="text-xl font-bold mb-4 text-foreground">
              Microplastics
            </h3>
            <p class="text-muted-foreground text-sm leading-relaxed">
              Microscopic plastic fragments detected in tap water, bottled
              water, and even human blood. These particles carry toxins and
              accumulate over time with unknown long-term effects.
            </p>
          </div>

          <div class="threat-card">
            <div class="text-4xl mb-4">🚿</div>
            <h3 class="text-xl font-bold mb-4 text-foreground">
              Transdermal Absorption
            </h3>
            <p class="text-muted-foreground text-sm leading-relaxed">
              Toxins don't just enter through drinking. During showers and
              baths, your skin absorbs chemicals, and your lungs inhale
              vaporized contaminants—whole-home filtration stops them at every
              tap.
            </p>
          </div>

          <div class="threat-card">
            <div class="text-4xl mb-4">🔧</div>
            <h3 class="text-xl font-bold mb-4 text-foreground">
              Hard Water & Scale Damage
            </h3>
            <p class="text-muted-foreground text-sm leading-relaxed">
              Calcium and magnesium minerals create scale buildup that reduces
              appliance lifespan, clogs pipes, and wastes money on soap and
              repairs. Utah's hard water is among the hardest in the nation.
            </p>
          </div>

          <div class="threat-card md:col-span-2">
            <div class="text-4xl mb-4">☣️</div>
            <h3 class="text-xl font-bold mb-4 text-foreground">
              Chlorine & Byproducts
            </h3>
            <p class="text-muted-foreground text-sm leading-relaxed">
              Municipal water treatment chemicals and their disinfection
              byproducts can irritate skin, exacerbate respiratory conditions,
              and have been associated with increased cancer risk.
            </p>
          </div>
        </div>
      </div>

      <p
        class="text-lg text-center text-foreground font-medium max-w-3xl mx-auto p-8 bg-accent rounded-2xl"
      >
        Our whole-home RO system addresses all five of these threats—not just at
        your kitchen sink, but at every faucet, shower, and appliance in your
        home.
      </p>
    </div>
  </section>

  <!-- Premium Lifestyle Section -->
  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-serif mb-6 text-foreground">
            Experience the Premium Difference
          </h2>
          <p class="text-lg text-muted-foreground leading-relaxed mb-6">
            Pure water transforms your daily rituals. Softer skin, shinier hair,
            and that spa-like feeling—every single day. No more mineral buildup
            on fixtures or spots on glassware.
          </p>
          <p class="text-lg text-muted-foreground leading-relaxed mb-8">
            This is the invisible luxury that elevates your home. Not flashy,
            just fundamentally better.
          </p>common-questions" class="text-primary font-semibold text-lg
          hover:opacity-80 transition-opacity" > Have Questions? Check Our
          FAQsemibold text-lg hover:opacity-80 transition-opacity" > Schedule
          Your Water Audit →
        </div>
      </div>
      <div>
        <Image
          src={fancyShowerImg}
          alt="Modern luxury shower with pristine water flowing through premium fixtures"
          class="rounded-2xl shadow-2xl w-full object-cover aspect-[4/3]"
          widths={[400, 600, 800]}
          sizes="(max-width: 768px) 100vw, 50vw"
        />
      </div>
    </div>
  </section>
</Layout>

<section class="bg-background py-16 md:py-20 px-4 text-center">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-serif mb-8 text-foreground">
      The Blue Logic Guarantee
    </h2>
    <p
      class="text-lg text-muted-foreground mb-12 max-w-3xl mx-auto leading-relaxed"
    >
      We use the exact same commercial-grade components as competitors. We
      provide the same professional installation. We offer the same
      comprehensive warranties. The only difference? We don't believe in
      charging twice what's fair.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
      <div class="p-8 bg-card rounded-2xl">
        <strong class="block text-lg mb-2 text-foreground"
          >Professional Installation</strong
        >
        <p class="text-muted-foreground">Licensed & certified technicians</p>
      </div>
      <div class="p-8 bg-card rounded-2xl">
        <strong class="block text-lg mb-2 text-foreground"
          >Grade-A Components</strong
        >
        <p class="text-muted-foreground">Commercial-quality materials</p>
      </div>
      <div class="p-8 bg-card rounded-2xl">
        <strong class="block text-lg mb-2 text-foreground">Full Warranty</strong
        >
        <p class="text-muted-foreground">Comprehensive coverage included</p>
      </div>
    </div>
  </div>
</section>

<section class="bg-card py-16 md:py-20 px-4 text-center">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-serif mb-4 text-foreground">
      Ready to Save $15,000?
    </h2>
    <p class="text-xl text-muted-foreground mb-8">
      Get a free consultation and water quality assessment
    </p>
    <a href="/#contact" class="btn btn-primary btn-lg">Schedule Your Audit</a>
  </div>
</section>

<style>
  @reference "../styles/global.css";
  .comparison-row {
    @apply grid grid-cols-3 gap-4 p-6 items-center border-b border-border last:border-b-0;
  }

  .threat-card {
    @apply bg-card p-8 rounded-2xl border-l-4 border-primary;
  }
</style>
