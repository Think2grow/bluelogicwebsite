---
import Layout from "../layouts/Layout.astro";
import { getBaseOrganizationSchema } from "../utils/schema";

const siteUrl = Astro.site?.toString() || "https://bluelogicwater.com";
const schema = [getBaseOrganizationSchema(siteUrl)];

const pageTitle = "Thank You - Blue Logic Water";
const pageDescription = "Thank you for contacting Blue Logic Water. We'll be in touch shortly to discuss your water purification needs.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  schema={schema}
>
  <!-- Tracking Pixels Section - Add your tracking codes here -->
  <!-- Example: Meta Pixel, Google Analytics Conversion, etc. -->
  
  <main class="min-h-screen bg-gradient-to-b from-[oklch(0.15_0.02_270)] to-[oklch(0.1_0.01_270)] flex items-center justify-center px-4 py-20">
    <div class="max-w-2xl mx-auto text-center">
      <!-- Success Icon -->
      <div class="mb-8 flex justify-center">
        <div class="w-24 h-24 rounded-full bg-glacier/10 flex items-center justify-center">
          <svg class="w-12 h-12 text-glacier" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>
      </div>

      <!-- Main Message -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif text-white mb-6">
        Thank You!
      </h1>
      
      <p class="text-xl md:text-2xl text-white/80 mb-8">
        We've received your request for a free water purity audit.
      </p>

      <!-- What's Next Section -->
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8 mb-12">
        <h2 class="text-2xl font-serif text-white mb-6">What Happens Next?</h2>
        
        <div class="space-y-6 text-left">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-glacier/20 flex items-center justify-center shrink-0 mt-1">
              <span class="text-glacier font-bold">1</span>
            </div>
            <div>
              <h3 class="text-white font-semibold mb-1">We'll Contact You</h3>
              <p class="text-white/70 text-sm">
                A member of our team will reach out within 24 hours to schedule your free water audit.
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-glacier/20 flex items-center justify-center shrink-0 mt-1">
              <span class="text-glacier font-bold">2</span>
            </div>
            <div>
              <h3 class="text-white font-semibold mb-1">In-person Or Video walkthrough.</h3>
              <p class="text-white/70 text-sm">
                We'll confirm which system is the correct solution for the specifc needs of your home.
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-glacier/20 flex items-center justify-center shrink-0 mt-1">
              <span class="text-glacier font-bold">3</span>
            </div>
            <div>
              <h3 class="text-white font-semibold mb-1">Custom Solution</h3>
              <p class="text-white/70 text-sm">
                We'll design a system tailored to your home and provide transparent pricing with no hidden costs.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-8 py-4 bg-glacier hover:bg-glacier/90 text-white font-semibold rounded-lg transition-colors duration-200"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Back to Home
        </a>
        
        <a
          href="https://www.instagram.com/bluelogicwater"
          class="inline-flex items-center gap-2 px-8 py-4 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-lg border border-white/20 transition-colors duration-200"
        >
          Check Out Our Instagram!
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>

      <!-- Contact Info -->
      <div class="mt-12 pt-8 border-t border-white/10">
        <p class="text-white/60 text-sm mb-2">
          Need immediate assistance?
        </p>
        <a href="tel:+18019802583" class="text-glacier hover:text-glacier/80 font-semibold transition-colors">
          Call us: (801) 980-2583
        </a>
      </div>
    </div>
  </main>
</Layout>
