---
import Layout from "../layouts/Layout.astro";
import { getBreadcrumbSchema } from "../utils/schema";

const siteUrl = Astro.site?.toString() || "https://bluelogicwater.com";

const schemas = [
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Privacy Policy", url: "/privacy" },
  ]),
];
---

<Layout
  title="Privacy Policy - Blue Logic Water"
  description="Learn how Blue Logic Water collects, uses, and protects your personal information."
  schema={schemas}
>
  <section class="hero">
    <div class="container">
      <h1>Privacy Policy</h1>
      <p class="subtitle">Last Updated: December 30, 2025</p>
    </div>
  </section>

  <section class="content">
    <div class="container">
      <div class="policy-content">
        <p class="intro">
          At Blue Logic Water, we respect your privacy and are committed to
          protecting your personal information. This Privacy Policy explains how
          we collect, use, and safeguard your data.
        </p>

        <section class="policy-section">
          <h2>1. Information We Collect</h2>
          <p>We may collect the following types of information from you:</p>
          <ul>
            <li>
              <strong>Contact Information:</strong> Name, email address, phone number,
              and home address
            </li>
            <li>
              <strong>Purchase Details:</strong> Products purchased, payment method
              (processed via third-party provider)
            </li>
            <li>
              <strong>Website Usage:</strong> IP address, browser type, pages visited,
              and referring website
            </li>
            <li>
              <strong>Lead Information:</strong> Data submitted through forms for
              scheduling or inquiries
            </li>
          </ul>
        </section>

        <section class="policy-section">
          <h2>2. How We Use Your Information</h2>
          <p>We use your information to:</p>
          <ul>
            <li>Process and fulfill your orders</li>
            <li>
              Communicate with you about services, appointments, and updates
            </li>
            <li>Respond to customer inquiries</li>
            <li>Improve our website, marketing, and services</li>
            <li>Comply with legal and regulatory requirements</li>
          </ul>
        </section>

        <section class="policy-section">
          <h2>3. Sharing of Information</h2>
          <p>We do not sell your personal information. We may share it with:</p>
          <ul>
            <li>
              Authorized installers and service technicians for fulfillment
              purposes
            </li>
            <li>
              Trusted third-party vendors (e.g., payment processors, CRM
              systems)
            </li>
            <li>Legal or regulatory bodies as required by law</li>
          </ul>
        </section>

        <section class="policy-section">
          <h2>4. Data Security</h2>
          <p>
            We use secure systems and industry-standard practices to protect
            your data. All personal information is stored securely and access is
            limited to authorized personnel only.
          </p>
        </section>

        <section class="policy-section">
          <h2>5. Cookies & Tracking</h2>
          <p>
            We may use cookies and similar tracking technologies to enhance your
            browsing experience and measure marketing effectiveness. You can
            disable cookies in your browser settings at any time.
          </p>
        </section>

        <section class="policy-section">
          <h2>6. Third-Party Links</h2>
          <p>
            Our website may contain links to third-party sites. We are not
            responsible for the privacy practices of those sites and encourage
            you to review their privacy policies.
          </p>
        </section>

        <section class="policy-section">
          <h2>7. Your Rights</h2>
          <p>
            You may request access to, correction of, or deletion of your
            personal information at any time by contacting us.
          </p>
        </section>

        <section class="policy-section">
          <h2>8. Contact Us</h2>
          <p>
            If you have any questions about this Privacy Policy or how we handle
            your data, please contact:
          </p>
          <div class="contact-info">
            <p><strong>Blue Logic Water</strong></p>
            <p>
              Email: <a href="mailto:info@bluelogicwater.com"
                >info@bluelogicwater.com</a
              >
            </p>
            <p>Phone: <a href="tel:+18382322583">(838) 232-2583</a></p>
          </div>
        </section>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: linear-gradient(
      135deg,
      oklch(0.95 0.01 90) 0%,
      oklch(0.85 0.05 220) 100%
    );
    padding: 6rem 2rem 4rem;
    text-align: center;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  h1 {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    font-family: "Instrument Serif", Georgia, serif;
  }

  .subtitle {
    font-size: 1.125rem;
    color: oklch(0.4 0.02 270);
    font-weight: 400;
  }

  .content {
    background-color: white;
  }

  .policy-content {
    line-height: 1.8;
  }

  .intro {
    font-size: 1.25rem;
    color: oklch(0.3 0.02 270);
    margin-bottom: 3rem;
    line-height: 1.8;
  }

  .policy-section {
    margin-bottom: 3rem;
  }

  .policy-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    color: oklch(0.7 0.1 220);
    font-family: "Instrument Serif", Georgia, serif;
  }

  .policy-section p {
    color: oklch(0.35 0.02 270);
    margin-bottom: 1rem;
  }

  .policy-section ul {
    list-style: disc;
    padding-left: 2rem;
    margin-bottom: 1rem;
  }

  .policy-section li {
    color: oklch(0.35 0.02 270);
    margin-bottom: 0.75rem;
  }

  .policy-section strong {
    color: oklch(0.2 0.02 270);
    font-weight: 600;
  }

  .contact-info {
    background-color: oklch(0.98 0.01 90);
    padding: 1.5rem;
    border-radius: 0.5rem;
    margin-top: 1rem;
  }

  .contact-info p {
    margin-bottom: 0.5rem;
  }

  .contact-info a {
    color: oklch(0.7 0.1 220);
    text-decoration: none;
    font-weight: 500;
  }

  .contact-info a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2.5rem;
    }

    .hero {
      padding: 4rem 1rem 3rem;
    }

    .container {
      padding: 3rem 1.5rem;
    }

    .policy-section h2 {
      font-size: 1.5rem;
    }
  }
</style>
