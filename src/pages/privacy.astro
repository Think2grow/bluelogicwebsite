---
import Layout from "../layouts/Layout.astro";
import { getBreadcrumbSchema } from "../utils/schema";

const siteUrl = Astro.site?.toString() || "https://bluelogicwater.com";
export const prerender = true;

const schemas = [
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Privacy Policy", url: "/privacy/" },
  ]),
];
---

<Layout
  title="Privacy Policy - Blue Logic Water"
  description="Learn how Blue Logic Water collects, uses, and protects your personal information."
  schema={schemas}
  noindex={true}
>
  <section class="hero-gradient py-20 md:py-24 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-6xl font-serif mb-4 text-foreground">
        Privacy Policy
      </h1>
      <p class="text-lg text-muted-foreground">
        Last Updated: December 30, 2025
      </p>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-3xl mx-auto">
      <div class="prose max-w-none">
        <p class="text-xl text-foreground leading-relaxed mb-12">
          At Blue Logic Water, we respect your privacy and are committed to
          protecting your personal information. This Privacy Policy explains how
          we collect, use, and safeguard your data.
        </p>

        <div class="policy-section">
          <h2 class="text-2xl font-serif text-primary mb-4">
            1. Information We Collect
          </h2>
          <p class="text-muted-foreground mb-4">
            We may collect the following types of information from you:
          </p>
          <ul class="list-disc pl-8 text-muted-foreground space-y-3">
            <li>
              <strong class="text-foreground">Contact Information:</strong> Name,
              email address, phone number, and home address
            </li>
            <li>
              <strong class="text-foreground">Purchase Details:</strong> Products
              purchased, payment method (processed via third-party provider)
            </li>
            <li>
              <strong class="text-foreground">Website Usage:</strong> IP address,
              browser type, pages visited, and referring website
            </li>
            <li>
              <strong class="text-foreground">Lead Information:</strong> Data submitted
              through forms for scheduling or inquiries
            </li>
          </ul>
        </div>

        <div class="policy-section">
          <h2 class="text-2xl font-serif text-primary mb-4">
            2. How We Use Your Information
          </h2>
          <p class="text-muted-foreground mb-4">We use your information to:</p>
          <ul class="list-disc pl-8 text-muted-foreground space-y-3">
            <li>Process and fulfill your orders</li>
            <li>
              Communicate with you about services, appointments, and updates
            </li>
            <li>Respond to customer inquiries</li>
            <li>Improve our website, marketing, and services</li>
            <li>Comply with legal and regulatory requirements</li>
          </ul>
        </div>

        <div class="policy-section">
          <h2 class="text-2xl font-serif text-primary mb-4">
            3. Sharing of Information
          </h2>
          <p class="text-muted-foreground mb-4">
            We do not sell your personal information. We may share it with:
          </p>
          <ul class="list-disc pl-8 text-muted-foreground space-y-3">
            <li>
              Authorized installers and service technicians for fulfillment
              purposes
            </li>
            <li>
              Trusted third-party vendors (e.g., payment processors, CRM
              systems)
            </li>
            <li>Legal or regulatory bodies as required by law</li>
          </ul>
        </div>

        <div class="policy-section">
          <h2 class="text-2xl font-serif text-primary mb-4">
            4. Data Security
          </h2>
          <p class="text-muted-foreground leading-relaxed">
            We use secure systems and industry-standard practices to protect
            your data. All personal information is stored securely and access is
            limited to authorized personnel only.
          </p>
        </div>

        <div class="policy-section">
          <h2 class="text-2xl font-serif text-primary mb-4">
            5. Cookies & Tracking
          </h2>
          <p class="text-muted-foreground leading-relaxed">
            We may use cookies and similar tracking technologies to enhance your
            browsing experience and measure marketing effectiveness. You can
            disable cookies in your browser settings at any time.
          </p>
        </div>

        <div class="policy-section">
          <h2 class="text-2xl font-serif text-primary mb-4">
            6. Third-Party Links
          </h2>
          <p class="text-muted-foreground leading-relaxed">
            Our website may contain links to third-party sites. We are not
            responsible for the privacy practices of those sites and encourage
            you to review their privacy policies.
          </p>
        </div>

        <div class="policy-section">
          <h2 class="text-2xl font-serif text-primary mb-4">7. Your Rights</h2>
          <p class="text-muted-foreground leading-relaxed">
            You may request access to, correction of, or deletion of your
            personal information at any time by contacting us.
          </p>
        </div>

        <div class="policy-section">
          <h2 class="text-2xl font-serif text-primary mb-4">8. Contact Us</h2>
          <p class="text-muted-foreground mb-4">
            If you have any questions about this Privacy Policy or how we handle
            your data, please contact:
          </p>
          <div class="bg-card p-6 rounded-xl">
            <p class="font-semibold text-foreground mb-2">Blue Logic Water</p>
            <p class="text-muted-foreground mb-2">
              Email: <a
                href="mailto:info@bluelogicwater.com"
                class="text-primary hover:underline font-medium"
                >info@bluelogicwater.com</a
              >
            </p>
            <p class="text-muted-foreground">
              Phone: <a
                href="tel:+18019802583"
                class="text-primary hover:underline font-medium"
                >(801) 980-2583</a
              >
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
