---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <header class="mb-8">
      <h1 class="text-4xl font-bold text-foreground mb-4">{post.data.title}</h1>
      {
        post.data.description && (
          <p class="text-xl text-muted-foreground mb-4">
            {post.data.description}
          </p>
        )
      }
      <div class="flex items-center gap-4 text-sm text-muted-foreground">
        <span>{post.data.author}</span>
        <span>•</span>
        <time datetime={post.data.date.toISOString()}>
          {
            post.data.date.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </time>
      </div>
    </header>

    <div class="rounded">
      {
        post.data.image && (
          <Image
            src={post.data.image}
            alt={`Cover image for ${post.data.title}`}
            class="w-full h-auto rounded-md mb-8"
          />
        )
      }
    </div>

    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .prose {
    color: var(--color-obsidian, oklch(0.2 0.02 270));
    line-height: 1.75;
  }

  .prose :global(h2) {
    font-size: 1.875rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
    color: var(--color-obsidian, oklch(0.2 0.02 270));
  }

  .prose :global(h3) {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
    color: var(--color-obsidian, oklch(0.2 0.02 270));
  }

  .prose :global(h4) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    line-height: 1.5;
    color: var(--color-obsidian, oklch(0.2 0.02 270));
  }

  .prose :global(p) {
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
    padding-left: 1.625rem;
  }

  .prose :global(li) {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(ul > li) {
    list-style-type: disc;
  }

  .prose :global(ol > li) {
    list-style-type: decimal;
  }

  .prose :global(strong) {
    font-weight: 600;
    color: var(--color-obsidian, oklch(0.2 0.02 270));
  }

  .prose :global(a) {
    color: var(--color-glacier, oklch(0.7 0.1 220));
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .prose :global(a:hover) {
    color: oklch(0.6 0.12 220);
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--color-glacier, oklch(0.7 0.1 220));
    padding-left: 1rem;
    font-style: italic;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    color: oklch(0.4 0.02 270);
  }

  .prose :global(code) {
    background-color: var(--color-quartz, oklch(0.95 0.01 90));
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .prose :global(pre) {
    background-color: var(--color-quartz, oklch(0.95 0.01 90));
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .prose :global(pre code) {
    background-color: transparent;
    padding: 0;
    font-size: 0.875rem;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid oklch(0.85 0.01 90);
    margin-top: 3rem;
    margin-bottom: 3rem;
  }

  .prose :global(img) {
    border-radius: 0.5rem;
    margin-top: 2rem;
    margin-bottom: 2rem;
  }
</style>
