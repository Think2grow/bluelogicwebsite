---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import { getBreadcrumbSchema } from "../../utils/schema";

function getArticleSchema(siteUrl: string, post: any, postId: string) {
  return {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: post.data.title,
    description: post.data.description || "",
    author: {
      "@type": "Organization",
      name: post.data.author || "Blue Logic Water",
      url: siteUrl,
    },
    publisher: {
      "@type": "Organization",
      name: "Blue Logic Water",
      url: siteUrl,
      logo: {
        "@type": "ImageObject",
        url: `${siteUrl}/3%20Blue%20Logic%20Water%20Logo-13.jpg`,
      },
    },
    datePublished: post.data.date.toISOString(),
    dateModified: post.data.date.toISOString(),
    url: `${siteUrl}/blog/${postId}/`,
    mainEntityOfPage: `${siteUrl}/blog/${postId}/`,
  };
}

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Related posts — a rotating window of the next 3 articles so every post
// receives inbound internal links (not just the newest few).
const allPosts = await getCollection("blog");
const sortedPosts = [...allPosts].sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const currentIdx = sortedPosts.findIndex((p) => p.id === post.id);
const relatedPosts = [1, 2, 3]
  .map((offset) => sortedPosts[(currentIdx + offset) % sortedPosts.length])
  .filter((p) => p && p.id !== post.id);

const siteUrl = "https://www.bluelogicwater.com";
const schemas = [
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Blog", url: "/blog/" },
    { name: post.data.title, url: `/blog/${post.id}/` },
  ]),
  getArticleSchema(siteUrl, post, post.id),
];
---

<Layout
  title={post.data.seoTitle ?? `${post.data.title} | Blue Logic Water`}
  description={post.data.description || "Utah water treatment guides and resources from Blue Logic Water."}
  schema={schemas}
>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <header class="mb-8">
      <h1 class="text-4xl font-bold text-foreground mb-4">{post.data.title}</h1>
      {
        post.data.description && (
          <p class="text-xl text-muted-foreground mb-4">
            {post.data.description}
          </p>
        )
      }
      <div class="flex items-center gap-4 text-sm text-muted-foreground">
        <span>{post.data.author}</span>
        <span>•</span>
        <time datetime={post.data.date.toISOString()}>
          {
            post.data.date.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </time>
      </div>
    </header>

    <div class="rounded">
      {
        post.data.image && (
          <Image
            src={post.data.image}
            alt={`Cover image for ${post.data.title}`}
            class="w-full h-auto rounded-md mb-8"
            widths={[600, 900, 1200]}
            sizes="(max-width: 768px) 100vw, 75vw"
            quality={80}
          />
        )
      }
    </div>

    <div class="prose prose-lg max-w-none">
      <Content />
    </div>

    <!-- Bottom CTA -->
    <div class="mt-16 bg-primary/5 border border-primary/20 rounded-2xl p-8 text-center not-prose">
      <h2 class="text-2xl font-serif mb-3 text-foreground">Ready to Test Your Water?</h2>
      <p class="text-muted-foreground mb-6">
        Blue Logic offers a free in-home water test for Wasatch Front homeowners — hardness and chlorine tested on-site, results explained in plain English. No cost, no obligation.
      </p>
      <a href="/free-water-test/" class="inline-block bg-primary text-primary-foreground font-semibold px-8 py-4 rounded-full shadow hover:bg-primary/90 transition-all">
        Schedule Free Water Test →
      </a>
    </div>

    <!-- Related articles -->
    {
      relatedPosts.length > 0 && (
        <div class="mt-16 pt-10 border-t border-border not-prose">
          <h2 class="text-2xl font-serif mb-6 text-foreground">Related Articles</h2>
          <ul class="grid gap-4 sm:grid-cols-3">
            {relatedPosts.map((p) => (
              <li>
                <a
                  href={`/blog/${p.id}/`}
                  class="block h-full bg-card border border-border rounded-xl p-5 hover:border-primary transition-colors"
                >
                  <span class="font-semibold text-foreground leading-snug">
                    {p.data.title}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }

    <!-- Related posts navigation -->
    <div class="mt-8 pt-8 border-t border-border not-prose">
      <a href="/blog/" class="text-primary font-semibold hover:opacity-80 transition-opacity">
        ← All Articles
      </a>
    </div>
  </article>
</Layout>

<style>
  .prose {
    color: var(--color-obsidian, oklch(0.2 0.02 270));
    line-height: 1.75;
  }

  .prose :global(h2) {
    font-size: 1.875rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
    color: var(--color-obsidian, oklch(0.2 0.02 270));
  }

  .prose :global(h3) {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
    color: var(--color-obsidian, oklch(0.2 0.02 270));
  }

  .prose :global(h4) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    line-height: 1.5;
    color: var(--color-obsidian, oklch(0.2 0.02 270));
  }

  .prose :global(p) {
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
    padding-left: 1.625rem;
  }

  .prose :global(li) {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(ul > li) {
    list-style-type: disc;
  }

  .prose :global(ol > li) {
    list-style-type: decimal;
  }

  .prose :global(strong) {
    font-weight: 600;
    color: var(--color-obsidian, oklch(0.2 0.02 270));
  }

  .prose :global(a) {
    color: var(--color-glacier, oklch(0.7 0.1 220));
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .prose :global(a:hover) {
    color: oklch(0.6 0.12 220);
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--color-glacier, oklch(0.7 0.1 220));
    padding-left: 1rem;
    font-style: italic;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    color: oklch(0.4 0.02 270);
  }

  .prose :global(code) {
    background-color: var(--color-quartz, oklch(0.95 0.01 90));
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .prose :global(pre) {
    background-color: var(--color-quartz, oklch(0.95 0.01 90));
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .prose :global(pre code) {
    background-color: transparent;
    padding: 0;
    font-size: 0.875rem;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid oklch(0.85 0.01 90);
    margin-top: 3rem;
    margin-bottom: 3rem;
  }

  .prose :global(img) {
    border-radius: 0.5rem;
    margin-top: 2rem;
    margin-bottom: 2rem;
  }
</style>
