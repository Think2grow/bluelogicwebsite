---
import Layout from "../layouts/Layout.astro";
import fatherDaughterImg from "../assets/water_art/AdobeStock_302662231_father_daughter_faucet.jpeg";
---

<Layout og={{ title: "Your Water Shouldn't Be a Mystery | Blue Logic Water", image: fatherDaughterImg.src }}>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-b from-quartz via-white to-quartz min-h-screen flex items-center justify-center px-4 py-20">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <!-- Left: Copy -->
      <div class="order-2 md:order-1 text-center md:text-left space-y-8">
        <div class="space-y-4">
          <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl font-bold text-obsidian leading-[1.1] tracking-tight">
            Your Water<br />
            <span class="text-glacier">Shouldn't</span><br />
            Be a Mystery
          </h1>
          <div class="h-1 w-24 bg-glacier mx-auto md:mx-0"></div>
        </div>
        
        <p class="text-xl md:text-2xl text-obsidian-muted leading-relaxed max-w-lg">
          Utah groundwater can contain <strong class="text-obsidian">arsenic, lead, and industrial contaminants.</strong>
        </p>

        <div class="space-y-4">
          <div class="flex items-start gap-3 text-left">
            <svg class="w-6 h-6 text-glacier flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <p class="text-obsidian-light"><strong class="text-obsidian">Free, comprehensive water testing</strong> at your home</p>
          </div>
          <div class="flex items-start gap-3 text-left">
            <svg class="w-6 h-6 text-glacier flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <p class="text-obsidian-light"><strong class="text-obsidian">Verified lab analysis</strong> of contaminant levels</p>
          </div>
          <div class="flex items-start gap-3 text-left">
            <svg class="w-6 h-6 text-glacier flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <p class="text-obsidian-light"><strong class="text-obsidian">Expert recommendations</strong> for your home's needs</p>
          </div>
        </div>

        <div class="flex items-center gap-4 pt-4 justify-center md:justify-start">
          <div class="flex -space-x-3">
            <div class="w-10 h-10 rounded-full bg-glacier/20 border-2 border-white flex items-center justify-center text-glacier font-bold">✓</div>
            <div class="w-10 h-10 rounded-full bg-glacier/20 border-2 border-white flex items-center justify-center text-glacier font-bold">✓</div>
            <div class="w-10 h-10 rounded-full bg-glacier/20 border-2 border-white flex items-center justify-center text-glacier font-bold">✓</div>
          </div>
          <p class="text-sm text-obsidian-muted"><strong class="text-obsidian">Local experts</strong> serving the Wasatch Front</p>
        </div>
      </div>

      <!-- Right: Image -->
      <div class="order-1 md:order-2">
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-br from-glacier/20 to-transparent rounded-3xl transform rotate-3"></div>
          <img 
            src={fatherDaughterImg.src} 
            alt="Father and daughter enjoying clean, safe water" 
            class="relative rounded-3xl shadow-2xl w-full h-[400px] md:h-[600px] object-cover border-4 border-white"
            loading="eager" 
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Form Section -->
  <section class="bg-obsidian py-20 px-4">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-12 space-y-4">
        <h2 class="font-serif text-4xl md:text-5xl font-bold text-white">
          Schedule Your Free<br />Water Quality Test
        </h2>
        <p class="text-lg text-glacier-light">No obligation. No cost. Know what's in your water.</p>
      </div>

      <form id="contact-form" class="bg-white rounded-3xl shadow-2xl p-8 md:p-12 space-y-6" autocomplete="on">
        <input type="hidden" name="source" value="ksl" />
        
        <div class="grid md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label for="firstname" class="block text-sm font-semibold text-obsidian">First Name</label>
            <input 
              required 
              name="firstname" 
              id="firstname" 
              type="text" 
              placeholder="John" 
              class="input-field w-full" 
              autocomplete="given-name" 
            />
          </div>
          <div class="space-y-2">
            <label for="lastname" class="block text-sm font-semibold text-obsidian">Last Name</label>
            <input 
              required 
              name="lastname" 
              id="lastname" 
              type="text" 
              placeholder="Smith" 
              class="input-field w-full" 
              autocomplete="family-name" 
            />
          </div>
        </div>
        
        <div class="space-y-2">
          <label for="email" class="block text-sm font-semibold text-obsidian">Email Address</label>
          <input 
            required 
            name="email" 
            id="email" 
            type="email" 
            placeholder="john@example.com" 
            class="input-field w-full" 
            autocomplete="email" 
          />
        </div>
        
        <div class="space-y-2">
          <label for="phone" class="block text-sm font-semibold text-obsidian">Phone Number</label>
          <input 
            required 
            name="phone" 
            id="phone" 
            type="tel" 
            placeholder="(801) 555-1234" 
            class="input-field w-full" 
            autocomplete="tel" 
          />
        </div>

        <button 
          type="submit" 
          class="w-full bg-gradient-to-r from-glacier to-glacier-dark hover:from-glacier-dark hover:to-glacier text-white font-bold py-5 px-8 rounded-xl text-lg font-serif tracking-wide transition-all duration-300 shadow-lg hover:shadow-xl transform hover:scale-[1.02] active:scale-[0.98]"
        >
          Schedule Free Water Test
        </button>

        <div id="form-status" class="hidden"></div>
      </form>

      <div class="text-center mt-8 space-y-3">
        <p class="text-sm text-glacier-light flex items-center justify-center gap-2">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
          </svg>
          Your information is safe and secure
        </p>
        <p class="text-xs text-glacier-light/70">We respect your privacy. No spam, ever.</p>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="bg-white py-12 px-4 border-t border-border">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div class="space-y-2">
          <div class="text-3xl font-bold text-glacier font-serif">Local</div>
          <div class="text-sm text-obsidian-muted">Family Owned</div>
        </div>
        <div class="space-y-2">
          <div class="text-3xl font-bold text-glacier font-serif">99%</div>
          <div class="text-sm text-obsidian-muted">Contaminants Removed</div>
        </div>
        <div class="space-y-2">
          <div class="text-3xl font-bold text-glacier font-serif">Free</div>
          <div class="text-sm text-obsidian-muted">Water Testing</div>
        </div>
        <div class="space-y-2">
          <div class="text-3xl font-bold text-glacier font-serif">Local</div>
          <div class="text-sm text-obsidian-muted">Utah Experts</div>
        </div>
      </div>
    </div>
  </section>

  <style>
    @reference "../styles/global.css";
    
    .input-field {
      @apply px-5 py-4 border-2 border-border rounded-xl text-base font-sans bg-background transition-all duration-200 focus:outline-none focus:border-glacier focus:ring-4 focus:ring-glacier/10 placeholder:text-obsidian-muted;
    }

    #form-status {
      @apply p-4 rounded-xl text-center;
    }

    #form-status.success {
      @apply block bg-success-light text-success;
    }

    #form-status.error {
      @apply block bg-error-light text-error;
    }
  </style>

  <script>
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const status = document.getElementById("form-status") as HTMLDivElement;

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();

      const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = submitButton.textContent;
      submitButton.disabled = true;
      submitButton.textContent = "Submitting...";
      submitButton.classList.add("opacity-75", "cursor-not-allowed");

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      try {
        const response = await fetch(
          "https://services.leadconnectorhq.com/hooks/Nd8el709gXwDJdVuixdV/webhook-trigger/20f1db10-4f68-4506-9d2d-5c3da0b44df4",
          {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify(data),
          }
        );

        if (response.ok || response.status === 200) {
          window.location.href = "/thank-you";
        } else {
          throw new Error("Submission failed");
        }
      } catch (error) {
        status.className = "error";
        status.textContent = "Something went wrong. Please call us at (801) 854-9554 or try again.";
        console.error("Form submission error:", error);
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = originalText || "Schedule Free Water Test";
        submitButton.classList.remove("opacity-75", "cursor-not-allowed");
      }
    });
  </script>
</Layout>
