---
import Layout from "../layouts/Layout.astro";
import LeadForm from "../components/LeadForm.astro";
import Reviews from "../components/Reviews.astro";
import { getFAQSchema, getBreadcrumbSchema } from "../utils/schema";

export const prerender = true;

const siteUrl = "https://www.bluelogicwater.com";

const faqs = [
  {
    question: "Kinetico focuses on softening. Does Blue Logic do softening too?",
    answer: "Yes. Blue Logic's whole-home system includes water softening as the first treatment stage — it addresses calcium and magnesium hardness and protects the downstream filtration stages. After softening, the system adds carbon filtration (chlorine, chloramines, VOCs) and an optional whole-home RO stage that removes arsenic, PFAS, heavy metals, and disinfection byproducts. You get the hardness protection of a dedicated softener plus full-spectrum filtration in one integrated system.",
  },
  {
    question: "Is Kinetico's non-electric system a meaningful advantage over Blue Logic?",
    answer: "Kinetico's non-electric twin-tank design is a genuine engineering choice — no timer to set, metered regeneration, simpler mechanically. Blue Logic's system uses a small pump to maintain pressure in the pressurized storage tank. For most Utah homeowners, the more meaningful question is what the system actually removes from your water. Non-electric operation doesn't address arsenic, PFAS, or disinfection byproducts — those require filtration and RO stages regardless of how the softener regenerates.",
  },
  {
    question: "How do I know if I need RO or if a softener is enough?",
    answer: "A free in-home water test answers this directly. It measures your water's hardness, TDS, and key contaminants specific to your address and water source. If you're in a city with known arsenic detection (Lehi at 484x EWG guideline, Draper at 450x, Salt Lake City at 135x) or PFAS contamination, softening alone won't address those. The test removes the guesswork.",
  },
  {
    question: "Can Blue Logic match a written Kinetico quote?",
    answer: "Yes. Blue Logic's written price-match guarantee applies to any licensed Utah water treatment company. Bring your Kinetico quote to your free Blue Logic water test — we'll match or beat it in writing.",
  },
  {
    question: "Does Blue Logic require a service contract like some premium brands?",
    answer: "No. Blue Logic does not require an ongoing service contract. An annual check-up is included and scheduled at installation. Service after the first year is available per request — no contractual obligation.",
  },
];

const schemas = [
  getFAQSchema(faqs),
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Blue Logic vs. Kinetico Utah", url: "/blue-logic-vs-kinetico-utah/" },
  ]),
];
---

<Layout
  title="Blue Logic vs. Kinetico Utah | Softening Alone Isn't Enough"
  description="Kinetico makes excellent water softeners. But Utah water has arsenic, PFAS, and disinfection byproducts that softening doesn't touch. See how whole-home RO compares. Free water test."
  schema={schemas}
>
  <section class="hero-gradient py-20 md:py-24 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary mb-4">
        Utah Water Treatment · Comparison Guide
      </p>
      <h1 class="text-4xl md:text-5xl font-serif mb-6 text-foreground leading-tight">
        Kinetico Is Great at Softening.<br />But Utah Water Needs More.
      </h1>
      <p class="text-lg md:text-xl text-muted-foreground max-w-3xl mx-auto leading-relaxed">
        Kinetico has built a strong reputation around non-electric twin-tank water softeners.
        If your only concern is scale and hardness, they're worth a look. But if your water
        has arsenic, PFAS, or disinfection byproducts — and in Utah, there's a good chance it
        does — softening alone won't address those contaminants.
      </p>
    </div>
  </section>

  <section class="bg-primary/5 border-y border-primary/20 py-6 px-4">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm text-muted-foreground text-center">
        <strong class="text-foreground">What this page covers:</strong> Blue Logic's verified specs and how softening compares to whole-home filtration for Utah's specific water problems.
        We make no claims about Kinetico's pricing. Bring any written quote and Blue Logic will match or beat it.
      </p>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-5xl mx-auto">

      <div class="mb-12">
        <h2 class="text-3xl font-serif text-center mb-8 text-foreground">
          What Softening Fixes — and What It Doesn't
        </h2>
        <p class="text-muted-foreground text-center max-w-2xl mx-auto mb-8">
          Water softening is designed for one job: removing calcium and magnesium (hardness minerals).
          It does that well. But Utah's water contains additional contaminants that softeners were never built to remove.
        </p>
        <div class="overflow-x-auto rounded-2xl border border-border">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-card border-b border-border">
                <th class="text-left p-4 font-semibold text-foreground">Water Problem in Utah</th>
                <th class="p-4 font-semibold text-foreground text-center">Softener Only</th>
                <th class="p-4 font-semibold text-primary text-center">Whole-Home Filtration + RO</th>
              </tr>
            </thead>
            <tbody>
              {[
                { problem: "Scale and hardness (calcium/magnesium)", softener: "✓ Resolved", ro: "✓ Resolved" },
                { problem: "Chlorine taste and odor", softener: "✗ Not addressed", ro: "✓ Removed" },
                { problem: "Arsenic (elevated in Lehi, Draper, SLC)", softener: "✗ Not removed", ro: "✓ Removed by RO membrane" },
                { problem: "PFAS (detected in Salt Lake City)", softener: "✗ Not removed", ro: "✓ Removed by RO membrane" },
                { problem: "Haloacetic acid disinfection byproducts", softener: "✗ Not addressed", ro: "✓ Addressed" },
                { problem: "Iron and manganese staining", softener: "Partial", ro: "✓ Addressed" },
              ].map((row, i) => (
                <tr class={i % 2 === 0 ? "bg-background" : "bg-card"}>
                  <td class="p-4 text-muted-foreground">{row.problem}</td>
                  <td class="p-4 text-center text-muted-foreground">{row.softener}</td>
                  <td class="p-4 text-center font-medium text-primary">{row.ro}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-xs text-muted-foreground text-center mt-4">
          Arsenic and PFAS data from EWG Tap Water Database. RO membrane removes &gt;95% of dissolved contaminants.
        </p>
      </div>

      <h2 class="text-3xl font-serif text-center mb-4 text-foreground">Blue Logic's Verified System Specs</h2>
      <p class="text-sm text-muted-foreground text-center mb-8">Ask Kinetico the same questions — then compare written answers.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-10">
        {[
          { label: "Softening stage included", value: "Yes", note: "Stage 1 of integrated whole-home system." },
          { label: "Filtration stage included", value: "Yes", note: "Removes chlorine, chloramines, VOCs." },
          { label: "RO stage (optional)", value: "Yes", note: "Removes arsenic, PFAS, heavy metals, DBPs." },
          { label: "System price range", value: "$5,995 – $19,999", note: "Full installed price. No hidden fees." },
          { label: "NSF-certified components", value: "Yes", note: "NSF/ANSI-rated membranes and food-grade tanks." },
          { label: "Warranty", value: "1-year limited (parts)", note: "Components designed for 8–10 year lifespan." },
          { label: "Service contract required", value: "No", note: "Annual check-up included. No ongoing obligation." },
          { label: "Price match", value: "Written guarantee", note: "Match or beat any written competing quote from a licensed Utah provider." },
        ].map((item) => (
          <div class="spec-card">
            <div class="flex justify-between items-start gap-4 mb-2">
              <span class="font-semibold text-foreground">{item.label}</span>
              <span class="text-primary font-bold shrink-0">{item.value}</span>
            </div>
            <p class="text-xs text-muted-foreground">{item.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-10 text-foreground">Common Questions</h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item group">
            <summary class="faq-question">
              {faq.question}
              <span class="faq-icon group-open:rotate-45 transition-transform">+</span>
            </summary>
            <div class="faq-answer">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <Reviews compact={true} heading="What Utah Homeowners Say About Blue Logic" />
    </div>
  </section>

  <section class="bg-primary/5 py-16 md:py-20 px-4">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-4 text-foreground">
        Find Out What's Actually in Your Water
      </h2>
      <p class="text-muted-foreground text-center mb-10">
        A free in-home water test measures your home's specific water profile — hardness, TDS,
        and key contaminants. That determines whether softening alone is enough, or whether you
        need filtration and RO. No obligation, no pressure.
      </p>
      <LeadForm />
    </div>
  </section>
</Layout>

<style>
  @reference "../styles/global.css";

  .hero-gradient {
    @apply bg-linear-to-br from-background to-card;
  }

  .spec-card {
    @apply bg-card p-5 rounded-xl border border-border;
  }

  .faq-item {
    @apply bg-card border border-border rounded-xl overflow-hidden;
  }

  .faq-question {
    @apply flex justify-between items-center p-6 cursor-pointer font-semibold text-foreground list-none select-none hover:bg-accent/50 transition-colors;
  }

  .faq-question::-webkit-details-marker { display: none; }

  .faq-icon {
    @apply text-2xl text-primary font-light leading-none shrink-0;
  }

  .faq-answer {
    @apply px-6 pb-6 text-muted-foreground leading-relaxed;
  }
</style>
