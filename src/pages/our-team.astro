---
import Layout from "../layouts/Layout.astro";
import ProcessStepper from "../components/ProcessStepper.astro";
import { Image } from "astro:assets";
import handInWaterImg from "../assets/water_art/AdobeStock_1028297772_hand_in_clean_water.jpeg";
import realtorSinkImg from "../assets/water_art/AdobeStock_720169525_realtor_showing_off_sink.jpeg";

export const prerender = true;
---

<Layout
  title="Our Team - Blue Logic Water"
  description="Meet the local team behind Blue Logic Water. Wasatch-born, professionally certified, dedicated to bringing pure water to Salt Lake City homes."
>
  <section class="hero-gradient py-20 md:py-24 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-6xl font-serif mb-4 text-foreground">
        Our Team
      </h1>
      <p class="text-xl md:text-2xl text-muted-foreground">
        Wasatch-born water purification experts
      </p>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-serif mb-8 text-foreground">
            The Wasatch-Born Story
          </h2>
          <p class="text-lg leading-relaxed text-muted-foreground mb-6">
            Blue Logic Water was founded by a team of engineers and water
            quality specialists who grew up in the Salt Lake Valley. We
            experienced firsthand the challenges of <a
              href="/the-value"
              class="text-primary hover:underline font-semibold"
              >Utah's hard water</a
            > and the frustration of seeing families pay inflated prices for basic
            water purification.
          </p>
          <p class="text-lg leading-relaxed text-muted-foreground">
            Our mission is simple: bring <a
              href="/the-system"
              class="text-primary hover:underline font-semibold"
              >commercial-grade reverse osmosis technology</a
            >
            to homes at a fair price. No marketing gimmicks, no unnecessary upsells—just
            pure water and honest service.
          </p>
        </div>
        <div>
          <Image
            src={handInWaterImg}
            alt="Hand gently touching crystal clear purified water, feeling its purity"
            class="rounded-2xl shadow-2xl w-full object-cover aspect-4/3"
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 100vw, 50vw"
            quality={50}
          />
          <p class="text-sm text-muted-foreground text-center mt-4 italic">
            Feel the difference of truly pure water
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-3xl md:text-4xl font-serif text-center mb-12 text-foreground"
      >
        Expert Roles & Expertise
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="team-member">
          <div class="member-icon">
            <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2 text-foreground">
            Water Quality Specialist
          </h3>
          <p
            class="text-primary font-semibold text-sm uppercase tracking-wider mb-4"
          >
            Testing & Analysis Expert
          </p>
          <p class="text-muted-foreground leading-relaxed">
            Conducts comprehensive water quality testing and analysis to design the optimal system for your home. Works with our certified installation partners to ensure proper setup.
          </p>
        </div>

        <div class="team-member">
          <div class="member-icon">
            <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19.5 3.5L18 2l-1.5 1.5L15 2l-1.5 1.5L12 2l-1.5 1.5L9 2 7.5 3.5 6 2v14H3v3c0 1.66 1.34 3 3 3h12c1.66 0 3-1.34 3-3V2l-1.5 1.5zM19 19c0 .55-.45 1-1 1s-1-.45-1-1v-3H8V5h11v14zM9 7h6v2H9V7zm7 0h2v2h-2V7zM9 10h6v2H9v-2zm7 0h2v2h-2v-2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2 text-foreground">
            Water Quality Engineer
          </h3>
          <p
            class="text-primary font-semibold text-sm uppercase tracking-wider mb-4"
          >
            System Design & Optimization
          </p>
          <p class="text-muted-foreground leading-relaxed">
            Specializes in RO system engineering and water chemistry. Designs
            custom solutions for Utah's unique water profile and mineral
            content.
          </p>
        </div>

        <div class="team-member">
          <div class="member-icon">
            <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24">
              <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2 text-foreground">
            Customer Success Lead
          </h3>
          <p
            class="text-primary font-semibold text-sm uppercase tracking-wider mb-4"
          >
            Client Relations & Support
          </p>
          <p class="text-muted-foreground leading-relaxed">
            Dedicated to ensuring every client receives exceptional service from
            first contact through installation and beyond. Local Salt Lake City
            resident.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Installation Process Roadmap -->
  <ProcessStepper />

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-3xl md:text-4xl font-serif text-center mb-4 text-foreground"
      >
        The Purity Guarantee
      </h2>
      <p class="text-lg text-center text-muted-foreground mb-12">
        When we enter your home, we follow the Blue Logic code of conduct:
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-card p-8 rounded-2xl">
          <h3 class="text-xl font-semibold mb-4 text-foreground">
            Professional Excellence
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Our certified installation partners perform every installation to commercial standards with
            meticulous attention to detail.
          </p>
        </div>

        <div class="bg-card p-8 rounded-2xl">
          <h3 class="text-xl font-semibold mb-4 text-foreground">
            Respect Your Home
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            We treat your home as our own—clean workspace, protective equipment,
            and thorough cleanup.
          </p>
        </div>

        <div class="bg-card p-8 rounded-2xl">
          <h3 class="text-xl font-semibold mb-4 text-foreground">
            Transparent Communication
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Clear explanations of the work, no hidden fees, and honest timelines
            from start to finish.
          </p>
        </div>

        <div class="bg-card p-8 rounded-2xl">
          <h3 class="text-xl font-semibold mb-4 text-foreground">
            Local Accountability
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            We're your neighbors. Our reputation is built on trust and we stand
            behind every system we provide.
          </p>
        </div>

        <div class="bg-card p-8 rounded-2xl">
          <h3 class="text-xl font-semibold mb-4 text-foreground">
            Ongoing Support
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            We don't disappear after installation. Local service and maintenance
            support when you need it.
          </p>
        </div>

        <div class="bg-card p-8 rounded-2xl">
          <h3 class="text-xl font-semibold mb-4 text-foreground">
            Fair Pricing Always
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            No upsells, no pressure tactics. Just honest pricing for honest
            work.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif mb-6 text-foreground">
        Proudly Serving Nationwide
      </h2>
      <p class="text-lg text-muted-foreground mb-4 max-w-3xl mx-auto">
        Blue Logic serves families nationwide with a focus on the <a
          href="/locations"
          class="text-primary hover:underline font-semibold"
          >Wasatch Front and Utah region</a
        >.
      </p>
      <p class="text-lg text-muted-foreground max-w-3xl mx-auto">
        <strong class="text-foreground">Primary Service Areas:</strong> Salt Lake
        City • Park City • Draper • Sandy • Cottonwood Heights • Holladay • Murray
        • Millcreek
      </p>
    </div>
  </section>

  <!-- Professional Service Image Section -->
  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <h2 class="text-3xl md:text-4xl font-serif mb-6 text-foreground">
            Professional Installation, Premium Results
          </h2>
          <p class="text-lg text-muted-foreground leading-relaxed mb-6">
            Every Blue Logic system is installed by our certified partner technicians
            who treat your home with respect. Clean workspace, careful
            craftsmanship, and meticulous attention to detail.
          </p>
          <p class="text-lg text-muted-foreground leading-relaxed mb-8">
            The result? A <a
              href="/the-system"
              class="text-primary hover:underline font-semibold"
              >system that integrates seamlessly into your home</a
            > and delivers pure water for years to come.
          </p>
          <a
            href="/#contact"
            class="text-primary font-semibold text-lg hover:opacity-80 transition-opacity"
          >
            Schedule Your Consultation →
          </a>
        </div>
        <div class="order-1 lg:order-2">
          <Image
            src={realtorSinkImg}
            alt="Professional showing a modern kitchen with premium water fixtures and purification system"
            class="rounded-2xl shadow-2xl w-full object-cover aspect-4/3"
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 100vw, 50vw"
            quality={50}
          />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif mb-4 text-foreground">
        Work With a Local Team
      </h2>
      <p class="text-xl text-muted-foreground mb-8">
        Schedule a free consultation with our water quality experts
      </p>
      <a href="/#contact" class="btn btn-primary btn-lg w-full md:w-auto">Get Started</a>
    </div>
  </section>
</Layout>

<style>
  @reference "../styles/global.css";
  .team-member {
    @apply bg-background p-8 rounded-2xl text-center;
  }

  .member-icon {
    @apply w-20 h-20 mx-auto mb-6 rounded-full bg-primary/10 text-primary flex items-center justify-center;
  }
</style>
