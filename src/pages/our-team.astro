---
import Layout from "../layouts/Layout.astro";
import ProcessStepper from "../components/ProcessStepper.astro";
import Reviews from "../components/Reviews.astro";
import { getLocalBusinessSchema, getBreadcrumbSchema } from "../utils/schema";
import { Image } from "astro:assets";
import handInWaterImg from "../assets/water_art/AdobeStock_1028297772_hand_in_clean_water.jpeg";
import realtorSinkImg from "../assets/water_art/AdobeStock_720169525_realtor_showing_off_sink.jpeg";

export const prerender = true;

const siteUrl = "https://www.bluelogicwater.com";
const schemas = [
  getLocalBusinessSchema(siteUrl, "Salt Lake City"),
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Our Team", url: "/our-team/" },
  ]),
];
---

<Layout
  title="Our Team | Blue Logic Water — Utah Water Treatment Specialists"
  description="Meet the Blue Logic Water team — local Utah water treatment specialists serving the Wasatch Front. Jared leads installations with meticulous, same-day service."
  schema={schemas}
>
  <section class="hero-gradient py-20 md:py-24 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-6xl font-serif mb-4 text-foreground">
        Our Team
      </h1>
      <p class="text-xl md:text-2xl text-muted-foreground">
        Wasatch-born water purification experts
      </p>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-serif mb-8 text-foreground">
            The Wasatch-Born Story
          </h2>
          <p class="text-lg leading-relaxed text-muted-foreground mb-6">
            Blue Logic Water was founded by a team of engineers and water
            quality specialists who grew up in the Salt Lake Valley. We
            experienced firsthand the challenges of <a
              href="/the-value/"
              class="text-primary hover:underline font-semibold"
              >Utah's hard water</a
            > and the frustration of seeing families pay inflated prices for basic
            water purification.
          </p>
          <p class="text-lg leading-relaxed text-muted-foreground">
            Our mission is simple: bring <a
              href="/the-system/"
              class="text-primary hover:underline font-semibold"
              >commercial-grade reverse osmosis technology</a
            >
            to homes at a fair price. No marketing gimmicks, no unnecessary upsells—just
            pure water and honest service.
          </p>
        </div>
        <div>
          <Image
            src={handInWaterImg}
            alt="Hand gently touching crystal clear purified water, feeling its purity"
            class="rounded-2xl shadow-2xl w-full object-cover aspect-4/3"
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 100vw, 50vw"
            quality={50}
          />
          <p class="text-sm text-muted-foreground text-center mt-4 italic">
            Feel the difference of truly pure water
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Jared — named installer -->
  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif text-center mb-4 text-foreground">
        The People Behind Every Installation
      </h2>
      <p class="text-lg text-muted-foreground text-center max-w-2xl mx-auto mb-12">
        Blue Logic is a local Utah team. When you schedule a water test or an installation,
        you're working with people who live and work on the Wasatch Front — not a national
        call center.
      </p>

      <!-- Jared -->
      <div class="jared-card mb-8">
        <div class="jared-avatar">J</div>
        <div>
          <div class="flex items-center gap-3 flex-wrap mb-1">
            <h3 class="text-2xl font-semibold text-foreground">Jared</h3>
            <span class="text-sm font-semibold text-primary bg-primary/10 px-3 py-1 rounded-full">Lead Installation Technician</span>
          </div>
          <p class="text-sm text-muted-foreground mb-4">Wasatch Front · Blue Logic Water</p>
          <p class="text-muted-foreground leading-relaxed mb-4">
            Jared leads installations for Blue Logic Water across the Wasatch Front. He
            performs on-site water assessments, installs whole-home RO and filtration systems,
            services existing systems, and trains homeowners on how their system works and what
            maintenance to expect.
          </p>
          <p class="text-muted-foreground leading-relaxed mb-4">
            What homeowners consistently say about Jared: he comes in, does exactly what he says
            he'll do, and leaves the space cleaner than he found it. He schedules annual check-up
            calls proactively so homeowners don't have to remember to do it themselves.
          </p>
          <div class="flex flex-wrap gap-3 mt-4">
            <span class="credential-tag">NSF-Certified System Installation</span>
            <span class="credential-tag">Whole-Home RO Specialist</span>
            <span class="credential-tag">Water Quality Assessment</span>
            <span class="credential-tag">System Service & Maintenance</span>
          </div>
        </div>
      </div>

      <!-- What Jared does at each appointment -->
      <div class="bg-background rounded-2xl border border-border p-6 md:p-8">
        <h3 class="text-xl font-semibold text-foreground mb-6">What Happens at Every Installation</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {[
            { step: "Site Assessment", detail: "Jared evaluates your utility room, existing plumbing, and water supply before recommending a system configuration." },
            { step: "On-Site Water Testing", detail: "Tests your home's water for hardness and chlorine on the spot. Walks you through the results in plain English before any work begins." },
            { step: "Professional Installation", detail: "Most whole-home systems are installed in a single day — 4 to 8 hours depending on home layout. NSF-certified components throughout." },
            { step: "System Walkthrough", detail: "Before leaving, Jared walks you through how your system works, what maintenance it needs, and how to read the indicators." },
            { step: "Annual Check-Up", detail: "Jared proactively schedules a one-year follow-up to inspect the system, check performance, and handle any maintenance — so you don't have to remember." },
            { step: "Ongoing Support", detail: "Blue Logic is a local Utah company. If something comes up after installation, you're calling a real person, not a national service queue." },
          ].map((item) => (
            <div class="flex gap-3">
              <span class="text-primary font-bold text-lg shrink-0 mt-0.5">✓</span>
              <div>
                <div class="font-semibold text-foreground text-sm mb-1">{item.step}</div>
                <p class="text-muted-foreground text-sm leading-relaxed">{item.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Installation Process Roadmap -->
  <ProcessStepper />

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-3xl md:text-4xl font-serif text-center mb-4 text-foreground"
      >
        The Purity Guarantee
      </h2>
      <p class="text-lg text-center text-muted-foreground mb-12">
        When we enter your home, we follow the Blue Logic code of conduct:
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-card p-8 rounded-2xl">
          <h3 class="text-xl font-semibold mb-4 text-foreground">
            Professional Excellence
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Our certified installation partners perform every installation to commercial standards with
            meticulous attention to detail.
          </p>
        </div>

        <div class="bg-card p-8 rounded-2xl">
          <h3 class="text-xl font-semibold mb-4 text-foreground">
            Respect Your Home
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            We treat your home as our own—clean workspace, protective equipment,
            and thorough cleanup.
          </p>
        </div>

        <div class="bg-card p-8 rounded-2xl">
          <h3 class="text-xl font-semibold mb-4 text-foreground">
            Transparent Communication
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Clear explanations of the work, no hidden fees, and honest timelines
            from start to finish.
          </p>
        </div>

        <div class="bg-card p-8 rounded-2xl">
          <h3 class="text-xl font-semibold mb-4 text-foreground">
            Local Accountability
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            We're your neighbors. Our reputation is built on trust and we stand
            behind every system we provide.
          </p>
        </div>

        <div class="bg-card p-8 rounded-2xl">
          <h3 class="text-xl font-semibold mb-4 text-foreground">
            Ongoing Support
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            We don't disappear after installation. Local service and maintenance
            support when you need it.
          </p>
        </div>

        <div class="bg-card p-8 rounded-2xl">
          <h3 class="text-xl font-semibold mb-4 text-foreground">
            Fair Pricing Always
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            No upsells, no pressure tactics. Just honest pricing for honest
            work.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <Reviews max={6} />
    </div>
  </section>

  <!-- Service Area -->
  <section class="bg-background py-12 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-serif mb-4 text-foreground">
        Serving Utah's Wasatch Front
      </h2>
      <p class="text-muted-foreground mb-6 max-w-2xl mx-auto">
        Blue Logic is a Utah company. We serve the Wasatch Front from Ogden to Springville —
        <a href="/locations/" class="text-primary hover:underline font-semibold">every major community</a>
        across Weber, Davis, Salt Lake, and Utah Counties.
      </p>
      <div class="flex flex-wrap justify-center gap-2">
        {["Salt Lake City", "Provo", "Orem", "Lehi", "Sandy", "Draper", "Ogden", "Layton",
          "Bountiful", "American Fork", "Spanish Fork", "Springville",
          "West Jordan", "South Jordan", "Cottonwood Heights"].map((city) => (
          <span class="px-3 py-1.5 bg-card border border-border rounded-full text-sm text-muted-foreground">{city}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Professional Service Image Section -->
  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <h2 class="text-3xl md:text-4xl font-serif mb-6 text-foreground">
            Professional Installation, Premium Results
          </h2>
          <p class="text-lg text-muted-foreground leading-relaxed mb-6">
            Every Blue Logic system is installed by our certified partner technicians
            who treat your home with respect. Clean workspace, careful
            craftsmanship, and meticulous attention to detail.
          </p>
          <p class="text-lg text-muted-foreground leading-relaxed mb-8">
            The result? A <a
              href="/the-system/"
              class="text-primary hover:underline font-semibold"
              >system that integrates seamlessly into your home</a
            > and delivers pure water for years to come.
          </p>
          <a
            href="/free-water-test/"
            class="text-primary font-semibold text-lg hover:opacity-80 transition-opacity"
          >
            Schedule Your Consultation →
          </a>
        </div>
        <div class="order-1 lg:order-2">
          <Image
            src={realtorSinkImg}
            alt="Professional showing a modern kitchen with premium water fixtures and purification system"
            class="rounded-2xl shadow-2xl w-full object-cover aspect-4/3"
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 100vw, 50vw"
            quality={50}
          />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif mb-4 text-foreground">
        Work With a Local Team
      </h2>
      <p class="text-xl text-muted-foreground mb-8">
        Schedule a free consultation with our water quality experts
      </p>
      <a href="/free-water-test/" class="btn btn-primary btn-lg w-full md:w-auto">Get Started</a>
    </div>
  </section>
</Layout>

<style>
  @reference "../styles/global.css";

  .jared-card {
    @apply flex gap-6 items-start bg-background p-6 md:p-8 rounded-2xl border-2 border-primary/20;
  }

  .jared-avatar {
    @apply w-16 h-16 shrink-0 rounded-full bg-primary text-primary-foreground font-bold text-2xl flex items-center justify-center;
  }

  .credential-tag {
    @apply text-xs font-semibold px-3 py-1.5 bg-primary/10 text-primary rounded-full;
  }

  /* kept for ProcessStepper compatibility */
  .team-member {
    @apply bg-background p-8 rounded-2xl text-center;
  }

  .member-icon {
    @apply w-20 h-20 mx-auto mb-6 rounded-full bg-primary/10 text-primary flex items-center justify-center;
  }
</style>
