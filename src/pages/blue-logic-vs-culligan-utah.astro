---
import Layout from "../layouts/Layout.astro";
import LeadForm from "../components/LeadForm.astro";
import Reviews from "../components/Reviews.astro";
import { getFAQSchema, getBreadcrumbSchema } from "../utils/schema";

export const prerender = true;

const siteUrl = "https://www.bluelogicwater.com";

const faqs = [
  {
    question: "Culligan offered me a rental or lease program. Is that a good deal?",
    answer: "Rental and lease programs mean you pay monthly indefinitely rather than building equity in a system you own. Over 7–10 years, those payments often exceed the outright purchase price of a comparable system several times over. Before signing, ask Culligan for the total cost of the agreement over 10 years, what happens at the end of the term, and what it costs to cancel. Then compare that to Blue Logic's outright purchase range of $5,995–$19,999. You own the Blue Logic system from day one.",
  },
  {
    question: "Culligan is a big national brand. Doesn't that mean better quality?",
    answer: "Brand recognition and installation quality are different things. Culligan operates through independently owned and operated dealerships — the Utah dealer is a local franchisee, not a Culligan corporate employee. Quality can vary significantly by franchise location. Blue Logic is owner-operated: Jared conducts the water test, designs your system, leads the installation, and handles annual check-ups personally. There's direct accountability at every step.",
  },
  {
    question: "Culligan requires a service contract. Does Blue Logic?",
    answer: "No. Blue Logic does not require an ongoing service contract. An annual check-up is included and scheduled at the time of installation, but there is no contractual ongoing obligation. After the first year, service visits are available per request at your discretion.",
  },
  {
    question: "A Culligan rep came to my door. Should I trust that sales process?",
    answer: "Door-to-door water treatment sales are a well-known high-pressure environment — the goal of an in-home visit is often to close the sale that day. Blue Logic's free water test is different: we test your water, show you exactly what's in it based on real measurements, give you a transparent written quote, and you take it home to decide at your own pace. No same-day pressure.",
  },
  {
    question: "Can Blue Logic match a written Culligan quote?",
    answer: "Yes. Blue Logic offers a written price-match guarantee on any competing quote from a licensed Utah water treatment company. Bring your written Culligan quote to your free Blue Logic water test and we'll match or beat it.",
  },
];

const schemas = [
  getFAQSchema(faqs),
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Blue Logic vs. Culligan Utah", url: "/blue-logic-vs-culligan-utah/" },
  ]),
];
---

<Layout
  title="Blue Logic vs. Culligan Utah | Before You Sign, Read This"
  description="Got a Culligan quote for Utah water treatment? Understand their rental model, franchise structure, and service contracts before signing. Blue Logic offers a written price-match guarantee. Free water test."
  schema={schemas}
>
  <section class="hero-gradient py-20 md:py-24 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary mb-4">
        Utah Water Treatment · Comparison Guide
      </p>
      <h1 class="text-4xl md:text-5xl font-serif mb-6 text-foreground leading-tight">
        Before You Sign With Culligan — Read This First
      </h1>
      <p class="text-lg md:text-xl text-muted-foreground max-w-3xl mx-auto leading-relaxed">
        Culligan is one of the most aggressively marketed water treatment brands in Utah. If you've
        received a flyer, a door knock, or a call — or if you're already holding a quote — here's
        what to understand before you commit.
      </p>
    </div>
  </section>

  <section class="bg-primary/5 border-y border-primary/20 py-6 px-4">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm text-muted-foreground text-center">
        <strong class="text-foreground">What this page covers:</strong> Blue Logic's verified specs and what to ask Culligan before signing.
        We make no claims about Culligan's pricing — those vary by franchise location. Bring any written quote and Blue Logic will match or beat it.
      </p>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-5xl mx-auto">

      <div class="callout-box mb-12">
        <h2 class="text-2xl font-serif mb-4 text-foreground">The Rental Model: What It Really Costs</h2>
        <p class="text-muted-foreground leading-relaxed mb-4">
          Culligan frequently markets water treatment through rental and lease agreements. Monthly
          payments sound manageable — but over 7–10 years, those payments typically exceed the
          outright purchase price of a comparable system, sometimes by a wide margin. And at the
          end of the term, you may not own the equipment.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          Blue Logic sells systems outright. You own it from the day it's installed. There's no
          monthly payment, no lease term, no question about what happens if you move or cancel.
        </p>
      </div>

      <div class="callout-box mb-12">
        <h2 class="text-2xl font-serif mb-4 text-foreground">Franchise vs. Owner-Operated: Who's Actually Installing Your System</h2>
        <p class="text-muted-foreground leading-relaxed mb-4">
          Culligan operates through independently owned and operated franchises. The local Utah
          Culligan dealer is a franchisee — not a Culligan corporate employee. Franchise quality,
          staffing, and pricing vary significantly by location.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          Blue Logic is owner-operated. Jared conducts the free water test, designs the system
          for your home's specific water profile, leads the installation, and handles annual
          check-ups personally. The same person is accountable from first call through long-term service.
        </p>
      </div>

      <h2 class="text-3xl font-serif text-center mb-4 text-foreground">Blue Logic's Verified System Specs</h2>
      <p class="text-sm text-muted-foreground text-center mb-8">Ask Culligan the same questions and compare the written answers side by side.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-10">
        {[
          { label: "Ownership model", value: "Own outright", note: "No rental, no lease, no monthly payments. Yours from day one." },
          { label: "System price range", value: "$5,995 – $19,999", note: "Full installed price confirmed at free water test. No hidden fees." },
          { label: "NSF-certified components", value: "Yes", note: "NSF/ANSI-rated RO membranes and NSF food-grade storage tanks." },
          { label: "Warranty", value: "1-year limited (parts)", note: "Components designed for 8–10 year service life with annual maintenance." },
          { label: "Service contract required", value: "No", note: "Annual check-up included. No ongoing contractual obligation." },
          { label: "Financing", value: "In-house, half down", note: "Flexible repayment terms. No third-party lender required." },
          { label: "Price match", value: "Written guarantee", note: "Match or beat any written competing quote from a licensed Utah provider." },
          { label: "Who installs", value: "Jared directly", note: "Owner-operated. No subcontractors, no franchise variability." },
        ].map((item) => (
          <div class="spec-card">
            <div class="flex justify-between items-start gap-4 mb-2">
              <span class="font-semibold text-foreground">{item.label}</span>
              <span class="text-primary font-bold shrink-0">{item.value}</span>
            </div>
            <p class="text-xs text-muted-foreground">{item.note}</p>
          </div>
        ))}
      </div>

      <div class="bg-card border border-border rounded-2xl p-6 md:p-8">
        <h2 class="text-2xl font-serif mb-4 text-foreground">Questions to Ask Culligan Before Signing</h2>
        <ul class="space-y-3 text-muted-foreground">
          {[
            "Is this a purchase, a rental, or a lease? What is the total cost over 10 years?",
            "If I sell my home or move, what happens to the system and the contract?",
            "What does the service contract require, and what does it cost annually?",
            "Are all components NSF-certified? Which specific standards and which parts?",
            "Who physically performs the installation — a company employee or a subcontractor?",
            "What is the full installed price in writing, including all components and labor?",
          ].map((q) => (
            <li class="flex gap-3">
              <span class="text-primary font-bold shrink-0 mt-0.5">→</span>
              <span>{q}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-10 text-foreground">Common Questions</h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item group">
            <summary class="faq-question">
              {faq.question}
              <span class="faq-icon group-open:rotate-45 transition-transform">+</span>
            </summary>
            <div class="faq-answer">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <Reviews compact={true} heading="What Utah Homeowners Say About Blue Logic" />
    </div>
  </section>

  <section class="bg-primary/5 py-16 md:py-20 px-4">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-4 text-foreground">
        Get a Second Opinion — No Pressure
      </h2>
      <p class="text-muted-foreground text-center mb-10">
        Blue Logic's free water test measures exactly what's in your water and gives you a
        transparent written quote. If you already have a Culligan quote, bring it — we'll match
        or beat it in writing. You leave with both quotes and make the call at your own pace.
      </p>
      <LeadForm />
    </div>
  </section>
</Layout>

<style>
  @reference "../styles/global.css";

  .hero-gradient {
    @apply bg-linear-to-br from-background to-card;
  }

  .callout-box {
    @apply bg-card border-l-4 border-primary rounded-r-2xl p-6 md:p-8;
  }

  .spec-card {
    @apply bg-card p-5 rounded-xl border border-border;
  }

  .faq-item {
    @apply bg-card border border-border rounded-xl overflow-hidden;
  }

  .faq-question {
    @apply flex justify-between items-center p-6 cursor-pointer font-semibold text-foreground list-none select-none hover:bg-accent/50 transition-colors;
  }

  .faq-question::-webkit-details-marker { display: none; }

  .faq-icon {
    @apply text-2xl text-primary font-light leading-none shrink-0;
  }

  .faq-answer {
    @apply px-6 pb-6 text-muted-foreground leading-relaxed;
  }
</style>
