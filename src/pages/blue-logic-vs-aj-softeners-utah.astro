---
import Layout from "../layouts/Layout.astro";
import LeadForm from "../components/LeadForm.astro";
import Reviews from "../components/Reviews.astro";
import { getFAQSchema, getBreadcrumbSchema } from "../utils/schema";

export const prerender = true;
const siteUrl = "https://www.bluelogicwater.com";

const faqs = [
  {
    question: "Should I compare Blue Logic and AJ Softeners before deciding?",
    answer: "Yes — and Blue Logic's price-match guarantee makes it low-risk. If you have a written AJ Softeners quote, bring it to your free Blue Logic water test. Blue Logic will match or beat any written competing quote from a licensed Utah water treatment company.",
  },
  {
    question: "Is there a difference between a water softener company and what Blue Logic does?",
    answer: "Water softening addresses hardness minerals (calcium and magnesium) only. Blue Logic's whole-home systems include integrated water softening as one of multiple treatment stages — also addressing chlorine, chloramines, iron, manganese, and with the RO upgrade, arsenic and PFAS. Whether you need that broader coverage depends on what's in your specific water. A free water test answers that.",
  },
  {
    question: "How do I verify Blue Logic's system quality?",
    answer: "Ask for NSF certification documentation on all components at your free water test. Blue Logic uses NSF/ANSI-rated RO membranes and food-grade storage tanks. The 1-year limited warranty covers parts; components are designed for an 8–10 year service life with annual maintenance.",
  },
  {
    question: "Does Blue Logic offer financing?",
    answer: "Yes. In-house financing with half down and flexible repayment terms. No third-party lender required.",
  },
];

const schemas = [
  getFAQSchema(faqs),
  getBreadcrumbSchema(siteUrl, [
    { name: "Home", url: "/" },
    { name: "Blue Logic vs. AJ Softeners Utah", url: "/blue-logic-vs-aj-softeners-utah/" },
  ]),
];
---

<Layout
  title="Blue Logic vs. AJ Softeners Utah | Get Both Quotes and Compare"
  description="Considering AJ Softeners for Utah water treatment? Here's what Blue Logic offers — whole-home filtration and RO with a written price-match guarantee. Free water test."
  schema={schemas}
>
  <section class="hero-gradient py-20 md:py-24 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary mb-4">Utah Water Treatment · Comparison Guide</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-6 text-foreground leading-tight">
        Considering AJ Softeners? Here's What Blue Logic Offers.
      </h1>
      <p class="text-lg md:text-xl text-muted-foreground max-w-3xl mx-auto leading-relaxed">
        If AJ Softeners is on your list, getting both quotes before committing is the most
        informed approach. Blue Logic's written price-match guarantee means there's no financial
        risk in getting a second opinion.
      </p>
    </div>
  </section>

  <section class="bg-primary/5 border-y border-primary/20 py-6 px-4">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm text-muted-foreground text-center">
        <strong class="text-foreground">What this page covers:</strong> Blue Logic's own verified specs and offers.
        We make no claims about AJ Softeners' pricing or system terms. Bring any written quote and Blue Logic will match or beat it.
      </p>
    </div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-4 text-foreground">Blue Logic's Verified System Specs</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-10">
        {[
          { label: "System price range", value: "$5,995 – $19,999", note: "Confirmed at free water test. No hidden fees." },
          { label: "NSF-certified components", value: "Yes", note: "NSF/ANSI-rated membranes and food-grade tanks." },
          { label: "Warranty", value: "1-year limited (parts)", note: "Components designed for 8–10 year lifespan." },
          { label: "Service contract required", value: "No", note: "Annual check-up included. No contractual obligation." },
          { label: "Financing", value: "In-house, half down", note: "Flexible terms. No third-party lender." },
          { label: "Price match", value: "Written guarantee", note: "Match or beat any written competing quote." },
          { label: "System scope", value: "Softening + filtration + optional RO", note: "Addresses hardness, chlorine, iron, manganese — and arsenic/PFAS with RO upgrade." },
          { label: "Free water test", value: "Yes — no obligation", note: "Confirms exactly what's in your specific home's water." },
        ].map((item) => (
          <div class="spec-card">
            <div class="flex justify-between items-start gap-4 mb-2">
              <span class="font-semibold text-foreground">{item.label}</span>
              <span class="text-primary font-bold shrink-0">{item.value}</span>
            </div>
            <p class="text-xs text-muted-foreground">{item.note}</p>
          </div>
        ))}
      </div>
      <div class="bg-card rounded-2xl border-2 border-primary p-6 text-center">
        <h3 class="text-xl font-semibold text-foreground mb-3">Price-Match Guarantee</h3>
        <p class="text-muted-foreground mb-4">Bring your written AJ Softeners quote. Blue Logic will match or beat it in writing for a comparable system.</p>
        <a href="/free-water-test/" class="inline-block bg-primary text-primary-foreground font-semibold px-8 py-4 rounded-full shadow hover:bg-primary/90 transition-all">Schedule Free Water Test →</a>
      </div>
    </div>
  </section>

  <section class="bg-card py-16 md:py-20 px-4">
    <div class="max-w-6xl mx-auto"><Reviews max={4} compact={true} /></div>
  </section>

  <section class="bg-background py-16 md:py-20 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-10 text-foreground">Common Questions</h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item group">
            <summary class="faq-question">{faq.question}<span class="faq-icon group-open:rotate-45 transition-transform">+</span></summary>
            <div class="faq-answer">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-card py-10 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/blue-logic-vs-culligan-utah/" class="related-link">vs. Culligan</a>
        <a href="/blue-logic-vs-kinetico-utah/" class="related-link">vs. Kinetico</a>
        <a href="/water-softener-vs-whole-home-filtration/" class="related-link">Compare All Systems</a>
        <a href="/free-water-test/" class="related-link">Free Water Test</a>
      </div>
    </div>
  </section>

  <section class="bg-primary/5 py-16 md:py-20 px-4">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-serif text-center mb-4 text-foreground">Get a Second Quote — Free</h2>
      <p class="text-muted-foreground text-center mb-10">Have a quote from AJ Softeners? Bring it. Blue Logic will match or beat any written offer from a licensed Utah water treatment company.</p>
      <LeadForm />
    </div>
  </section>
</Layout>

<style>
  @reference "../styles/global.css";
  .spec-card { @apply bg-card p-5 rounded-xl border border-border; }
  .related-link { @apply px-4 py-2 bg-background border border-border rounded-full text-sm text-primary font-medium hover:border-primary transition-colors; }
  .faq-item { @apply bg-card border border-border rounded-xl overflow-hidden; }
  .faq-question { @apply flex justify-between items-center p-6 cursor-pointer font-semibold text-foreground list-none select-none hover:bg-accent/50 transition-colors; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-icon { @apply text-2xl text-primary font-light leading-none shrink-0; }
  .faq-answer { @apply px-6 pb-6 text-muted-foreground leading-relaxed; }
</style>
