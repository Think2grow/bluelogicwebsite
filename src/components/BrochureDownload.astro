---
import brochurePure from "/print_material/BL Brochure WH-Pure v3.1 FINAL.pdf";
import brochureFiltration from "/print_material/Filtration Brochure v1 FINAL.pdf";
---

<div class="mt-12">
  <h3 class="text-2xl font-serif mb-4 text-foreground">
    Download Our Brochures
  </h3>
  <div class="flex flex-col sm:flex-row justify-center gap-4">
    <a
      href={brochurePure}
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-secondary"
    >
      Whole-Home Purification Brochure
    </a>
    <a
      href={brochureFiltration}
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-secondary"
    >
      7-Layer Filtration Brochure
    </a>
  </div>
</div>
