---
// Header component with responsive navigation
import logo from "../assets/Blue Logic Logo FINAL-03.png";
import { Picture } from "astro:assets";
---

<header
  class="bg-background border-b border-border sticky top-0 z-50 px-4 py-4 md:px-8"
>
  <nav
    class="max-w-7xl mx-auto flex justify-between items-center gap-8"
    aria-label="Main navigation"
  >
    <a
      href="/"
      class="text-2xl font-bold text-foreground no-underline hover:text-primary transition-colors"
    >
      <Picture
        src={logo}
        formats={["avif", "webp", "png"]}
        alt="Blue Logic Water"
        class="h-10 w-18 inline-block mr-2"
        quality={75}
        loading={"eager"}
      />
    </a>

    <!-- Desktop Navigation -->
    <ul class="hidden md:flex gap-8 list-none m-0 p-0">
      <li>
        <a
          href="/"
          class="text-foreground no-underline hover:text-primary transition-colors"
          >Home</a
        >
      </li>
      <li>
        <a
          href="/the-system"
          class="text-foreground no-underline hover:text-primary transition-colors"
          >The System</a
        >
      </li>
      <li>
        <a
          href="/the-value"
          class="text-foreground no-underline hover:text-primary transition-colors"
          >Why Us</a
        >
      </li>
      <li>
        <a
          href="/our-team"
          class="text-foreground no-underline hover:text-primary transition-colors"
          >Our Team</a
        >
      </li>
      <li>
        <a
          href="/common-questions"
          class="text-foreground no-underline hover:text-primary transition-colors"
          >FAQ</a
        >
      </li>
      <li>
        <a
          href="/salt-lake-city"
          class="text-foreground no-underline hover:text-primary transition-colors"
          >Salt Lake City</a
        >
      </li>
    </ul>

    <!-- Mobile Menu Button -->
    <button
      class="mobile-menu-btn md:hidden flex flex-col justify-center gap-[5px] w-11 h-11 p-2.5 bg-transparent border-none cursor-pointer z-[101]"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-sidebar"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </nav>
</header>

<!-- Mobile Sidebar Overlay -->
<div class="sidebar-overlay" aria-hidden="true"></div>

<!-- Mobile Sidebar -->
<aside
  id="mobile-sidebar"
  class="mobile-sidebar"
  aria-label="Mobile navigation"
  aria-hidden="true"
>
  <div class="sidebar-header">
    <span class="text-xl font-bold text-foreground">Blue Logic Water</span>
    <button class="sidebar-close-btn" aria-label="Close menu">
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <nav class="sidebar-nav">
    <ul class="sidebar-links">
      <li><a href="/">Home</a></li>
      <li><a href="/the-system">The System</a></li>
      <li><a href="/the-value">Why Us</a></li>
      <li><a href="/our-team">Our Team</a></li>
      <li><a href="/common-questions">FAQ</a></li>
      <li><a href="/salt-lake-city">Salt Lake City</a></li>
    </ul>
  </nav>

  <div class="sidebar-footer">
    <a href="/#contact" class="sidebar-cta">Get Started</a>
    <div class="sidebar-contact">
      <a href="tel:+18382322583">(838) 232-2583</a>
      <a href="mailto:info@bluelogicwater.com">info@bluelogicwater.com</a>
    </div>
  </div>
</aside>

<style>
  @reference "../styles/global.css";

  /* Mobile Menu Button - hamburger lines */
  .hamburger-line {
    @apply block w-6 h-0.5 bg-foreground rounded-sm transition-all duration-300 ease-[cubic-bezier(0.4,0,0.2,1)] origin-center;
  }

  /* Hamburger to X animation */
  .mobile-menu-btn[aria-expanded="true"] .hamburger-line:nth-child(1) {
    @apply translate-y-[7px] rotate-45;
  }

  .mobile-menu-btn[aria-expanded="true"] .hamburger-line:nth-child(2) {
    @apply opacity-0 scale-x-0;
  }

  .mobile-menu-btn[aria-expanded="true"] .hamburger-line:nth-child(3) {
    @apply -translate-y-[7px] -rotate-45;
  }

  /* Sidebar Overlay */
  .sidebar-overlay {
    @apply fixed inset-0 bg-black/0 backdrop-blur-none z-[199] pointer-events-none transition-all duration-400 ease-[cubic-bezier(0.4,0,0.2,1)];
  }

  .sidebar-overlay.active {
    @apply bg-black/40 backdrop-blur-sm pointer-events-auto;
  }

  /* Mobile Sidebar */
  .mobile-sidebar {
    @apply fixed top-0 right-0 w-[min(320px,85vw)] h-dvh bg-background z-[200] flex flex-col translate-x-full transition-transform duration-400 ease-[cubic-bezier(0.4,0,0.2,1)] shadow-none;
  }

  .mobile-sidebar.active {
    @apply translate-x-0;
    box-shadow: -8px 0 32px rgba(0, 0, 0, 0.15);
  }

  .sidebar-header {
    @apply flex justify-between items-center px-6 py-5 border-b border-border;
  }

  .sidebar-close-btn {
    @apply flex items-center justify-center w-11 h-11 bg-transparent border-none cursor-pointer text-foreground rounded-full transition-colors hover:bg-muted;
  }

  .sidebar-nav {
    @apply flex-1 py-6 overflow-y-auto;
  }

  .sidebar-links {
    @apply list-none m-0 p-0;
  }

  .sidebar-links li {
    @apply opacity-0 translate-x-5 transition-all duration-300 ease-out;
  }

  .mobile-sidebar.active .sidebar-links li {
    @apply opacity-100 translate-x-0;
  }

  /* Stagger animation for menu items */
  .mobile-sidebar.active .sidebar-links li:nth-child(1) {
    transition-delay: 0.1s;
  }
  .mobile-sidebar.active .sidebar-links li:nth-child(2) {
    transition-delay: 0.15s;
  }
  .mobile-sidebar.active .sidebar-links li:nth-child(3) {
    transition-delay: 0.2s;
  }
  .mobile-sidebar.active .sidebar-links li:nth-child(4) {
    transition-delay: 0.25s;
  }
  .mobile-sidebar.active .sidebar-links li:nth-child(5) {
    transition-delay: 0.3s;
  }
  .mobile-sidebar.active .sidebar-links li:nth-child(6) {
    transition-delay: 0.35s;
  }

  .sidebar-links a {
    @apply block px-6 py-4 text-foreground no-underline text-lg font-medium transition-all duration-200 hover:bg-muted hover:text-primary;
  }

  .sidebar-footer {
    @apply px-6 py-6 border-t border-border opacity-0 translate-y-2.5 transition-all duration-300 ease-out;
    transition-delay: 0.3s;
  }

  .mobile-sidebar.active .sidebar-footer {
    @apply opacity-100 translate-y-0;
  }

  .sidebar-cta {
    @apply block w-full py-4 bg-primary text-primary-foreground no-underline text-center font-semibold rounded-lg transition-all duration-200 hover:opacity-90 hover:scale-[1.02];
  }

  .sidebar-contact {
    @apply flex flex-col gap-2 mt-4 text-center;
  }

  .sidebar-contact a {
    @apply text-foreground no-underline text-sm opacity-70 transition-opacity duration-200 hover:opacity-100;
  }

  @media (min-width: 769px) {
    .mobile-sidebar,
    .sidebar-overlay {
      @apply hidden;
    }
  }
</style>

<script>
  // Mobile sidebar functionality - using module script for proper lifecycle
  function initMobileSidebar() {
    const menuBtn = document.querySelector(
      ".mobile-menu-btn",
    ) as HTMLButtonElement | null;
    const sidebar = document.querySelector(
      ".mobile-sidebar",
    ) as HTMLElement | null;
    const overlay = document.querySelector(
      ".sidebar-overlay",
    ) as HTMLElement | null;
    const closeBtn = document.querySelector(
      ".sidebar-close-btn",
    ) as HTMLButtonElement | null;
    const sidebarLinks = document.querySelectorAll(
      ".sidebar-links a, .sidebar-cta",
    );

    if (!menuBtn || !sidebar || !overlay || !closeBtn) {
      console.warn("Mobile sidebar elements not found");
      return;
    }

    // Remove any existing listeners by cloning elements
    const newMenuBtn = menuBtn.cloneNode(true) as HTMLButtonElement;
    const newCloseBtn = closeBtn.cloneNode(true) as HTMLButtonElement;
    const newOverlay = overlay.cloneNode(true) as HTMLElement;

    menuBtn.parentNode?.replaceChild(newMenuBtn, menuBtn);
    closeBtn.parentNode?.replaceChild(newCloseBtn, closeBtn);
    overlay.parentNode?.replaceChild(newOverlay, overlay);

    function openSidebar() {
      newMenuBtn.setAttribute("aria-expanded", "true");
      sidebar!.classList.add("active");
      sidebar!.setAttribute("aria-hidden", "false");
      newOverlay.classList.add("active");
      newOverlay.setAttribute("aria-hidden", "false");
      document.body.classList.add("sidebar-open");

      // Focus the close button for accessibility
      setTimeout(() => newCloseBtn.focus(), 100);
    }

    function closeSidebar() {
      newMenuBtn.setAttribute("aria-expanded", "false");
      sidebar!.classList.remove("active");
      sidebar!.setAttribute("aria-hidden", "true");
      newOverlay.classList.remove("active");
      newOverlay.setAttribute("aria-hidden", "true");
      document.body.classList.remove("sidebar-open");

      // Return focus to menu button
      newMenuBtn.focus();
    }

    // Use touchend for mobile to avoid 300ms delay, with click fallback
    function handleMenuToggle(e: Event) {
      e.preventDefault();
      e.stopPropagation();
      const isExpanded = newMenuBtn.getAttribute("aria-expanded") === "true";
      if (isExpanded) {
        closeSidebar();
      } else {
        openSidebar();
      }
    }

    // Add both touch and click handlers for better mobile support
    newMenuBtn.addEventListener("click", handleMenuToggle);
    newMenuBtn.addEventListener("touchend", handleMenuToggle, {
      passive: false,
    });

    newCloseBtn.addEventListener("click", (e) => {
      e.preventDefault();
      closeSidebar();
    });
    newCloseBtn.addEventListener(
      "touchend",
      (e) => {
        e.preventDefault();
        closeSidebar();
      },
      { passive: false },
    );

    newOverlay.addEventListener("click", closeSidebar);
    newOverlay.addEventListener(
      "touchend",
      (e) => {
        e.preventDefault();
        closeSidebar();
      },
      { passive: false },
    );

    // Close on link click
    sidebarLinks.forEach((link) => {
      link.addEventListener("click", closeSidebar);
    });

    // Close on escape key
    function handleEscape(e: KeyboardEvent) {
      if (e.key === "Escape" && sidebar!.classList.contains("active")) {
        closeSidebar();
      }
    }
    document.removeEventListener("keydown", handleEscape);
    document.addEventListener("keydown", handleEscape);

    // Handle resize - close sidebar if window becomes large
    function handleResize() {
      if (window.innerWidth > 768 && sidebar!.classList.contains("active")) {
        closeSidebar();
      }
    }
    window.removeEventListener("resize", handleResize);
    window.addEventListener("resize", handleResize);
  }

  // Initialize when DOM is ready
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initMobileSidebar);
  } else {
    initMobileSidebar();
  }

  // Re-initialize after Astro View Transitions
  document.addEventListener("astro:page-load", initMobileSidebar);
</script>
