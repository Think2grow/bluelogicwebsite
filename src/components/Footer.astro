---
// Footer component
---

<footer class="bg-obsidian text-white mt-16">
  <div class="max-w-7xl mx-auto px-6 py-12 lg:py-16">
    <!-- Top Row: Logo and Socials -->
    <div
      class="flex flex-col md:flex-row justify-between items-center gap-6 mb-12"
    >
      <!-- Company Logo -->
      <a href="/" class="block">
        <img
          src="/Blue Logic Logo FINAL-02.png"
          alt="Blue Logic Water"
          class="h-12 md:h-14 w-auto brightness-0 invert"
        />
      </a>

      <!-- Social Links -->
      <div class="flex items-center gap-4">
        <a
          href="https://www.facebook.com/BlueLogicWater"
          target="_blank"
          rel="noopener noreferrer"
          class="group p-3 rounded-full bg-white/10 hover:bg-glacier transition-all duration-300"
          aria-label="Follow us on Facebook"
        >
          <svg
            class="w-5 h-5 fill-current text-white"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
            ></path>
          </svg>
        </a>
        <a
          href="https://www.instagram.com/bluelogicwater/"
          target="_blank"
          rel="noopener noreferrer"
          class="group p-3 rounded-full bg-white/10 hover:bg-glacier transition-all duration-300"
          aria-label="Follow us on Instagram"
        >
          <svg
            class="w-5 h-5 fill-current text-white"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
            ></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Middle Row: Link Columns -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-16 mb-12">
      <!-- Product Column -->
      <div>
        <h3
          class="text-sm font-semibold uppercase tracking-wider text-glacier mb-4"
        >
          Product
        </h3>
        <ul class="space-y-3">
          <li>
            <a
              href="/the-system"
              class="text-white/70 hover:text-white transition-colors duration-200"
            >
              The System
            </a>
          </li>
          <li>
            <a
              href="/the-value"
              class="text-white/70 hover:text-white transition-colors duration-200"
            >
              Why Us
            </a>
          </li>
          <li>
            <a
              href="/common-questions"
              class="text-white/70 hover:text-white transition-colors duration-200"
            >
              FAQ
            </a>
          </li>
        </ul>
      </div>

      <!-- Company Column -->
      <div>
        <h3
          class="text-sm font-semibold uppercase tracking-wider text-glacier mb-4"
        >
          Company
        </h3>
        <ul class="space-y-3">
          <li>
            <a
              href="/our-team"
              class="text-white/70 hover:text-white transition-colors duration-200"
            >
              Our Team
            </a>
          </li>
          <li>
            <a
              href="/locations/salt-lake-city"
              class="text-white/70 hover:text-white transition-colors duration-200"
            >
              Salt Lake City
            </a>
          </li>
          <li>
            <a
              href="/locations/park-city"
              class="text-white/70 hover:text-white transition-colors duration-200"
            >
              Park City
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact Us Column -->
      <div>
        <h3
          class="text-sm font-semibold uppercase tracking-wider text-glacier mb-4"
        >
          Contact Us
        </h3>
        <ul class="space-y-3">
          <li>
            <a
              href="tel:+18382322583"
              class="text-white/70 hover:text-white transition-colors duration-200 flex items-center gap-2"
            >
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
              (838) 232-2583
            </a>
          </li>
          <li>
            <a
              href="mailto:info@bluelogicwater.com"
              class="text-white/70 hover:text-white transition-colors duration-200 flex items-center gap-2"
            >
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
              info@bluelogicwater.com
            </a>
          </li>
          <li>
            <a
              href="/#contact"
              class="inline-flex items-center gap-2 mt-2 px-5 py-2.5 bg-glacier text-white font-medium rounded-lg hover:bg-glacier/90 transition-all duration-200"
            >
              Get a Quote
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-white/20"></div>

    <!-- Bottom Row: Legal Links and Copyright -->
    <div
      class="flex flex-col md:flex-row justify-between items-center gap-4 pt-8"
    >
      <div class="flex flex-wrap justify-center md:justify-start gap-6 text-sm">
        <a
          href="/privacy"
          class="text-white/60 hover:text-white transition-colors duration-200"
        >
          Privacy Policy
        </a>
        <a
          href="/terms"
          class="text-white/60 hover:text-white transition-colors duration-200"
        >
          Terms & Conditions
        </a>
      </div>
      <p class="text-white/50 text-sm">
        © 2025 Blue Logic Water. All rights reserved.
      </p>
    </div>
  </div>
</footer>
