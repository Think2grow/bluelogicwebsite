---
// Basic lead capture form component
---

<div class="max-w-xl mx-auto my-16 px-6 py-10 bg-card rounded-2xl" id="contact">
  <h2 class="text-3xl font-serif text-center mb-2">
    Get Your Free Water Purity Audit
  </h2>
  <p class="text-center text-muted-foreground mb-8">
    Schedule a consultation with our team
  </p>

  <iframe
    src="https://bl.bluelogicwater.com/widget/form/IhMJa3xffx3UO7sBRf5h"
    style="width:100%;height:100%;border:none;border-radius:3px"
    id="inline-IhMJa3xffx3UO7sBRf5h"
    data-layout="{'id':'INLINE'}"
    data-trigger-type="alwaysShow"
    data-trigger-value=""
    data-activation-type="alwaysActivated"
    data-activation-value=""
    data-deactivation-type="neverDeactivate"
    data-deactivation-value=""
    data-form-name="Website Contact Form"
    data-height="493"
    data-layout-iframe-id="inline-IhMJa3xffx3UO7sBRf5h"
    data-form-id="IhMJa3xffx3UO7sBRf5h"
    title="Website Contact Form"
  >
  </iframe>
  <script src="https://bl.bluelogicwater.com/js/form_embed.js"></script>
</div>

<style>
  @reference "../styles/global.css";
  .input-field {
    @apply px-4 py-3 border-2 border-border rounded-lg text-base font-sans bg-background transition-colors focus:outline-none focus:border-ring;
  }

  .form-status {
    @apply text-center p-4 rounded-lg hidden;
  }

  .form-status.success {
    @apply block bg-success-light text-success;
  }

  .form-status.error {
    @apply block bg-error-light text-error;
  }
</style>

<script>
  const form = document.getElementById("leadForm") as HTMLFormElement;
  const status = document.getElementById("formStatus") as HTMLDivElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const submitButton = form.querySelector(
      'button[type="submit"]'
    ) as HTMLButtonElement;
    submitButton.disabled = true;
    submitButton.textContent = "Submitting...";

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const response = await fetch("/api/lead", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (response.ok) {
        status.className = "form-status success";
        status.textContent =
          "Thank you! We'll contact you shortly to schedule your water audit.";
        form.reset();
      } else {
        throw new Error(result.error || "Submission failed");
      }
    } catch (error) {
      status.className = "form-status error";
      status.textContent =
        "Something went wrong. Please try again or call us directly.";
      console.error("Form submission error:", error);
    } finally {
      submitButton.disabled = false;
      submitButton.textContent = "Schedule Audit";
    }
  });
</script>
