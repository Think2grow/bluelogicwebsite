---
// Basic lead capture form component

interface Props {
  compact?: boolean;
  variant?: "default" | "premium";
}

const { compact = false, variant = "default" } = Astro.props;
---

<div
  class:list={[
    variant === "premium"
      ? compact
        ? "relative w-full px-7 py-9 rounded-3xl border border-primary/20 bg-card/80 shadow-2xl backdrop-blur"
        : "relative max-w-xl mx-auto my-16 px-7 py-10 rounded-3xl border border-primary/20 bg-card/80 shadow-2xl backdrop-blur"
      : compact
        ? "w-full px-6 py-8 bg-card rounded-2xl border border-border shadow-sm"
        : "max-w-xl mx-auto my-16 px-6 py-10 bg-card rounded-2xl",
  ]}
  id="contact"
>
  {
    variant === "premium" && (
      <>
        <div class="pointer-events-none absolute -inset-px rounded-3xl bg-linear-to-b from-primary/25 via-primary/10 to-transparent" />
        <div class="pointer-events-none absolute inset-0 rounded-3xl ring-1 ring-white/60" />
      </>
    )
  }

  <div class={variant === "premium" ? "relative" : undefined}>
  <h2 class="text-3xl font-serif text-center mb-2">
    Know Your Water. Protect Your Home.
  </h2>
  <p class="text-center text-muted-foreground mb-8">
    Schedule a consultation with our team
  </p>
  <p class="text-center text-sm text-muted-foreground mb-8">
    Prefer to talk now?
    <a
      href="tel:+18382322583"
      class="font-semibold text-primary hover:text-primary/80 transition-colors"
    >
      Call or text (838) 232-2583
    </a>
  </p>

  <form id="leadForm" class="space-y-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label for="firstName" class="block text-sm font-medium mb-2">First Name</label>
        <input
          type="text"
          id="firstName"
          name="firstName"
          required
          class="input-field w-full"
          placeholder="John"
        />
      </div>
      <div>
        <label for="lastName" class="block text-sm font-medium mb-2">Last Name</label>
        <input
          type="text"
          id="lastName"
          name="lastName"
          required
          class="input-field w-full"
          placeholder="Smith"
        />
      </div>
    </div>

    <div>
      <label for="email" class="block text-sm font-medium mb-2">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="input-field w-full"
        placeholder="john@example.com"
      />
    </div>

    <div>
      <label for="phone" class="block text-sm font-medium mb-2">Phone</label>
      <input
        type="tel"
        id="phone"
        name="phone"
        required
        class="input-field w-full"
        placeholder="(555) 123-4567"
      />
    </div>

    <div>
      <label for="zip" class="block text-sm font-medium mb-2">Zip Code</label>
      <input
        type="text"
        id="zip"
        name="zip"
        required
        pattern="[0-9]{5}"
        class="input-field w-full"
        placeholder="84101"
      />
    </div>

    <button
      type="submit"
      class:list={[
        "w-full font-semibold py-4 px-6 transition-all duration-300",
        variant === "premium"
          ? "rounded-xl font-serif tracking-wide text-white bg-linear-to-r from-glacier to-glacier-dark hover:from-glacier-dark hover:to-glacier shadow-lg hover:shadow-xl transform hover:scale-[1.01] active:scale-[0.99]"
          : "rounded-lg bg-glacier hover:bg-glacier/90 text-white transition-colors duration-200",
      ]}
    >
      Schedule Audit
    </button>

    <div id="formStatus" class="form-status"></div>
  </form>

  </div>
</div>

<style>
  @reference "../styles/global.css";
  .input-field {
    @apply px-4 py-3 border-2 border-border rounded-lg text-base font-sans bg-background transition-colors focus:outline-none focus:border-ring;
  }

  .form-status {
    @apply text-center p-4 rounded-lg hidden;
  }

  .form-status.success {
    @apply block bg-success-light text-success;
  }

  .form-status.error {
    @apply block bg-error-light text-error;
  }
</style>

<script>
  const form = document.getElementById("leadForm") as HTMLFormElement;
  const status = document.getElementById("formStatus") as HTMLDivElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const submitButton = form.querySelector(
      'button[type="submit"]',
    ) as HTMLButtonElement;
    submitButton.disabled = true;
    submitButton.textContent = "Submitting...";

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const response = await fetch("https://services.leadconnectorhq.com/hooks/Nd8el709gXwDJdVuixdV/webhook-trigger/ea841b49-85b0-436e-b298-541b997461c0", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(data),
      });

      if (response.ok || response.status === 200) {
        // Redirect to thank you page
        window.location.href = "/thank-you";
      } else {
        throw new Error("Submission failed");
      }
    } catch (error) {
      status.className = "form-status error";
      status.textContent =
        "Something went wrong. Please try again or call us directly.";
      console.error("Form submission error:", error);
    } finally {
      submitButton.disabled = false;
      submitButton.textContent = "Schedule Audit";
    }
  });
</script>
