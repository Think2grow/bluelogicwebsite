---
// Basic lead capture form component
---

<div class="max-w-xl mx-auto my-16 px-6 py-10 bg-card rounded-2xl" id="contact">
  <h2 class="text-3xl font-serif text-center mb-2">
    Know Your Water. Protect Your Home.
  </h2>
  <p class="text-center text-muted-foreground mb-8">
    Schedule a consultation with our team
  </p>

  <form id="leadForm" class="space-y-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label for="firstName" class="block text-sm font-medium mb-2">First Name</label>
        <input
          type="text"
          id="firstName"
          name="firstName"
          required
          class="input-field w-full"
          placeholder="John"
        />
      </div>
      <div>
        <label for="lastName" class="block text-sm font-medium mb-2">Last Name</label>
        <input
          type="text"
          id="lastName"
          name="lastName"
          required
          class="input-field w-full"
          placeholder="Smith"
        />
      </div>
    </div>

    <div>
      <label for="email" class="block text-sm font-medium mb-2">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="input-field w-full"
        placeholder="john@example.com"
      />
    </div>

    <div>
      <label for="phone" class="block text-sm font-medium mb-2">Phone</label>
      <input
        type="tel"
        id="phone"
        name="phone"
        required
        class="input-field w-full"
        placeholder="(555) 123-4567"
      />
    </div>

    <div>
      <label for="zip" class="block text-sm font-medium mb-2">Zip Code</label>
      <input
        type="text"
        id="zip"
        name="zip"
        required
        pattern="[0-9]{5}"
        class="input-field w-full"
        placeholder="84101"
      />
    </div>

    <button
      type="submit"
      class="w-full bg-glacier hover:bg-glacier/90 text-white font-semibold py-4 px-6 rounded-lg transition-colors duration-200"
    >
      Schedule Audit
    </button>

    <div id="formStatus" class="form-status"></div>
  </form>
</div>

<style>
  @reference "../styles/global.css";
  .input-field {
    @apply px-4 py-3 border-2 border-border rounded-lg text-base font-sans bg-background transition-colors focus:outline-none focus:border-ring;
  }

  .form-status {
    @apply text-center p-4 rounded-lg hidden;
  }

  .form-status.success {
    @apply block bg-success-light text-success;
  }

  .form-status.error {
    @apply block bg-error-light text-error;
  }
</style>

<script>
  const form = document.getElementById("leadForm") as HTMLFormElement;
  const status = document.getElementById("formStatus") as HTMLDivElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const submitButton = form.querySelector(
      'button[type="submit"]',
    ) as HTMLButtonElement;
    submitButton.disabled = true;
    submitButton.textContent = "Submitting...";

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const response = await fetch("https://services.leadconnectorhq.com/hooks/Nd8el709gXwDJdVuixdV/webhook-trigger/ea841b49-85b0-436e-b298-541b997461c0", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(data),
      });

      if (response.ok || response.status === 200) {
        status.className = "form-status success";
        status.textContent =
          "Thank you! We'll contact you shortly to schedule your water audit.";
        form.reset();
      } else {
        throw new Error("Submission failed");
      }
    } catch (error) {
      status.className = "form-status error";
      status.textContent =
        "Something went wrong. Please try again or call us directly.";
      console.error("Form submission error:", error);
    } finally {
      submitButton.disabled = false;
      submitButton.textContent = "Schedule Audit";
    }
  });
</script>
