---
// Basic lead capture form component
---

<div class="max-w-xl mx-auto my-16 px-6 py-10 bg-card rounded-2xl" id="contact">
  <h2 class="text-3xl font-serif text-center mb-2">
    Get Your Free Water Purity Audit
  </h2>
  <p class="text-center text-muted-foreground mb-8">
    Schedule a consultation with our team
  </p>

  <form id="leadForm" class="flex flex-col gap-6">
    <div class="flex flex-col gap-2">
      <label for="name" class="font-semibold text-sm uppercase tracking-wider"
        >Full Name *</label
      >
      <input type="text" id="name" name="name" required class="input-field" />
    </div>

    <div class="flex flex-col gap-2">
      <label for="email" class="font-semibold text-sm uppercase tracking-wider"
        >Email *</label
      >
      <input
        type="email"
        id="email"
        name="email"
        required
        class="input-field"
      />
    </div>

    <div class="flex flex-col gap-2">
      <label for="phone" class="font-semibold text-sm uppercase tracking-wider"
        >Phone *</label
      >
      <input type="tel" id="phone" name="phone" required class="input-field" />
    </div>

    <div class="flex flex-col gap-2">
      <label
        for="address"
        class="font-semibold text-sm uppercase tracking-wider">Address</label
      >
      <input type="text" id="address" name="address" class="input-field" />
    </div>

    <div class="flex flex-col gap-2">
      <label for="city" class="font-semibold text-sm uppercase tracking-wider"
        >City</label
      >
      <input
        type="text"
        id="city"
        name="city"
        value="Salt Lake City"
        class="input-field"
      />
    </div>

    <div class="flex flex-col gap-2">
      <label
        for="message"
        class="font-semibold text-sm uppercase tracking-wider">Message</label
      >
      <textarea
        id="message"
        name="message"
        rows="4"
        class="input-field resize-y"></textarea>
    </div>

    <button type="submit" class="btn btn-primary btn-lg mt-2"
      >Schedule Audit</button
    >

    <div id="formStatus" class="form-status"></div>
  </form>
</div>

<style>
  @reference "../styles/global.css";
  .input-field {
    @apply px-4 py-3 border-2 border-border rounded-lg text-base font-sans bg-background transition-colors focus:outline-none focus:border-ring;
  }

  .form-status {
    @apply text-center p-4 rounded-lg hidden;
  }

  .form-status.success {
    @apply block bg-success-light text-success;
  }

  .form-status.error {
    @apply block bg-error-light text-error;
  }
</style>

<script>
  const form = document.getElementById("leadForm") as HTMLFormElement;
  const status = document.getElementById("formStatus") as HTMLDivElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const submitButton = form.querySelector(
      'button[type="submit"]',
    ) as HTMLButtonElement;
    submitButton.disabled = true;
    submitButton.textContent = "Submitting...";

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const response = await fetch("/api/lead", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (response.ok) {
        status.className = "form-status success";
        status.textContent =
          "Thank you! We'll contact you shortly to schedule your water audit.";
        form.reset();
      } else {
        throw new Error(result.error || "Submission failed");
      }
    } catch (error) {
      status.className = "form-status error";
      status.textContent =
        "Something went wrong. Please try again or call us directly.";
      console.error("Form submission error:", error);
    } finally {
      submitButton.disabled = false;
      submitButton.textContent = "Schedule Audit";
    }
  });
</script>
