---
/**
 * ParallaxHero Component (static, performance-optimized)
 *
 * Renders fully in server HTML so the LCP hero image + heading paint
 * immediately — no React/Framer Motion hydration in the critical path.
 * Entrance animations are CSS-only and respect prefers-reduced-motion.
 */
import { getImage } from "astro:assets";
import heroImageSrc from "../assets/water_art/AdobeStock_689029947_toddler_with_water.jpeg";

interface Props {
  title?: string;
  subtitle?: string;
  tagline?: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  title = "Your Family, Unfiltered.",
  subtitle = "Professional reverse osmosis systems for the health-conscious home",
  tagline = "Half the cost. Half the footprint. 10x quieter.",
  ctaText = "Schedule Free Water Test",
  ctaHref = "/free-water-test/",
} = Astro.props;

// Responsive AVIF srcset so phones don't download the full 1920px desktop image.
const widths = [640, 828, 1080, 1280, 1920];
const images = await Promise.all(
  widths.map((w) =>
    getImage({ src: heroImageSrc, width: w, quality: 50, format: "avif" })
  )
);
const srcset = images
  .map((img) => `${img.src} ${img.options.width}w`)
  .join(", ");
const fallbackSrc = images[images.length - 1].src;
---

<section
  class="relative overflow-hidden min-h-[90vh] md:min-h-screen flex items-center justify-center"
>
  <!-- Background Layer (LCP element — eager + high priority) -->
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src={fallbackSrc}
      srcset={srcset}
      sizes="100vw"
      alt=""
      class="w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    {/* Premium gradient overlay */}
    <div
      class="absolute inset-0 bg-gradient-to-b from-[oklch(0.2_0.02_270_/_0.6)] via-[oklch(0.2_0.02_270_/_0.4)] to-[oklch(0.2_0.02_270_/_0.7)]"
    >
    </div>
    {/* Subtle blue accent overlay */}
    <div
      class="absolute inset-0 bg-gradient-to-br from-[oklch(0.7_0.1_220_/_0.1)] via-transparent to-[oklch(0.7_0.1_220_/_0.05)]"
    >
    </div>
  </div>

  <!-- Content Layer -->
  <div class="relative z-10 px-4 py-24 md:py-32 text-center max-w-5xl mx-auto">
    {/* Location Badge */}
    <div
      class="fade-up inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 mb-8"
    >
      <svg
        class="w-4 h-4 text-[oklch(0.85_0.05_220)]"
        fill="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
        ></path>
      </svg>
      <span class="text-sm font-medium text-white/90">
        Serving the Wasatch Front
      </span>
    </div>

    {/* Main Heading */}
    <h1
      class="fade-up text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-serif mb-6 leading-[1.1] text-white"
      style="text-shadow: 0 4px 20px rgba(0, 0, 0, 0.3)"
    >
      {title}
    </h1>

    {/* Subtitle */}
    <p
      class="fade-up text-xl md:text-2xl lg:text-3xl mb-4 text-white/90 font-light max-w-3xl mx-auto"
    >
      {subtitle}
    </p>

    {/* Tagline */}
    <p
      class="fade-up text-lg md:text-xl mb-10 text-[oklch(0.85_0.05_220)] font-medium"
    >
      {tagline}
    </p>

    {/* CTA Button */}
    <div class="fade-up">
      <a
        href={ctaHref}
        class="group relative inline-flex w-full sm:w-auto items-center justify-center gap-3 bg-glacier text-white font-semibold text-lg px-6 py-4 rounded-full shadow-lg transition-all duration-200 hover:scale-105 hover:bg-[oklch(0.55_0.12_220)] hover:shadow-2xl active:scale-[0.98]"
      >
        <span class="relative z-10">{ctaText}</span>
        <svg
          class="w-5 h-5 transition-transform duration-200 group-hover:translate-x-1"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"
          ></path>
        </svg>
      </a>
    </div>

    {/* Trust Indicators */}
    <div
      class="fade-up mt-12 flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-8 text-white/70 text-sm"
    >
      <div class="flex items-center gap-2">
        <svg
          class="w-5 h-5 text-[oklch(0.85_0.05_220)]"
          fill="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
          ></path>
        </svg>
        <span>Protecting Homes and Businesses</span>
      </div>
      <div class="hidden sm:block w-1 h-1 bg-white/40 rounded-full"></div>
      <div class="flex items-center gap-2">
        <svg
          class="w-5 h-5 text-[oklch(0.85_0.05_220)]"
          fill="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10zm-1-6l-4-4 1.41-1.41L11 13.17l5.59-5.59L18 9l-7 7z"
          ></path>
        </svg>
        <span>Professional Installation</span>
      </div>
      <div class="hidden sm:block w-1 h-1 bg-white/40 rounded-full"></div>
      <div class="flex items-center gap-2">
        <svg
          class="w-5 h-5 text-[oklch(0.85_0.05_220)]"
          fill="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"
          ></path>
        </svg>
        <span>Local Utah Team</span>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="hero-scroll absolute bottom-8 left-1/2 -translate-x-1/2 z-10">
    <svg
      class="w-6 h-6 text-white/60"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 14l-7 7m0 0l-7-7m7 7V3"
      ></path>
    </svg>
  </div>
</section>

<style>
  /* CSS-only staggered entrance — runs without JS so content paints immediately. */
  .fade-up {
    opacity: 0;
    transform: translateY(30px);
    animation: heroFadeUp 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }
  .fade-up:nth-child(1) {
    animation-delay: 0.2s;
  }
  .fade-up:nth-child(2) {
    animation-delay: 0.35s;
  }
  .fade-up:nth-child(3) {
    animation-delay: 0.5s;
  }
  .fade-up:nth-child(4) {
    animation-delay: 0.65s;
  }
  .fade-up:nth-child(5) {
    animation-delay: 0.8s;
  }
  .fade-up:nth-child(6) {
    animation-delay: 0.95s;
  }

  @keyframes heroFadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-scroll {
    animation: heroBounce 1.5s ease-in-out infinite;
  }
  @keyframes heroBounce {
    0%,
    100% {
      transform: translate(-50%, 0);
    }
    50% {
      transform: translate(-50%, 10px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fade-up {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .hero-scroll {
      animation: none;
    }
  }
</style>
