# Google Places API Configuration
# Get your API key from: https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=your_api_key_here

# Your Google Business Place ID
# Find it using: https://developers.google.com/maps/documentation/places/web-service/place-id
# Or use the format: ChIJ... (starts with ChIJ)
GOOGLE_PLACE_ID=your_place_id_here

# Public version of Place ID (used for frontend "Write a Review" link)
PUBLIC_GOOGLE_PLACE_ID=your_place_id_here
